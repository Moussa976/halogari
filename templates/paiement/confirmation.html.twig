{% extends 'base.html.twig' %}
{% import 'partials/avatar.html.twig' as avatar %}

{% set paiement = paiement ?? reservation.paiement %}
{% set paiementCapture = paiement and paiement.statut == 'capture' %}

{% block title %}HaloGari | {{ paiementCapture ? 'Paiement confirmé' : 'Paiement enregistré' }}{% endblock %}

{% block body %}
<section class="app-page-header app-page-header--compact">
  <div class="container">
    <p class="app-kicker">Paiement</p>
    <h1>{{ paiementCapture ? 'Paiement confirmé' : 'Paiement enregistré' }}</h1>
    <p>{{ paiementCapture ? 'Votre place est confirmée. Vous pouvez préparer votre trajet.' : 'Votre paiement est enregistré. Votre place est suivie par HaloGari.' }}</p>
  </div>
</section>

<section class="container hg-account-section reservation-confirmation">
  <article class="app-panel reservation-confirmation__card">
    <div class="reservation-success-icon">
      <i class="bi bi-shield-check"></i>
    </div>
    <div class="reservation-confirmation__intro">
      <h2>{{ paiementCapture ? 'Votre place est confirmée.' : 'Votre paiement est enregistré.' }}</h2>
      <p>
        {% if paiementCapture %}
          Votre réservation est payée. Votre place est bloquée pour ce trajet.
        {% else %}
          Votre paiement est enregistré. Vous n'avez rien d'autre à faire pour le moment.
        {% endif %}
      </p>
    </div>

    <div class="reservation-route-card">
      <div>
        <span>Départ</span>
        <strong>{{ reservation.trajet.depart }}</strong>
      </div>
      <i class="bi bi-arrow-right-short"></i>
      <div>
        <span>Arrivée</span>
        <strong>{{ reservation.trajet.arrivee }}</strong>
      </div>
    </div>

    <div class="reservation-stats">
      <div class="reservation-stat">
        <span>Date</span>
        <strong>{{ reservation.trajet.dateTrajet|date_fr('d F Y') }}</strong>
      </div>
      <div class="reservation-stat">
        <span>Heure</span>
        <strong>{{ reservation.trajet.heureTrajet|date('H:i') }}</strong>
      </div>
      <div class="reservation-stat">
        <span>Places</span>
        <strong>{{ reservation.places }}</strong>
      </div>
      <div class="reservation-stat">
        <span>{{ paiementCapture ? 'Total payé' : 'Montant payé' }}</span>
        <strong>{{ reservation.prixTotal|number_format(2, ',', ' ') }} €</strong>
      </div>
    </div>

    <div class="reservation-confirmation__driver">
      {{ avatar.formatSimple(reservation.trajet.conducteur, 52, 0, 1) }}
      <div>
        <span>Conducteur</span>
        <strong>{{ reservation.trajet.conducteur.prenom == 'Utilisateur supprimé' ? 'Utilisateur supprimé' : reservation.trajet.conducteur.prenom }}</strong>
      </div>
    </div>

    <div class="reservation-next-steps">
      <div class="reservation-next-step is-active">
        <span><i class="bi bi-check-circle-fill"></i></span>
        <p>{{ paiementCapture ? 'Votre place est confirmée.' : 'Votre paiement est enregistré.' }}</p>
      </div>
      <div class="reservation-next-step">
        <span><i class="bi bi-chat-dots-fill"></i></span>
        <p>Contactez le conducteur pour le lieu exact ou une question pratique.</p>
      </div>
      <div class="reservation-next-step">
        <span><i class="bi bi-flag-fill"></i></span>
        <p>Après le trajet, vous pourrez laisser un avis.</p>
      </div>
    </div>

    <div class="reservation-actions reservation-actions--center">
      <a href="{{ path('app_user_reservation', { id: reservation.id }) }}" class="btn btn-primary">
        <i class="bi bi-eye"></i>
        Suivre ma réservation
      </a>
      {% if reservation.trajet.conducteur.nom != 'Utilisateur supprimé' %}
        <a href="{{ path('app_conversation', { userId: reservation.trajet.conducteur.id, trajetId: reservation.trajet.id }) }}" class="btn btn-outline-primary">
          <i class="bi bi-chat-dots"></i>
          Écrire au conducteur
        </a>
        {% if reservation.trajet.conducteur.telephone %}
          <a href="tel:{{ reservation.trajet.conducteur.telephone }}" class="btn btn-outline-success">
            <i class="bi bi-telephone"></i>
            Appeler
          </a>
        {% endif %}
      {% endif %}
      <a href="{{ path('app_mes_reservations') }}" class="btn btn-outline-primary">
        <i class="bi bi-list-check"></i>
        Mes réservations
      </a>
    </div>
  </article>
</section>
{% endblock %}
