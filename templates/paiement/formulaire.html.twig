{% extends 'base.html.twig' %}
{% import 'partials/avatar.html.twig' as avatar %}

{% block title %}HaloGari | Paiement sécurisé{% endblock %}

{% block body %}
<section class="app-page-header app-page-header--compact">
  <div class="container">
    <p class="app-kicker">Paiement</p>
    <h1>Paiement sécurisé</h1>
    <p>Enregistrez votre paiement après acceptation du conducteur. HaloGari le finalisera selon le déroulement du trajet.</p>
  </div>
</section>

<section class="container hg-account-section payment-page">
  <div class="payment-layout payment-layout--checkout">
    <article class="app-panel payment-card">
      <div class="app-panel__header">
        <span class="app-panel__icon"><i class="bi bi-credit-card-2-front-fill"></i></span>
        <div>
          <h2>Carte bancaire</h2>
          <p>Les informations de carte sont traitées par Stripe, pas stockées par HaloGari.</p>
        </div>
      </div>

      <div class="payment-total payment-total--compact">
        <span>Montant sécurisé</span>
        <strong>{{ total|number_format(2, ',', ' ') }} €</strong>
      </div>

      <button class="btn btn-outline-primary payment-detail-toggle" type="button" data-bs-toggle="collapse" data-bs-target="#reservationPaymentDetail" aria-expanded="false" aria-controls="reservationPaymentDetail">
        <i class="bi bi-receipt"></i>
        Voir le détail de la réservation
      </button>

      <div class="collapse" id="reservationPaymentDetail">
        <div class="payment-summary payment-summary--collapsed">
          <div class="payment-route">
            <div>
              <span>Départ</span>
              <strong>{{ reservation.trajet.depart }}</strong>
            </div>
            <i class="bi bi-arrow-right-short"></i>
            <div>
              <span>Arrivée</span>
              <strong>{{ reservation.trajet.arrivee }}</strong>
            </div>
          </div>

          <div class="reservation-stats">
            <div class="reservation-stat">
              <span>Date</span>
              <strong>{{ reservation.trajet.dateTrajet|date_fr('d F Y') }}</strong>
            </div>
            <div class="reservation-stat">
              <span>Heure</span>
              <strong>{{ reservation.trajet.heureTrajet|date('H:i') }}</strong>
            </div>
            <div class="reservation-stat">
              <span>Places</span>
              <strong>{{ reservation.places }}</strong>
            </div>
          </div>

          <div class="payment-driver">
            {{ avatar.formatSimple(reservation.trajet.conducteur, 52, 0, 1) }}
            <div>
              <span>Conducteur</span>
              <strong>{{ reservation.trajet.conducteur.prenom == 'Utilisateur supprimé' ? 'Utilisateur supprimé' : reservation.trajet.conducteur.prenom }}</strong>
            </div>
          </div>
        </div>
      </div>

      <form id="payment-form" class="payment-form">
        <label for="card-element" class="form-label fw-bold">Numéro de carte</label>
        <div id="card-element" class="payment-card-element"></div>

        <div class="payment-note">
          <i class="bi bi-shield-lock-fill"></i>
          <p>Votre paiement est enregistré maintenant. HaloGari le finalisera au bon moment, puis traitera le reversement conducteur selon les règles prévues.</p>
        </div>

        <button class="btn btn-primary w-100" type="submit">
          <i class="bi bi-lock-fill"></i>
          Enregistrer le paiement
        </button>
        <div id="payment-result" class="mt-3"></div>
      </form>
    </article>
  </div>
</section>
{% endblock %}

{% block javascripts %}
<script src="https://js.stripe.com/v3/"></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
  const stripe = Stripe('{{ stripePublicKey }}');
  const elements = stripe.elements();
  const card = elements.create('card');
  card.mount('#card-element');

  const form = document.getElementById('payment-form');
  const resultDiv = document.getElementById('payment-result');

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    resultDiv.innerHTML = '';

    const submitButton = form.querySelector('button[type="submit"]');
    submitButton.disabled = true;
    submitButton.innerHTML = '<span class="spinner-border spinner-border-sm" aria-hidden="true"></span> Enregistrement...';

    const { error, paymentIntent } = await stripe.confirmCardPayment('{{ clientSecret }}', {
      payment_method: {
        card: card,
        billing_details: {
          name: '{{ (reservation.passager.nom ~ ' ' ~ reservation.passager.prenom)|e('js') }}',
          email: '{{ reservation.passager.email|e('js') }}'
        }
      }
    });

    if (error) {
      resultDiv.innerHTML = `<div class="alert alert-danger">Paiement refusé : ${error.message}</div>`;
      submitButton.disabled = false;
      submitButton.innerHTML = '<i class="bi bi-lock-fill"></i> Enregistrer le paiement';
      return;
    }

    if (paymentIntent.status === 'requires_capture' || paymentIntent.status === 'succeeded') {
      resultDiv.innerHTML = '<div class="alert alert-success">Paiement enregistré. Redirection...</div>';
      window.setTimeout(() => {
        window.location.href = '{{ path("paiement_confirmation", { id: reservation.id }) }}';
      }, 1200);
      return;
    }

    resultDiv.innerHTML = `<div class="alert alert-warning">Paiement en statut inattendu : ${paymentIntent.status}</div>`;
    submitButton.disabled = false;
    submitButton.innerHTML = '<i class="bi bi-lock-fill"></i> Enregistrer le paiement';
  });
});
</script>
{% endblock %}
