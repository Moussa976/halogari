{% extends 'base.html.twig' %}

{% block title %}HaloGari | Covoiturage à Mayotte{% endblock %}
{% block meta_description %}Cherchez ou publiez un trajet de covoiturage à Mayotte avec HaloGari. Une solution locale pour partager les places, réduire les coûts et voyager plus sereinement.{% endblock %}

{% set trajetsFallback = [
  { depart: 'Koungou', arrivee: 'Mamoudzou', total: 4 },
  { depart: 'Chirongui', arrivee: 'Sada', total: 2 },
  { depart: 'Sada', arrivee: 'Mamoudzou', total: 1 }
] %}
{% set trajetsAffiches = popularTrajets|length > 0 ? popularTrajets : trajetsFallback %}

{% block body %}
<header class="app-hero home-hero">
  <div class="container app-hero__inner">
    <div class="app-hero__content">
      <p class="app-kicker">Mayotte bouge ensemble</p>
      <h1>Un trajet simple, une place partagée.</h1>
      <p class="app-hero__lead">Trouvez un conducteur proche de vous ou proposez vos places libres en quelques secondes.</p>

    </div>

    <button type="button" class="home-search-mobile-trigger" data-home-search-open aria-controls="form-recherche" aria-expanded="false">
      <i class="bi bi-search"></i>
      <span>
        <strong>Votre départ → Votre destination</strong>
        <small>Aujourd'hui, 1 passager</small>
      </span>
      <b>Rechercher</b>
    </button>

    <form method="GET" action="{{ path('app_chercher') }}" id="form-recherche" class="quick-search search-page-form search-page-form--wide home-search-form" aria-label="Recherche rapide">
      <div class="home-search-form__mobile-head">
        <button type="button" class="home-search-form__close" data-home-search-close aria-label="Fermer la recherche">
          <i class="bi bi-x-lg"></i>
        </button>
        <strong>Où souhaitez-vous aller ?</strong>
      </div>
      <div class="ride-scene" aria-hidden="true">
        <div class="ride-scene__sign ride-scene__sign--start">Départ</div>
        <div class="ride-scene__road"></div>
        <div class="ride-scene__group ride-scene__group--start">
          <span></span><span></span>
        </div>
        <div class="ride-scene__van">
          <i class="bi bi-car-front-fill"></i>
          <div class="ride-scene__passengers">
            <span></span><span></span>
          </div>
        </div>
        <div class="ride-scene__group ride-scene__group--arrival">
          <span></span><span></span>
        </div>
        <div class="ride-scene__sign ride-scene__sign--end">Arrivée</div>
      </div>
      <div class="quick-search__title search-page-form__title">
        <strong>Où allez-vous ?</strong>
        <span>Recherche rapide</span>
      </div>

      <div class="input-group search-form-field">
        <span class="input-group-text text-vert"><i class="bi bi-geo-fill"></i></span>
        <div class="form-floating">
          <input id="select_departure" class="form-control villages" name="select_departure" placeholder="Village de départ" required>
          <label for="select_departure">Départ</label>
        </div>
      </div>

      <div class="input-group search-form-field">
        <span class="input-group-text text-vert"><i class="bi bi-flag-fill"></i></span>
        <div class="form-floating">
          <input id="select_arrival" name="select_arrival" class="form-control villages" placeholder="Village d'arrivée" required>
          <label for="select_arrival">Arrivée</label>
        </div>
      </div>

      <div class="quick-search__row">
        <div class="input-group search-form-field">
          <span class="input-group-text text-vert"><i class="bi bi-calendar2-event-fill"></i></span>
          <div class="form-floating">
            <input type="text" id="date_trajet" class="form-control dateDepart" name="date_trajet" value="{{ todayDisplayDate }}" placeholder="jj/mm/aaaa" data-default-today="true" required>
            <label for="date_trajet">Date</label>
          </div>
        </div>

        <div class="input-group search-form-field">
          <span class="input-group-text text-vert"><i class="bi bi-people-fill"></i></span>
          <div class="form-floating">
            <select class="form-select" id="places_min" name="places_min">
              {% for i in 1..8 %}
                <option value="{{ i }}" {{ i == 1 ? 'selected' : '' }}>{{ i }}</option>
              {% endfor %}
            </select>
            <label for="places_min">Places</label>
          </div>
        </div>
      </div>

      <button type="submit" class="btn btn-orange btn-lg w-100" data-loading-button data-loading-label="Recherche">
        <i class="bi bi-search"></i>
        Voir les trajets
      </button>
    </form>
  </div>
</header>

<section class="app-band home-feature-section">
  <div class="container">
    <div class="app-section-heading">
      <p class="app-kicker">Simple pour tous</p>
      <h2>Les actions importantes restent visibles.</h2>
    </div>

    <div class="feature-grid">
      <article class="feature-card">
        <img src="{{ asset('images/petit-prix.png') }}" alt="" width="44" height="44">
        <h3>Prix clair</h3>
        <p>Le passager voit le prix par place avant de réserver.</p>
      </article>
      <article class="feature-card">
        <img src="{{ asset('images/confiance.png') }}" alt="" width="44" height="44">
        <h3>Profils vérifiés</h3>
        <p>Documents, messages et confirmations aident à voyager sereinement.</p>
      </article>
      <article class="feature-card">
        <img src="{{ asset('images/rapide.png') }}" alt="" width="44" height="44">
        <h3>Réponse rapide</h3>
        <p>Les notifications préviennent conducteur et passager au bon moment.</p>
      </article>
    </div>
  </div>
</section>

<section class="app-band app-band--light home-routes-section">
  <div class="container">
    <div class="app-section-heading">
      <p class="app-kicker">Trajets populaires</p>
      <h2>Les lignes les plus demandées.</h2>
    </div>

    <div class="route-list">
      {% for trajet in trajetsAffiches|slice(0, 3) %}
        <a class="route-item" href="{{ path('app_chercher') ~ '?select_departure=' ~ trajet.depart|url_encode ~ '&select_arrival=' ~ trajet.arrivee|url_encode ~ '&date_trajet=' ~ todaySearchDate ~ '&places_min=1' }}">
          <span class="route-item__icon"><i class="bi bi-signpost-2"></i></span>
          <span>
            <strong>{{ trajet.depart }} vers {{ trajet.arrivee }}</strong>
            <small>{{ trajet.total }} réservation{{ trajet.total > 1 ? 's' : '' }}</small>
          </span>
          <i class="bi bi-chevron-right"></i>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

<section class="trust-strip">
  <div class="container trust-strip__inner">
    <div class="trust-strip__content">
      <p class="app-kicker">Sécurité</p>
      <h2>Une communauté locale, avec des règles claires.</h2>
      <p>HaloGari accompagne les profils vérifiés, les paiements sécurisés, les avis et les notifications importantes.</p>
    </div>
    <div class="trust-strip__checks" aria-label="Points de confiance HaloGari">
      <span><i class="bi bi-patch-check-fill"></i> Profils vérifiés</span>
      <span><i class="bi bi-credit-card-2-front-fill"></i> Paiements protégés</span>
      <span><i class="bi bi-bell-fill"></i> Alertes utiles</span>
    </div>
    <a href="{{ path('app_securite') }}" class="btn btn-light btn-lg trust-strip__button">
      <i class="bi bi-shield-check"></i>
      Voir la sécurité
    </a>
  </div>
</section>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "HaloGari",
      "url": "{{ absolute_url(path('app_home')) }}",
      "logo": "{{ absolute_url(asset('images/logo/logo-787x298.png')) }}",
      "sameAs": [
        "https://www.facebook.com/profile.php?id=61591126017246"
      ]
    }
  </script>
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "HaloGari",
      "url": "{{ absolute_url(path('app_home')) }}"
    }
  </script>
  <script>
    (() => {
      const trigger = document.querySelector('[data-home-search-open]');
      const form = document.querySelector('.home-search-form');
      const close = document.querySelector('[data-home-search-close]');

      if (!trigger || !form || !close) {
        return;
      }

      const open = () => {
        form.classList.add('is-mobile-open');
        trigger.setAttribute('aria-expanded', 'true');
        document.body.classList.add('home-search-is-open');
        window.setTimeout(() => form.querySelector('.villages')?.focus(), 80);
      };

      const hide = () => {
        form.classList.remove('is-mobile-open');
        trigger.setAttribute('aria-expanded', 'false');
        document.body.classList.remove('home-search-is-open');
      };

      trigger.addEventListener('click', open);
      close.addEventListener('click', hide);
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && form.classList.contains('is-mobile-open')) {
          hide();
        }
      });
    })();
  </script>
{% endblock %}
