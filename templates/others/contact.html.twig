{% extends 'base.html.twig' %}

{% block title %}HaloGari | Contact{% endblock %}
{% block meta_description %}Contactez HaloGari pour une question sur un trajet, une réservation, un paiement, un document ou l’utilisation du covoiturage à Mayotte.{% endblock %}

{% block body %}
{% set canContact = app.user is not null %}
<section class="app-page-header app-page-header--compact">
  <div class="container">
    <p class="app-kicker">Support WEB976</p>
    <h1>Nous contacter</h1>
    <p>Une question, une idée, un souci de réservation ou de paiement ? Écrivez-nous avec les détails utiles.</p>
  </div>
</section>

<section class="container auth-layout">
  <div class="auth-card">
    <form method="POST" action="{{ path('app_contact') }}" class="app-panel app-panel--form auth-form contact-form {{ not canContact ? 'contact-form--locked' : '' }}">
      <div class="auth-form__heading">
        <span><i class="bi bi-envelope-paper-heart-fill"></i></span>
        <div>
          <h2>Votre message</h2>
          <p>Plus votre message est précis, plus la réponse peut être rapide et utile.</p>
        </div>
      </div>

      {% if not canContact %}
        <div class="contact-login-notice">
          <i class="bi bi-lock-fill"></i>
          <div>
            <strong>Connexion requise</strong>
            <span>Connectez-vous pour écrire au support depuis votre compte HaloGari.</span>
          </div>
        </div>
      {% endif %}

      <fieldset class="hg-form-grid contact-form__fields" {{ not canContact ? 'disabled' : '' }}>
        <div class="form-floating">
          <input type="text" class="form-control" id="nom" name="nom" placeholder="Votre nom" autocomplete="name" value="{{ canContact ? app.user.nom ~ ' ' ~ app.user.prenom : '' }}" readonly disabled>
          <label for="nom">Nom</label>
        </div>

        <div class="form-floating">
          <input type="email" class="form-control" id="email" name="email" placeholder="exemple@halogari.yt" autocomplete="email" inputmode="email" value="{{ canContact ? app.user.email : '' }}" readonly disabled>
          <label for="email">E-mail</label>
        </div>

        <div class="form-floating hg-form-full">
          <input type="text" class="form-control" id="sujet" name="sujet" placeholder="Sujet" required {{ not canContact ? 'disabled' : '' }}>
          <label for="sujet">Sujet</label>
        </div>

        <div class="form-floating hg-form-full">
          <textarea class="form-control app-message-textarea" id="message" name="message" rows="8" placeholder="Écrivez votre message ici..." required></textarea>
          <label for="message">Message</label>
        </div>
        <div class="field-hint hg-form-full">Ajoutez si possible : la date, le départ, l’arrivée et les personnes concernées.</div>
      </fieldset>

      <div class="hg-form-actions">
        {% if canContact %}
          <input type="hidden" name="_token" value="{{ csrf_token('contact_message') }}">
          <button type="submit" class="btn btn-orange">
            <i class="bi bi-send-fill"></i>
            Envoyer
          </button>
        {% else %}
          <a href="{{ path('app_login', { next: app.request.requestUri }) }}" class="btn btn-orange">
            <i class="bi bi-box-arrow-in-right"></i>
            Se connecter pour écrire
          </a>
        {% endif %}
      </div>
    </form>
    {% if not canContact %}
      <script>
      document.querySelectorAll('.contact-form input, .contact-form textarea').forEach((field) => {
        field.disabled = true;
      });
      </script>
    {% endif %}
  </div>

  <aside class="app-panel auth-aside">
    <span class="app-panel__icon"><i class="bi bi-chat-heart"></i></span>
    <h2>WEB976</h2>
    <p>HaloGari est créé par l'association WEB976 et développé par Moussa INSSA.</p>
    <p>Vous pouvez aussi écrire directement à <a href="mailto:contact@halogari.yt">contact@halogari.yt</a>.</p>
    <div class="tip-list">
      <span><i class="bi bi-check-circle-fill"></i> Réservations</span>
      <span><i class="bi bi-check-circle-fill"></i> Documents et profil</span>
      <span><i class="bi bi-check-circle-fill"></i> Paiements et remboursements</span>
    </div>
  </aside>
</section>
{% endblock %}
