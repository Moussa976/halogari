{% extends 'base.html.twig' %}

{% block title %}HaloGari | Contact{% endblock %}

{% block body %}
<section class="app-page-header app-page-header--compact">
  <div class="container">
    <p class="app-kicker">Support WEB976</p>
    <h1>Nous contacter</h1>
    <p>Une question, une idée, un souci de réservation ou de paiement ? Écrivez-nous avec les détails utiles.</p>
  </div>
</section>

<section class="container auth-layout">
  <div class="auth-card">
    <form method="POST" action="{{ path('app_contact') }}" class="app-panel app-panel--form auth-form">
      <div class="auth-form__heading">
        <span><i class="bi bi-envelope-paper-heart-fill"></i></span>
        <div>
          <h2>Votre message</h2>
          <p>Plus votre message est précis, plus la réponse peut être rapide et utile.</p>
        </div>
      </div>

      <div class="hg-form-grid">
        <div class="form-floating">
          <input type="text" class="form-control" id="nom" name="nom" placeholder="Votre nom" autocomplete="name" required {% if app.user %}value="{{ app.user.nom ~ ' ' ~ app.user.prenom }}"{% endif %}>
          <label for="nom">Nom</label>
        </div>

        <div class="form-floating">
          <input type="email" class="form-control" id="email" name="email" placeholder="exemple@halogari.yt" autocomplete="email" inputmode="email" required {% if app.user %}value="{{ app.user.email }}"{% endif %}>
          <label for="email">E-mail</label>
        </div>

        <div class="form-floating hg-form-full">
          <input type="text" class="form-control" id="sujet" name="sujet" placeholder="Sujet" required>
          <label for="sujet">Sujet</label>
        </div>

        <div class="form-floating hg-form-full">
          <textarea class="form-control app-message-textarea" id="message" name="message" rows="8" placeholder="Écrivez votre message ici..." required></textarea>
          <label for="message">Message</label>
        </div>
        <div class="field-hint hg-form-full">Ajoutez si possible : date du trajet, départ, arrivée, conducteur, passager ou numéro de réservation.</div>
      </div>

      <div class="hg-form-actions">
        <button type="submit" class="btn btn-orange">
          <i class="bi bi-send-fill"></i>
          Envoyer
        </button>
      </div>
    </form>
  </div>

  <aside class="app-panel auth-aside">
    <span class="app-panel__icon"><i class="bi bi-chat-heart"></i></span>
    <h2>WEB976</h2>
    <p>HaloGari est créé par l'association WEB976 et développé par Moussa INSSA.</p>
    <p>Vous pouvez aussi écrire directement à <a href="mailto:moussa@halogari.yt">moussa@halogari.yt</a>.</p>
    <div class="tip-list">
      <span><i class="bi bi-check-circle-fill"></i> Réservations</span>
      <span><i class="bi bi-check-circle-fill"></i> Documents et profil</span>
      <span><i class="bi bi-check-circle-fill"></i> Paiements et remboursements</span>
    </div>
  </aside>
</section>
{% endblock %}
