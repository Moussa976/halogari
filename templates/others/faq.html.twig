{% extends 'base.html.twig' %}

{% block title %}HaloGari | FAQ{% endblock %}

{% block body %}
<section class="app-page-header app-page-header--compact">
  <div class="container">
    <p class="app-kicker">Aide rapide</p>
    <h1>Foire aux questions</h1>
    <p>Les réponses essentielles pour utiliser HaloGari comme passager ou conducteur.</p>
  </div>
</section>

<section class="container app-page-grid">
  <div class="app-panel">
    {% set faq = [
      {
        question: "Qui crée HaloGari ?",
        reponse: "HaloGari est une application créée par l'association WEB976 pour Mayotte. Le développement est assuré par Moussa INSSA."
      },
      {
        question: "Comment chercher un trajet ?",
        reponse: "Indiquez le village de départ, le village d'arrivée, la date et le nombre de places. Les champs de villages proposent des résultats après quelques caractères pour éviter les longues listes."
      },
      {
        question: "Comment réserver une place ?",
        reponse: "Ouvrez un trajet, choisissez le nombre de places, puis envoyez votre demande. Le conducteur peut accepter ou refuser selon les disponibilités."
      },
      {
        question: "Comment publier un trajet ?",
        reponse: "Connectez-vous, ouvrez Publier, indiquez le départ, l'arrivée, la date, l'heure, les places, le prix et les informations utiles pour les passagers."
      },
      {
        question: "Pourquoi dois-je vérifier mon profil ?",
        reponse: "La vérification aide à rassurer les autres utilisateurs. Elle permet aussi d'activer certaines fonctionnalités comme les paiements conducteur."
      },
      {
        question: "Quels documents peuvent être demandés ?",
        reponse: "Un justificatif d'identité et un RIB peuvent être demandés selon votre usage. Les fichiers sont pré-contrôlés techniquement, puis validés ou refusés par l'administration HaloGari."
      },
      {
        question: "Comment installer HaloGari sur mon téléphone ?",
        reponse: "Sur iPhone, ouvrez HaloGari dans Safari, appuyez sur le bouton de partage, puis choisissez « Sur l'écran d'accueil ». Sur Android, utilisez le bouton « Installer HaloGari » quand il apparaît, ou le menu du navigateur puis « Installer l'application ». Si HaloGari est déjà installée, utilisez simplement l'icône ajoutée sur votre écran d'accueil."
      },
      {
        question: "Les paiements sont-ils sécurisés ?",
        reponse: "Oui. Les paiements sont gérés via Stripe. Après acceptation du conducteur, vous enregistrez votre paiement, puis HaloGari le finalise selon le déroulement du trajet. HaloGari ne stocke pas les numéros complets de carte bancaire."
      },
      {
        question: "Quelle est la politique de remboursement ?",
        reponse: 'Elle dépend du moment de l\'annulation et de la personne qui annule. Consultez la <a href="' ~ path('app_conditionsutisation') ~ '#remboursement">politique de remboursement</a>.'
      },
      {
        question: "Comment supprimer mon compte ?",
        reponse: "Depuis Paramètres, ouvrez la zone sensible et confirmez avec votre mot de passe actuel. Le compte est désactivé pendant 15 jours, puis la suppression définitive est programmée."
      },
      {
        question: "Comment contacter le support ?",
        reponse: 'Utilisez la page <a href="' ~ path('app_contact') ~ '">Contact</a> ou écrivez à <a href="mailto:moussa@halogari.yt">moussa@halogari.yt</a>.'
      }
    ] %}

    <div class="accordion" id="faqAccordion">
      {% for item in faq %}
        <div class="accordion-item">
          <h2 class="accordion-header" id="heading{{ loop.index }}">
            <button class="accordion-button {% if not loop.first %}collapsed{% endif %}" type="button" data-bs-toggle="collapse" data-bs-target="#collapse{{ loop.index }}" aria-expanded="{{ loop.first ? 'true' : 'false' }}" aria-controls="collapse{{ loop.index }}">
              {{ item.question }}
            </button>
          </h2>
          <div id="collapse{{ loop.index }}" class="accordion-collapse collapse {% if loop.first %}show{% endif %}" aria-labelledby="heading{{ loop.index }}" data-bs-parent="#faqAccordion">
            <div class="accordion-body">{{ item.reponse|raw }}</div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>

  <aside class="app-panel app-tips-panel">
    <span class="app-panel__icon"><i class="bi bi-question-circle"></i></span>
    <h2>Pas trouvé ?</h2>
    <p>Envoyez-nous un message avec les détails du trajet, du compte, du paiement ou du document concerné.</p>
    <a href="{{ path('app_contact') }}" class="btn btn-orange w-100">
      <i class="bi bi-send-fill"></i>
      Contacter le support
    </a>
  </aside>
</section>
{% endblock %}
