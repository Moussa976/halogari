<!DOCTYPE html>
<html lang="fr">
	<head>
		<meta charset="UTF-8">
		<title>
			{% block title %}Admin | HaloGari
			{% endblock %}
		</title>

		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
		<link href="https://unpkg.com/@adminkit/core@latest/dist/css/app.css" rel="stylesheet">
		<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">

		<style>
			.hg-avatar-wrap {
				position: relative;
				display: inline-flex;
				flex: 0 0 auto;
				align-items: center;
				justify-content: center;
				line-height: 1;
				vertical-align: middle;
				max-width: min(100%, 128px);
				max-height: 128px;
				aspect-ratio: 1 / 1;
				overflow: visible;
			}
			.hg-avatar-wrap .profile-avatar,
			.hg-avatar-wrap img {
				width: 100%;
				height: 100%;
				max-width: 100%;
				max-height: 100%;
				object-fit: cover;
				aspect-ratio: 1 / 1;
				border: 2px solid rgba(206, 212, 218, .95);
				border-radius: 50%;
				background-color: #fff;
			}
			.hg-avatar-wrap.is-verified .profile-avatar,
			.hg-avatar-wrap.is-verified img {
				border-color: #22c55e !important;
			}
			.hg-verified-badge {
				position: absolute;
				left: 50%;
				bottom: 0;
				transform: translate(-50%, 42%);
				z-index: 2;
				width: clamp(16px, 38%, 24px);
				height: clamp(16px, 38%, 24px);
				display: inline-flex;
				align-items: center;
				justify-content: center;
				color: #fff;
				border: 2px solid #22c55e;
				border-radius: 999px;
				background: linear-gradient(135deg, #166534, #22c55e);
				box-shadow: 0 6px 14px rgba(22, 101, 52, .28);
				font-size: clamp(.65rem, 45%, .9rem);
			}
			.img-note .profile-avatar {
				width: 100%;
				height: 100%;
				object-fit: cover;
				border-radius: 50%;
				border: 2px solid rgb(206, 212, 218);
				background-color: #fff;
				position: relative;
				z-index: 1;
			}
			.img-note.verified .profile-avatar {
				border: 2px solid #28a745;
			}
			.img-note.verified::after {
				content: "\F531";
				font-family: 'bootstrap-icons';
				font-size: 10px;
				position: absolute;
				bottom: -10px;
				right: 40%;
				background-color: #fff;
				color: #28a745;
				border-radius: 50%;
				padding: 0;
				z-index: 100;
			}
			.table-responsive,
			.table-responsive-sm,
			.table-responsive-md,
			.table-responsive-lg,
			.table-responsive-xl,
			.table-responsive-xxl {
				overflow-x: auto;
				overflow-y: hidden;
				-webkit-overflow-scrolling: touch;
			}
			.table-responsive > .table,
			.table-responsive-sm > .table,
			.table-responsive-md > .table,
			.table-responsive-lg > .table,
			.table-responsive-xl > .table,
			.table-responsive-xxl > .table {
				min-width: 720px;
				margin-bottom: 0;
			}
			.admin-table-tools {
				display: grid;
				grid-template-columns: minmax(220px, 1fr) auto;
				gap: .75rem;
				align-items: end;
				margin-bottom: 1rem;
			}
			.admin-table-empty {
				display: none;
				margin: .75rem 0 0;
			}
			.admin-sort-button {
				width: 100%;
				display: inline-flex;
				align-items: center;
				justify-content: space-between;
				gap: .5rem;
				padding: 0;
				color: inherit;
				font: inherit;
				font-weight: 700;
				text-align: left;
				background: transparent;
				border: 0;
			}
			.admin-sort-button:hover,
			.admin-sort-button:focus {
				color: #245c36;
			}
			.admin-sort-icon {
				flex: 0 0 auto;
				min-width: 1rem;
				color: #adb5bd;
				font-size: .78rem;
				text-align: center;
			}
			.admin-sort-button.is-active .admin-sort-icon {
				color: #245c36;
			}
			.admin-dashboard-chart {
				position: relative;
				width: 100%;
				height: 320px;
				max-height: 46vh;
				min-height: 260px;
			}
			.admin-dashboard-chart canvas {
				display: block;
				width: 100% !important;
				height: 100% !important;
			}
			@media (max-width: 767.98px) {
				.admin-table-tools {
					grid-template-columns: 1fr;
				}
				.admin-table-tools .btn {
					width: 100%;
				}
				.admin-dashboard-chart {
					height: 260px;
					min-height: 220px;
				}
			}
		</style>

		{% block stylesheets %}{% endblock %}
	</head>

	<body>
		<div class="wrapper">
			{% include 'admin/_sidebar.html.twig' %}
			<div class="main">
				{% include 'admin/_navbar.html.twig' %}
				<main class="content container-fluid py-4"> {% block body %}{% endblock %}
					</main>
					<footer class="footer bg-light mt-4 py-3 border-top">
						<div class="container-fluid">
							<div class="row text-muted">
								<div class="col-6 text-start">
									<p class="mb-0">
										<span class="text-muted">©
											{{ "now"|date("Y") }}
											<strong>HaloGari</strong>
										</span>
										– Mobilité partagée à Mayotte.
									</p>
								</div>
								<div class="col-6 text-end">
									<ul class="list-inline mb-0">
										<li class="list-inline-item">
											<a class="text-muted" href="https://halogari.yt/mentions-legales" target="_blank">Mentions légales</a>
										</li>
										<li class="list-inline-item">
											<a class="text-muted" href="mailto:moussa@halogari.yt">Support</a>
										</li>
										<li class="list-inline-item">
											<a class="text-muted" href="https://halogari.yt/confidentialite" target="_blank">Confidentialité</a>
										</li>
										<li class="list-inline-item">
											<a class="text-muted" href="https://halogari.yt/cgu" target="_blank">CGU</a>
										</li>
									</ul>
								</div>
							</div>
						</div>
					</footer>

				</div>
			</div>

			{# ✅ Bootstrap JS avec SRI completé #}
			<script src="https://unpkg.com/@adminkit/core@latest/dist/js/app.js"></script>
			<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.21.0/dist/sweetalert2.all.min.js"></script>
			<script>
				document.addEventListener('DOMContentLoaded', () => {
					document.querySelectorAll('.js-admin-table').forEach((table, tableIndex) => {
						const body = table.tBodies[0];
						const headers = Array.from(table.querySelectorAll('thead th'));
						if (!body || headers.length === 0 || table.dataset.enhanced === '1') {
							return;
						}

						table.dataset.enhanced = '1';
						const wrapper = table.closest('.table-responsive') || table.parentElement;
						const tools = document.createElement('div');
						tools.className = 'admin-table-tools';
						tools.innerHTML = `
							<div>
								<label class="form-label small text-muted" for="admin-table-search-${tableIndex}">Recherche</label>
								<input id="admin-table-search-${tableIndex}" type="search" class="form-control" placeholder="Rechercher dans le tableau">
							</div>
							<button type="button" class="btn btn-outline-secondary">Réinitialiser</button>
						`;

						const empty = document.createElement('div');
						empty.className = 'alert alert-light border text-muted admin-table-empty';
						empty.textContent = 'Aucun résultat pour cette recherche.';

						wrapper.before(tools);
						wrapper.after(empty);

						const globalInput = tools.querySelector('input');
						const resetButton = tools.querySelector('button');
						const rows = Array.from(body.rows).filter(row => row.cells.length === headers.length);
						const originalRows = rows.slice();
						const normalize = value => (value || '').toString().toLocaleLowerCase('fr-FR').normalize('NFD').replace(/[\u0300-\u036f]/g, '');
						const getCellText = (row, columnIndex) => row.cells[columnIndex]?.textContent.trim() || '';
						const asSortableValue = value => {
							const numeric = normalize(value).replace(/\s/g, '').replace(',', '.').replace(/[^\d.-]/g, '');
							if (numeric && !Number.isNaN(Number(numeric))) {
								return Number(numeric);
							}

							const dateMatch = value.match(/^(\d{2})\/(\d{2})\/(\d{4})(?:\s+[àa]\s+|\s+)?(\d{2}:\d{2})?/i);
							if (dateMatch) {
								const [, day, month, year, time = '00:00'] = dateMatch;
								return new Date(`${year}-${month}-${day}T${time}:00`).getTime();
							}

							return normalize(value);
						};

						const applySearch = () => {
							const globalNeedle = normalize(globalInput.value);
							let visibleCount = 0;

							rows.forEach(row => {
								const rowText = normalize(row.textContent);
								const visible = !globalNeedle || rowText.includes(globalNeedle);
								row.hidden = !visible;
								if (visible) {
									visibleCount++;
								}
							});

							empty.style.display = rows.length > 0 && visibleCount === 0 ? 'block' : 'none';
						};

						headers.forEach((header, columnIndex) => {
							const label = header.textContent.trim();
							if (!label || label.toLowerCase() === 'actions') {
								return;
							}

							header.dataset.sortDirection = '';
							header.innerHTML = '';
							const button = document.createElement('button');
							button.type = 'button';
							button.className = 'admin-sort-button';
							button.innerHTML = `<span>${label}</span><span class="admin-sort-icon" aria-hidden="true">↕</span>`;
							button.setAttribute('aria-label', `Trier par ${label}`);
							header.appendChild(button);

							button.addEventListener('click', () => {
								const direction = header.dataset.sortDirection === 'asc' ? 'desc' : 'asc';

								headers.forEach(otherHeader => {
									otherHeader.dataset.sortDirection = '';
									otherHeader.querySelector('.admin-sort-button')?.classList.remove('is-active');
									const icon = otherHeader.querySelector('.admin-sort-icon');
									if (icon) {
										icon.textContent = '↕';
									}
								});

								header.dataset.sortDirection = direction;
								button.classList.add('is-active');
								button.querySelector('.admin-sort-icon').textContent = direction === 'asc' ? '↑' : '↓';

								rows.slice().sort((a, b) => {
									const valueA = asSortableValue(getCellText(a, columnIndex));
									const valueB = asSortableValue(getCellText(b, columnIndex));

									if (typeof valueA === 'number' && typeof valueB === 'number') {
										return direction === 'asc' ? valueA - valueB : valueB - valueA;
									}

									return direction === 'asc'
										? String(valueA).localeCompare(String(valueB), 'fr-FR')
										: String(valueB).localeCompare(String(valueA), 'fr-FR');
								}).forEach(row => body.appendChild(row));

								applySearch();
							});
						});

						globalInput.addEventListener('input', applySearch);
						resetButton.addEventListener('click', () => {
							globalInput.value = '';
							headers.forEach(header => {
								header.dataset.sortDirection = '';
								header.querySelector('.admin-sort-button')?.classList.remove('is-active');
								const icon = header.querySelector('.admin-sort-icon');
								if (icon) {
									icon.textContent = '↕';
								}
							});
							originalRows.forEach(row => body.appendChild(row));
							applySearch();
						});
					});
				});
			</script>

			{% for type, messages in app.flashes %}
				{% for message in messages %}
					<script>
						const type = "{{ type }}";
const icons = [
'success',
'error',
'warning',
'info',
'question'
];
Swal.fire({
icon: icons.includes(type) ? type : 'info',
title: {
success: "Réussite",
error: "Échec",
warning: "Attention",
info: "Information",
question: "Question"
}[type] || "Message",
text: "{{ message|e('js') }}",
timer: ['error', 'warning'].includes(type) ? 10000 : 3000,
showConfirmButton: false
});
					</script>
				{% endfor %}
			{% endfor %}

			{% block scripts %}{% endblock %}


		</body>
	</html>
