<!DOCTYPE html>
<html lang="fr">
	<head>
		<meta charset="UTF-8">
		<title>
			{% block title %}Admin | HaloGari
			{% endblock %}
		</title>

		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
		<link href="https://unpkg.com/@adminkit/core@latest/dist/css/app.css" rel="stylesheet">
		<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">

		<style>
			.hg-avatar-wrap {
				position: relative;
				display: inline-flex;
				flex: 0 0 auto;
				align-items: center;
				justify-content: center;
				line-height: 1;
				vertical-align: middle;
				max-width: min(100%, 128px);
				max-height: 128px;
				aspect-ratio: 1 / 1;
				overflow: visible;
			}
			.hg-avatar-wrap .profile-avatar,
			.hg-avatar-wrap img {
				width: 100%;
				height: 100%;
				max-width: 100%;
				max-height: 100%;
				object-fit: cover;
				aspect-ratio: 1 / 1;
				border: 2px solid rgba(206, 212, 218, .95);
				border-radius: 50%;
				background-color: #fff;
			}
			.hg-avatar-wrap.is-verified .profile-avatar,
			.hg-avatar-wrap.is-verified img {
				border-color: #22c55e !important;
			}
			.hg-verified-badge {
				position: absolute;
				left: 50%;
				bottom: 0;
				transform: translate(-50%, 42%);
				z-index: 2;
				width: clamp(16px, 38%, 24px);
				height: clamp(16px, 38%, 24px);
				display: inline-flex;
				align-items: center;
				justify-content: center;
				color: #fff;
				border: 2px solid #22c55e;
				border-radius: 999px;
				background: linear-gradient(135deg, #166534, #22c55e);
				box-shadow: 0 6px 14px rgba(22, 101, 52, .28);
				font-size: clamp(.65rem, 45%, .9rem);
			}
			.img-note .profile-avatar {
				width: 100%;
				height: 100%;
				object-fit: cover;
				border-radius: 50%;
				border: 2px solid rgb(206, 212, 218);
				background-color: #fff;
				position: relative;
				z-index: 1;
			}
			.img-note.verified .profile-avatar {
				border: 2px solid #28a745;
			}
			.img-note.verified::after {
				content: "\F531";
				font-family: 'bootstrap-icons';
				font-size: 10px;
				position: absolute;
				bottom: -10px;
				right: 40%;
				background-color: #fff;
				color: #28a745;
				border-radius: 50%;
				padding: 0;
				z-index: 100;
			}
			.table-responsive,
			.table-responsive-sm,
			.table-responsive-md,
			.table-responsive-lg,
			.table-responsive-xl,
			.table-responsive-xxl {
				overflow-x: auto;
				overflow-y: hidden;
				-webkit-overflow-scrolling: touch;
			}
			.table-responsive > .table,
			.table-responsive-sm > .table,
			.table-responsive-md > .table,
			.table-responsive-lg > .table,
			.table-responsive-xl > .table,
			.table-responsive-xxl > .table {
				min-width: 720px;
				margin-bottom: 0;
			}
			.admin-table-tools {
				display: grid;
				grid-template-columns: minmax(220px, 1fr) auto;
				gap: .75rem;
				align-items: end;
				margin-bottom: 1rem;
			}
			.admin-table-filters {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
				gap: .5rem;
				margin-bottom: 1rem;
			}
			.admin-table-filters .form-label {
				margin-bottom: .2rem;
				font-size: .72rem;
				font-weight: 700;
				color: #6c757d;
				text-transform: uppercase;
			}
			.admin-table-empty {
				display: none;
				margin: .75rem 0 0;
			}
			@media (max-width: 767.98px) {
				.admin-table-tools {
					grid-template-columns: 1fr;
				}
				.admin-table-tools .btn {
					width: 100%;
				}
			}
		</style>

		{% block stylesheets %}{% endblock %}
	</head>

	<body>
		<div class="wrapper">
			{% include 'admin/_sidebar.html.twig' %}
			<div class="main">
				{% include 'admin/_navbar.html.twig' %}
				<main class="content container-fluid py-4"> {% block body %}{% endblock %}
					</main>
					<footer class="footer bg-light mt-4 py-3 border-top">
						<div class="container-fluid">
							<div class="row text-muted">
								<div class="col-6 text-start">
									<p class="mb-0">
										<span class="text-muted">©
											{{ "now"|date("Y") }}
											<strong>HaloGari</strong>
										</span>
										– Mobilité partagée à Mayotte.
									</p>
								</div>
								<div class="col-6 text-end">
									<ul class="list-inline mb-0">
										<li class="list-inline-item">
											<a class="text-muted" href="https://halogari.yt/mentions-legales" target="_blank">Mentions légales</a>
										</li>
										<li class="list-inline-item">
											<a class="text-muted" href="mailto:moussa@halogari.yt">Support</a>
										</li>
										<li class="list-inline-item">
											<a class="text-muted" href="https://halogari.yt/confidentialite" target="_blank">Confidentialité</a>
										</li>
										<li class="list-inline-item">
											<a class="text-muted" href="https://halogari.yt/cgu" target="_blank">CGU</a>
										</li>
									</ul>
								</div>
							</div>
						</div>
					</footer>

				</div>
			</div>

			{# ✅ Bootstrap JS avec SRI completé #}
			<script src="https://unpkg.com/@adminkit/core@latest/dist/js/app.js"></script>
			<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.21.0/dist/sweetalert2.all.min.js"></script>
			<script>
				document.addEventListener('DOMContentLoaded', () => {
					document.querySelectorAll('.js-admin-table').forEach((table, tableIndex) => {
						const body = table.tBodies[0];
						const headers = Array.from(table.querySelectorAll('thead th'));
						if (!body || headers.length === 0 || table.dataset.enhanced === '1') {
							return;
						}

						table.dataset.enhanced = '1';
						const wrapper = table.closest('.table-responsive') || table.parentElement;
						const tools = document.createElement('div');
						tools.className = 'admin-table-tools';
						tools.innerHTML = `
							<div>
								<label class="form-label small text-muted" for="admin-table-search-${tableIndex}">Recherche</label>
								<input id="admin-table-search-${tableIndex}" type="search" class="form-control" placeholder="Rechercher dans le tableau">
							</div>
							<button type="button" class="btn btn-outline-secondary">Réinitialiser les filtres</button>
						`;

						const filters = document.createElement('div');
						filters.className = 'admin-table-filters';
						const filterInputs = headers.map((header, columnIndex) => {
							const label = header.textContent.trim();
							if (!label || label.toLowerCase() === 'actions') {
								return null;
							}

							const group = document.createElement('div');
							group.innerHTML = `
								<label class="form-label" for="admin-table-${tableIndex}-filter-${columnIndex}">${label}</label>
								<input id="admin-table-${tableIndex}-filter-${columnIndex}" type="search" class="form-control form-control-sm" placeholder="Filtrer">
							`;
							filters.appendChild(group);
							return { columnIndex, input: group.querySelector('input') };
						}).filter(Boolean);

						const empty = document.createElement('div');
						empty.className = 'alert alert-light border text-muted admin-table-empty';
						empty.textContent = 'Aucun résultat pour ces filtres.';

						wrapper.before(tools);
						wrapper.before(filters);
						wrapper.after(empty);

						const globalInput = tools.querySelector('input');
						const resetButton = tools.querySelector('button');
						const rows = Array.from(body.rows).filter(row => row.cells.length === headers.length);
						const normalize = value => (value || '').toString().toLocaleLowerCase('fr-FR').normalize('NFD').replace(/[\u0300-\u036f]/g, '');

						const applyFilters = () => {
							const globalNeedle = normalize(globalInput.value);
							let visibleCount = 0;

							rows.forEach(row => {
								const rowText = normalize(row.textContent);
								const matchesGlobal = !globalNeedle || rowText.includes(globalNeedle);
								const matchesColumns = filterInputs.every(({ columnIndex, input }) => {
									const needle = normalize(input.value);
									return !needle || normalize(row.cells[columnIndex]?.textContent).includes(needle);
								});
								const visible = matchesGlobal && matchesColumns;
								row.hidden = !visible;
								if (visible) {
									visibleCount++;
								}
							});

							empty.style.display = rows.length > 0 && visibleCount === 0 ? 'block' : 'none';
						};

						globalInput.addEventListener('input', applyFilters);
						filterInputs.forEach(({ input }) => input.addEventListener('input', applyFilters));
						resetButton.addEventListener('click', () => {
							globalInput.value = '';
							filterInputs.forEach(({ input }) => {
								input.value = '';
							});
							applyFilters();
						});
					});
				});
			</script>

			{% for type, messages in app.flashes %}
				{% for message in messages %}
					<script>
						const type = "{{ type }}";
const icons = [
'success',
'error',
'warning',
'info',
'question'
];
Swal.fire({
icon: icons.includes(type) ? type : 'info',
title: {
success: "Réussite",
error: "Échec",
warning: "Attention",
info: "Information",
question: "Question"
}[type] || "Message",
text: "{{ message|e('js') }}",
timer: ['error', 'warning'].includes(type) ? 10000 : 3000,
showConfirmButton: false
});
					</script>
				{% endfor %}
			{% endfor %}

			{% block scripts %}{% endblock %}


		</body>
	</html>
