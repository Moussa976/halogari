{% macro formatModifiable(user, size, withEditButton) %}
    {% set isVerified = user and user.isProfilVerifieComplet() %}
    <div class="hg-avatar-wrap profile-avatar-container{% if isVerified %} is-verified{% endif %}"
         {% if isVerified %}
             tabindex="0"
             data-bs-toggle="tooltip"
             data-bs-title="Profil vérifié : pièce d'identité validée"
             title="Profil vérifié : pièce d'identité validée"
         {% endif %}
         style="width: {{ size }}px; height: {{ size }}px;">
        <img src="{{ user.photo ? asset('uploads/photos/' ~ user.photo) : asset('images/profil.png') }}"
             alt="Photo de {{ user.prenom == 'Utilisateur supprimé' ? 'Utilisateur supprimé' : user.prenom }}"
             class="profile-avatar"
             id="previewPhoto">

        {% if isVerified %}
            <span class="hg-verified-badge" aria-label="Profil vérifié">
                <i class="bi bi-patch-check-fill"></i>
            </span>
        {% endif %}

        {% if withEditButton %}
            <button class="btn btn-sm btn-light border rounded-circle edit-avatar-button"
                    data-bs-toggle="modal"
                    data-bs-target="#modalPhoto"
                    title="Modifier la photo">
                <i class="bi bi-pencil-fill"></i>
            </button>
        {% endif %}
    </div>
{% endmacro %}
{% macro formatSimple(user, size, forElement, afficheBadge) %}
    {% set isVerified = user and user.isProfilVerifieComplet() %}
    {% set showBadge = isVerified and afficheBadge is not same as(false) %}
    <div
        {% if forElement %} onclick="document.getElementById('{{ forElement }}').click()" {% endif %}
        class="hg-avatar-wrap profile-avatar-inline{% if showBadge %} is-verified{% endif %}"
        {% if showBadge %}
            tabindex="0"
            data-bs-toggle="tooltip"
            data-bs-title="Profil vérifié : pièce d'identité validée"
            title="Profil vérifié : pièce d'identité validée"
        {% endif %}
        style="width: {{ size }}px; height: {{ size }}px;"
    >
        <img src="{{ user.photo ? asset('uploads/photos/' ~ user.photo) : asset('images/profil.png') }}"
            alt="Photo de {{ user.prenom == 'Utilisateur supprimé' ? 'Utilisateur supprimé' : user.prenom }}"
            class="profile-avatar">

        {% if showBadge %}
            <span class="hg-verified-badge" aria-label="Profil vérifié">
                <i class="bi bi-patch-check-fill"></i>
            </span>
        {% endif %}
    </div>
{% endmacro %}
