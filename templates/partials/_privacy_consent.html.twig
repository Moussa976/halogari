<div class="hg-consent" data-hg-consent hidden>
  <div class="hg-consent__content">
    <strong>Confidentialité HaloGari</strong>
    <p>
      HaloGari utilise uniquement des cookies nécessaires au bon fonctionnement du site :
      connexion, sécurité, session et préférences. Aucun cookie publicitaire n'est utilisé.
    </p>
  </div>
  <div class="hg-consent__actions">
    <button type="button" class="btn btn-outline-secondary btn-sm" data-hg-consent-refuse>Refuser</button>
    <button type="button" class="btn btn-orange btn-sm" data-hg-consent-accept>Accepter</button>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const banner = document.querySelector('[data-hg-consent]');
    if (!banner || localStorage.getItem('halogariPrivacyConsent')) {
      return;
    }

    const saveConsent = (value) => {
      localStorage.setItem('halogariPrivacyConsent', value);
      document.cookie = `halogari_privacy_consent=${value}; Max-Age=31536000; Path=/; SameSite=Lax`;
      banner.hidden = true;
    };

    banner.hidden = false;
    banner.querySelector('[data-hg-consent-accept]')?.addEventListener('click', () => saveConsent('accepted'));
    banner.querySelector('[data-hg-consent-refuse]')?.addEventListener('click', () => saveConsent('necessary_only'));
  });
</script>
