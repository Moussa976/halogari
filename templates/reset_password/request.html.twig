{% extends 'base.html.twig' %}

{% block title %}HaloGari | Mot de passe oublié{% endblock %}

{% block body %}
<section class="app-page-header app-page-header--compact">
	<div class="container">
		<p class="app-kicker">Compte HaloGari</p>
		<h1>Mot de passe oublié ?</h1>
		<p>Recevez un lien sécurisé pour créer un nouveau mot de passe.</p>
	</div>
</section>

<section class="container auth-layout">
	<div class="auth-card">
		{% for flash_error in app.flashes('reset_password_error') %}
			<div class="alert alert-danger" role="alert">{{ flash_error }}</div>
		{% endfor %}

		{{ form_start(requestForm, { attr: { class: 'app-panel app-panel--form auth-form' } }) }}
			<div class="auth-form__heading">
				<span><i class="bi bi-envelope-check"></i></span>
				<div>
					<h2>Réinitialisation</h2>
					<p>Indiquez l’adresse liée à votre compte.</p>
				</div>
			</div>

			<div class="form-floating">
				{{ form_widget(requestForm.email, {
					attr: {
						class: 'form-control',
						placeholder: 'exemple@halogari.yt',
						value: last_username|default(''),
						autocomplete: 'email',
						inputmode: 'email'
					}
				}) }}
				{{ form_label(requestForm.email, 'Adresse e-mail', {'label_attr': {'class': 'form-label'}}) }}
				{{ form_errors(requestForm.email) }}
			</div>

			<p class="small text-muted mb-0">
				Entrez votre adresse e-mail et nous vous enverrons un lien pour réinitialiser votre mot de passe.
			</p>

			<div class="hg-form-actions">
				<button type="submit" class="btn btn-orange">
					<i class="bi bi-send-fill"></i>
					Envoyer le lien
				</button>
			</div>
		{{ form_end(requestForm) }}
	</div>

	<aside class="app-panel auth-aside">
		<span class="app-panel__icon"><i class="bi bi-envelope-check"></i></span>
		<h2>Un lien par e-mail</h2>
		<p>Si votre adresse existe, HaloGari vous envoie un lien de réinitialisation valable temporairement.</p>
	</aside>
</section>
{% endblock %}
