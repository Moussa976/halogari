{% extends 'base.html.twig' %}

{% block title %}HaloGari | Réinitialiser le mot de passe{% endblock %}

{% block body %}
<section class="app-page-header app-page-header--compact">
	<div class="container">
		<p class="app-kicker">Sécurité</p>
		<h1>Réinitialiser le mot de passe</h1>
		<p>Choisissez un nouveau mot de passe pour sécuriser votre compte.</p>
	</div>
</section>

<section class="container auth-layout">
	<div class="auth-card">
		{{ form_start(resetForm, {
			attr: {
				class: 'app-panel app-panel--form auth-form needs-validation',
				novalidate: 'novalidate'
			}
		}) }}

			{% for flash_error in app.flashes('reset_password_error') %}
				<div class="alert alert-danger" role="alert">{{ flash_error }}</div>
			{% endfor %}

			<div class="auth-form__heading">
				<span><i class="bi bi-shield-lock-fill"></i></span>
				<div>
					<h2>Nouveau mot de passe</h2>
					<p>Utilisez un mot de passe unique et difficile à deviner.</p>
				</div>
			</div>

			<div>
				<div class="input-group auth-input-group password-input-group">
					<div class="form-floating">
						{{ form_widget(resetForm.plainPassword.first, {
							attr: {
								class: 'form-control ' ~ (resetForm.plainPassword.first.vars.valid == false ? 'is-invalid' : ''),
								placeholder: 'Votre mot de passe',
								autocomplete: 'new-password',
								'aria-describedby': 'passwordFeedback'
							}
						}) }}
						{{ form_label(resetForm.plainPassword.first, 'Nouveau mot de passe', {'label_attr': {'class': 'form-label'}}) }}
					</div>
					<button class="btn btn-outline-secondary toggle-password" type="button" data-target="change_password_form_plainPassword_first" aria-label="Afficher ou masquer le mot de passe">
						<i class="bi bi-eye-slash-fill"></i>
					</button>
				</div>
				<div id="passwordFeedback" class="invalid-feedback">{{ form_errors(resetForm.plainPassword.first) }}</div>
				<div class="password-rules" data-password-rules data-for="change_password_form_plainPassword_first">
					<span data-rule="length">8 caractères minimum</span>
					<span data-rule="lower">Une minuscule</span>
					<span data-rule="upper">Une majuscule</span>
					<span data-rule="number">Un chiffre</span>
					<span data-rule="special">Un caractère spécial</span>
				</div>
			</div>

			<div>
				<div class="input-group auth-input-group password-input-group">
					<div class="form-floating">
						{{ form_widget(resetForm.plainPassword.second, {
							attr: {
								class: 'form-control ' ~ (resetForm.plainPassword.second.vars.valid == false ? 'is-invalid' : ''),
								placeholder: 'Confirmez votre mot de passe',
								autocomplete: 'new-password',
								'aria-describedby': 'confirmPasswordFeedback'
							}
						}) }}
						{{ form_label(resetForm.plainPassword.second, 'Confirmer le mot de passe', {'label_attr': {'class': 'form-label'}}) }}
					</div>
					<button class="btn btn-outline-secondary toggle-password" type="button" data-target="change_password_form_plainPassword_second" aria-label="Afficher ou masquer le mot de passe">
						<i class="bi bi-eye-slash-fill"></i>
					</button>
				</div>
				<div id="confirmPasswordFeedback" class="invalid-feedback">{{ form_errors(resetForm.plainPassword.second) }}</div>
			</div>

			<div class="hg-form-actions">
				<button type="submit" class="btn btn-orange">
					<i class="bi bi-lock"></i>
					Réinitialiser le mot de passe
				</button>
			</div>

		{{ form_end(resetForm) }}
	</div>

	<aside class="app-panel auth-aside">
		<span class="app-panel__icon"><i class="bi bi-shield-check"></i></span>
		<h2>Conseil sécurité</h2>
		<p>Utilisez un mot de passe unique, avec des lettres, des chiffres et un caractère spécial.</p>
	</aside>
</section>
{% endblock %}

{% block javascripts %}
<script>
(() => {
  'use strict';
  document.querySelectorAll('.needs-validation').forEach((form) => {
    form.addEventListener('submit', (event) => {
      if (!form.checkValidity()) {
        event.preventDefault();
        event.stopPropagation();
      }
      form.classList.add('was-validated');
    }, false);
  });
})();
</script>
{% endblock %}
