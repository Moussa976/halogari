<!DOCTYPE html>
<html lang="fr">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  {% set currentRoute = app.request.attributes.get('_route')|default('') %}
  {% set isPreprodHost = app.request.host starts with 'preprod.' %}
  {% set seoDefaultTitle = platform_setting('seo.default_title', 'HaloGari | Covoiturage à Mayotte') %}
  {% set seoDefaultDescription = platform_setting('seo.default_description', 'HaloGari facilite le covoiturage local à Mayotte : cherchez une place, publiez un trajet et voyagez avec une communauté de confiance.') %}
  {% set seoDefaultImage = platform_setting('seo.og_image', absolute_url(asset('images/logo/logo-787x298.png'))) %}
  {% set seoCanonicalBaseUrl = platform_setting('seo.canonical_base_url', '') %}
  {% set seoProductionRobots = platform_setting('seo.robots_default', 'index, follow') %}
  {% set seoFacebookUrl = platform_setting('seo.facebook_url', 'https://www.facebook.com/profile.php?id=1202754536249735') %}
  {% set seoGoogleVerification = platform_setting('seo.google_site_verification', '') %}
  {% set seoBingVerification = platform_setting('seo.bing_site_verification', '') %}
  {% set isPrivateSeoRoute =
    currentRoute starts with 'admin_'
    or currentRoute starts with 'api_'
    or currentRoute starts with 'app_user_'
    or currentRoute starts with 'app_mes'
    or currentRoute starts with 'app_conversation'
    or currentRoute starts with 'api_conversation_'
    or currentRoute starts with 'app_notifications'
    or currentRoute starts with 'app_paiement'
    or currentRoute starts with 'app_parametres'
    or currentRoute starts with 'app_mon_'
    or currentRoute starts with 'app_document'
    or currentRoute starts with 'app_verify_email'
    or currentRoute starts with 'app_reservation'
    or currentRoute starts with 'app_noter'
    or currentRoute in ['app_login', 'app_register', 'registration_confirmation', 'app_publier', 'app_chercherResultats', 'app_trajet_show', 'trajet_annuler', 'affiche_test', 'app_test_carte', 'app_message', 'notification_voir', 'paiement_form', 'paiement_confirmation', 'app_mesreservation', 'reservation_accepter', 'reservation_refuser', 'reservation_annuler_legacy', 'app_user', 'app_profile', 'app_compte', 'app_documents', 'reservation_annuler', 'app_user_resend_confirmation', 'push_test_user']
  %}
  <title>
    {% block title %}{{ seoDefaultTitle }}
    {% endblock %}
  </title>
  <meta name="description" content="{% block meta_description %}{{ seoDefaultDescription }}{% endblock %}">
  <meta name="robots" content="{% block meta_robots %}{{ isPrivateSeoRoute ? 'noindex, nofollow' : (isPreprodHost ? 'noindex, follow' : seoProductionRobots) }}{% endblock %}">
  <link rel="canonical" href="{% block canonical_url %}{{ (not isPreprodHost and seoCanonicalBaseUrl ? seoCanonicalBaseUrl : app.request.schemeAndHttpHost) ~ app.request.pathInfo }}{% endblock %}">
  {% if seoGoogleVerification %}
    <meta name="google-site-verification" content="{{ seoGoogleVerification }}">
  {% endif %}
  {% if seoBingVerification %}
    <meta name="msvalidate.01" content="{{ seoBingVerification }}">
  {% endif %}
  <meta property="og:site_name" content="HaloGari">
  <meta property="og:type" content="{% block og_type %}website{% endblock %}">
  <meta property="og:title" content="{% block og_title %}{{ block('title')|striptags|trim }}{% endblock %}">
  <meta property="og:description" content="{% block og_description %}{{ block('meta_description')|striptags|trim }}{% endblock %}">
  <meta property="og:url" content="{{ app.request.schemeAndHttpHost ~ app.request.pathInfo }}">
  <meta property="og:image" content="{% block og_image %}{{ seoDefaultImage }}{% endblock %}">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ block('og_title')|striptags|trim }}">
  <meta name="twitter:description" content="{{ block('og_description')|striptags|trim }}">
  <meta name="twitter:image" content="{{ block('og_image')|striptags|trim }}">
  {% if not isPrivateSeoRoute %}
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "HaloGari",
        "url": "{{ (seoCanonicalBaseUrl ?: app.request.schemeAndHttpHost)|e('js') }}",
        "logo": "{{ absolute_url(asset('images/logo/logo-787x298.png'))|e('js') }}",
        "description": "{{ seoDefaultDescription|e('js') }}",
        "areaServed": {
          "@type": "AdministrativeArea",
          "name": "Mayotte"
        }{% if seoFacebookUrl %},
        "sameAs": [
          "{{ seoFacebookUrl|e('js') }}"
        ]{% endif %}
      }
    </script>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "HaloGari",
        "url": "{{ (seoCanonicalBaseUrl ?: app.request.schemeAndHttpHost)|e('js') }}",
        "potentialAction": {
          "@type": "SearchAction",
          "target": "{{ (seoCanonicalBaseUrl ?: app.request.schemeAndHttpHost)|e('js') }}{{ path('app_chercher') }}?depart={depart}&arrivee={arrivee}",
          "query-input": [
            "required name=depart",
            "required name=arrivee"
          ]
        }
      }
    </script>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "SiteNavigationElement",
            "name": "Chercher un trajet",
            "url": "{{ (seoCanonicalBaseUrl ?: app.request.schemeAndHttpHost)|e('js') }}{{ path('app_chercher') }}"
          },
          {
            "@type": "SiteNavigationElement",
            "name": "Covoiturage à Mayotte",
            "url": "{{ (seoCanonicalBaseUrl ?: app.request.schemeAndHttpHost)|e('js') }}{{ path('app_covoiturage_mayotte') }}"
          },
          {
            "@type": "SiteNavigationElement",
            "name": "Covoiturage Mamoudzou",
            "url": "{{ (seoCanonicalBaseUrl ?: app.request.schemeAndHttpHost)|e('js') }}{{ path('app_covoiturage_mamoudzou') }}"
          },
          {
            "@type": "SiteNavigationElement",
            "name": "Covoiturage Koungou",
            "url": "{{ (seoCanonicalBaseUrl ?: app.request.schemeAndHttpHost)|e('js') }}{{ path('app_covoiturage_koungou') }}"
          },
          {
            "@type": "SiteNavigationElement",
            "name": "Covoiturage M'Tsamboro",
            "url": "{{ (seoCanonicalBaseUrl ?: app.request.schemeAndHttpHost)|e('js') }}{{ path('app_covoiturage_mtsamboro') }}"
          },
          {
            "@type": "SiteNavigationElement",
            "name": "Covoiturage Dembéni",
            "url": "{{ (seoCanonicalBaseUrl ?: app.request.schemeAndHttpHost)|e('js') }}{{ path('app_covoiturage_dembeni') }}"
          },
          {
            "@type": "SiteNavigationElement",
            "name": "Sécurité et confiance",
            "url": "{{ (seoCanonicalBaseUrl ?: app.request.schemeAndHttpHost)|e('js') }}{{ path('app_securite') }}"
          },
          {
            "@type": "SiteNavigationElement",
            "name": "FAQ HaloGari",
            "url": "{{ (seoCanonicalBaseUrl ?: app.request.schemeAndHttpHost)|e('js') }}{{ path('app_faq') }}"
          },
          {
            "@type": "SiteNavigationElement",
            "name": "Contact",
            "url": "{{ (seoCanonicalBaseUrl ?: app.request.schemeAndHttpHost)|e('js') }}{{ path('app_contact') }}"
          }
        ]
      }
    </script>
  {% endif %}

  {% include 'partials/bootstrap-link.html.twig' %}
  <link rel="stylesheet" href="{{ asset('css/style.css') }}">
  <link rel="stylesheet" href="{{ asset('assets/styles/app.css') }}?v=20260722-local-seo-links">
  {% block stylesheets %}{% endblock %}
</head>

<body class="d-flex flex-column min-vh-100 app-shell route-{{ app.request.attributes.get('_route')|default('page') }}">
  <div id="splash-screen" style=" position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background-color: white; display: flex; flex-direction: column; justify-content: center; align-items: center; z-index: var(--hg-z-splash); ">
    <img id="splash-logo" src="{{ asset('images/logo/logo-787x298.png') }}" alt="HaloGari" style="max-width: 180px; opacity: 0; transform: scale(0.8); transition: all 0.8s ease-in-out;">
    <p id="splash-text" style=" margin-top: 20px; font-size: 1.1rem; color: #f27c1e; opacity: 0; transform: translateY(10px); transition: all 0.8s ease-in-out; ">
      Covoiturage à Mayotte
    </p>
  </div>



  {% include 'components/layout/_navbar.html.twig' %}

  {% block body %}{% endblock %}

  {% include 'partials/footer.html.twig' %}
  {% include 'components/layout/_mobile_tabbar.html.twig' %}
  {% include 'components/layout/_help_bot.html.twig' %}
  {% include 'partials/_privacy_consent.html.twig' %}
  {% include 'partials/bootstrap-script.html.twig' %}

  {% for type, messages in app.flashes %}
    {% for message in messages %}
      <script>
      (() => {
        const type = "{{ type }}";
        const message = "{{ message|e('js') }}";
        const icons = ['success', 'error', 'warning', 'info', 'question'];
        const timer = message.startsWith('Alerte créée.') ? 5000 : (['error', 'warning'].includes(type) ? 10000 : 3000);

        Swal.fire({
          icon: icons.includes(type) ? type : 'info',
          title: {
            success: "Réussite",
            error: "Échec",
            warning: "Attention",
            info: "Information",
            question: "Question"
          }[type] || "Message",
          text: message,
          timer,
          showConfirmButton: false
        });
      })();
      </script>
    {% endfor %}
  {% endfor %}
  <script src="{{ asset('assets/scripts/app-ui.js') }}?v=20260703-chat-submit-loading"></script>
  {% block javascripts %}{% endblock %}
</body>

</html>
