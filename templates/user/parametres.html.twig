{% extends 'base.html.twig' %}

{% block title %}HaloGari | Paramètres du compte{% endblock %}

{% block body %}
<section class="app-page-header app-page-header--compact">
  <div class="container">
    <p class="app-kicker">Espace personnel</p>
    <h1>Paramètres du compte</h1>
    <p>Retrouvez les réglages essentiels et les accès vers vos pages personnelles.</p>
  </div>
</section>

<section class="container app-page-grid settings-page">
  <div class="d-grid gap-4">
    <article class="app-panel">
      <div class="app-panel__header">
        <span class="app-panel__icon"><i class="bi bi-grid-1x2-fill"></i></span>
        <div>
          <h2>Mes informations</h2>
          <p>Les détails personnels sont maintenant rangés dans des pages dédiées.</p>
        </div>
      </div>

      <div class="row g-3">
        <div class="col-md-6">
          <a class="d-block text-decoration-none border rounded-3 p-3 h-100 bg-white" href="{{ path('app_mon_profil') }}">
            <div class="app-panel__header mb-0">
              <span class="app-panel__icon"><i class="bi bi-person-circle"></i></span>
              <div>
                <h3 class="h5 mb-1 text-dark">Mon profil</h3>
                <p class="mb-0 text-muted">Identité, téléphone et photo.</p>
              </div>
            </div>
          </a>
        </div>
        <div class="col-md-6">
          <a class="d-block text-decoration-none border rounded-3 p-3 h-100 bg-white" href="{{ path('app_mon_adresse') }}">
            <div class="app-panel__header mb-0">
              <span class="app-panel__icon"><i class="bi bi-geo-alt-fill"></i></span>
              <div>
                <h3 class="h5 mb-1 text-dark">Mon adresse</h3>
                <p class="mb-0 text-muted">Adresse postale du dossier conducteur.</p>
              </div>
            </div>
          </a>
        </div>
        <div class="col-md-6">
          <a class="d-block text-decoration-none border rounded-3 p-3 h-100 bg-white" href="{{ path('app_mon_vehicule') }}">
            <div class="app-panel__header mb-0">
              <span class="app-panel__icon"><i class="bi bi-car-front-fill"></i></span>
              <div>
                <h3 class="h5 mb-1 text-dark">Mon véhicule</h3>
                <p class="mb-0 text-muted">Marque, modèle, couleur et photo.</p>
              </div>
            </div>
          </a>
        </div>
        <div class="col-md-6">
          <a class="d-block text-decoration-none border rounded-3 p-3 h-100 bg-white" href="{{ path('app_documents') }}">
            <div class="app-panel__header mb-0">
              <span class="app-panel__icon"><i class="bi bi-file-earmark-text-fill"></i></span>
              <div>
                <h3 class="h5 mb-1 text-dark">Mes documents</h3>
                <p class="mb-0 text-muted">Pièce d’identité, RIB et validation.</p>
              </div>
            </div>
          </a>
        </div>
      </div>
    </article>

    {% include 'user/partials/_notification_panel.html.twig' %}
    {% include 'user/partials/_security_form.html.twig' %}
  </div>

  {% include 'user/partials/_delete_account_panel.html.twig' %}
</section>
{% endblock %}

{% block javascripts %}
  {% include 'user/partials/_settings_scripts.html.twig' %}
{% endblock %}
