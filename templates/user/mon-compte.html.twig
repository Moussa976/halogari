{% extends 'base.html.twig' %}

{% block title %}HaloGari | Mon tableau de bord{% endblock %}

{% block body %}
<section class="app-page-header app-page-header--compact">
  <div class="container">
    <p class="app-kicker">Compte</p>
    <h1>Bonjour {{ app.user ? app.user.prenom : 'Moussa' }}</h1>
    <p>Votre espace pour suivre vos trajets, réservations, documents et messages.</p>
  </div>
</section>

<section class="container dashboard-grid">
  <article class="app-panel profile-hero">
    <span class="hg-avatar-wrap profile-hero__avatar-wrap{% if app.user and app.user.isProfilVerifieComplet %} is-verified{% endif %}"
      {% if app.user and app.user.isProfilVerifieComplet %}
          tabindex="0"
          title="Profil vérifié : pièce d'identité validée"
      {% endif %}>
      <img src="{{ asset(app.user and app.user.photo ? '/uploads/photos/' ~ app.user.photo : '/images/profil.png') }}" class="profile-hero__avatar" alt="Photo de profil">
      {% if app.user and app.user.isProfilVerifieComplet %}
        <span class="hg-verified-badge" aria-label="Profil vérifié">
          <i class="bi bi-patch-check-fill"></i>
        </span>
      {% endif %}
    </span>
    <div>
      <p class="app-kicker">Profil</p>
      <h2>{{ app.user ? app.user.prenom ~ ' ' ~ app.user.nom : 'Utilisateur HaloGari' }}</h2>
      <p>{{ app.user and app.user.isProfilVerifieComplet ? 'Profil vérifié et prêt à voyager.' : 'Complétez vos informations pour gagner la confiance des passagers.' }}</p>
      <a href="{{ app.user ? path('app_profile', { id: app.user.id }) : path('app_home') }}" class="btn btn-orange">
        <i class="bi bi-person-check"></i>
        Voir mon profil
      </a>
    </div>
  </article>

  <div class="dashboard-actions">
    <a class="app-panel dashboard-action" href="{{ path('app_chercher') }}">
      <i class="bi bi-search"></i>
      <strong>Chercher</strong>
      <span>Trouver une place rapidement.</span>
    </a>
    <a class="app-panel dashboard-action" href="{{ path('app_publier') }}">
      <i class="bi bi-plus-circle"></i>
      <strong>Publier</strong>
      <span>Proposer un trajet en quelques étapes.</span>
    </a>
    <a class="app-panel dashboard-action" href="{{ path('app_mes_reservations') }}">
      <i class="bi bi-calendar-check"></i>
      <strong>Réservations</strong>
      <span>Suivre vos demandes.</span>
    </a>
    <a class="app-panel dashboard-action" href="{{ path('app_documents') }}">
      <i class="bi bi-shield-check"></i>
      <strong>Documents</strong>
      <span>Vérifier votre compte.</span>
    </a>
  </div>

  <article class="app-panel dashboard-trust">
    <span class="app-panel__icon"><i class="bi bi-stars"></i></span>
    <h2>Prochaine étape conseillée</h2>
    <p>
      {% if app.user and not app.user.isProfilVerifieComplet %}
        Complétez votre profil et vos documents pour inspirer confiance avant de publier ou réserver.
      {% else %}
        Votre compte est prêt. Vous pouvez chercher une place ou publier un trajet selon votre besoin du jour.
      {% endif %}
    </p>
    <div class="tip-list">
      <span><i class="bi bi-check-circle-fill"></i> Profil clair</span>
      <span><i class="bi bi-check-circle-fill"></i> Notifications utiles</span>
      <span><i class="bi bi-check-circle-fill"></i> Paiement sécurisé</span>
    </div>
  </article>
</section>
{% endblock %}
