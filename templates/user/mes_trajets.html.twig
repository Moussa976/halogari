{% extends 'base.html.twig' %}

{% block title %}HaloGari | Mes trajets{% endblock %}

{% set statutLabels = {
  'all': 'Tous',
  'annule': 'Annulé',
  'passe': 'Passé',
  'avenir': 'À venir',
  'en_cours': 'En cours'
} %}

{% block body %}
<section class="app-page-header app-page-header--compact">
  <div class="container">
    <p class="app-kicker">Conducteur</p>
    <h1>Mes trajets publiés</h1>
    <p>Gardez la main sur vos trajets, les demandes des passagers et l'état de vos publications.</p>
  </div>
</section>

<section class="container hg-account-section">
  <div class="app-panel">
    <div class="app-panel__header">
      <div>
        <h2>Tableau de bord conducteur</h2>
        <p>Un espace simple pour suivre ce qui est à venir, passé, en cours ou annulé.</p>
      </div>
      <a href="{{ path('app_publier') }}" class="btn btn-orange btn-sm">
        <i class="bi bi-plus-circle"></i>
        Publier
      </a>
    </div>

    <div class="hg-filter-select mb-4">
      <label for="filtreTrajetsSelect">Filtrer les trajets</label>
      <select id="filtreTrajetsSelect" class="form-select" onchange="filterTrajets(this.value)">
        {% for key, label in statutLabels %}
          <option value="{{ key }}">{{ label }}</option>
        {% endfor %}
      </select>
    </div>

    <ul class="nav nav-pills app-tabs hg-filter-tabs mb-4" id="filtreTabs" role="tablist" aria-label="Filtrer les trajets">
      {% for key, label in statutLabels %}
        <li class="nav-item" role="presentation">
          <button class="nav-link {{ loop.first ? 'active' : '' }}" id="tab-{{ key }}" type="button" onclick="filterTrajets('{{ key }}')">{{ label }}</button>
        </li>
      {% endfor %}
    </ul>

    <div class="d-grid gap-3" id="liste-trajets">
      {% set nowTs = "now"|date("U") %}
      {% for trajet in trajets %}
        {% set datetimeDepStr = trajet.dateTrajet|date("Y-m-d") ~ " " ~ trajet.heureTrajet|date("H:i:s") %}
        {% set datetimeDep = datetimeDepStr|date("U") %}
        {% set datetimeFin = datetimeDepStr|date_modify("+3 hours")|date("U") %}
        {% set statut = trajet.isAnnule ? 'annule' : (datetimeDep <= nowTs and nowTs < datetimeFin ? 'en_cours' : (datetimeDep > nowTs ? 'avenir' : 'passe')) %}
        {% set activeReservations = trajet.reservations|filter(r => r.statut in ['en_attente', 'acceptee', 'payee'])|length %}

        <a href="{{ path('app_user_trajet', { id: trajet.id }) }}" class="hg-list-card text-decoration-none text-reset" data-status="{{ statut }}">
          <div class="d-flex flex-column flex-md-row gap-3 justify-content-between align-items-md-center">
            <div>
              <div class="fw-bold fs-5">{{ trajet.depart }} → {{ trajet.arrivee }}</div>
              <div class="text-muted">{{ trajet.dateTrajet|date_fr('l d F Y') }} à {{ trajet.heureTrajet|date('H:i') }}</div>
              <div class="small text-muted">
                {{ trajet.placesDisponibles }} place{{ trajet.placesDisponibles > 1 ? 's' : '' }} disponible{{ trajet.placesDisponibles > 1 ? 's' : '' }}
                · {{ activeReservations }} demande{{ activeReservations > 1 ? 's' : '' }} active{{ activeReservations > 1 ? 's' : '' }}
              </div>
            </div>
            <div class="d-flex flex-wrap gap-2 justify-content-md-end">
              <span class="badge {% if statut == 'annule' %}bg-danger{% elseif statut == 'passe' %}bg-secondary{% elseif statut == 'en_cours' %}bg-info text-dark{% else %}bg-success{% endif %}">
                {{ statutLabels[statut]|default(statut) }}
              </span>
              <span class="badge bg-light text-dark border">{{ trajet.prix|number_format(2, ',', ' ') }} € / place</span>
            </div>
          </div>
        </a>
      {% else %}
        <div class="alert alert-info mb-0">
          Vous n'avez pas encore publié de trajet. Proposez un trajet utile et clair pour aider les habitants à se déplacer.
          <div class="mt-3">
            <a href="{{ path('app_publier') }}" class="btn btn-orange btn-sm">
              <i class="bi bi-plus-circle"></i>
              Publier mon premier trajet
            </a>
          </div>
        </div>
      {% endfor %}

      <div class="alert alert-info mb-0 d-none" id="empty-trajets-filter">
        Aucun trajet ne correspond à ce filtre.
      </div>
    </div>
  </div>
</section>
{% endblock %}

{% block javascripts %}
<script>
function filterTrajets(status) {
  let visibleCount = 0;
  document.querySelectorAll('#liste-trajets [data-status]').forEach(item => {
    const visible = status === 'all' || item.dataset.status === status;
    item.style.display = visible ? '' : 'none';
    if (visible) {
      visibleCount++;
    }
  });

  document.querySelectorAll('#filtreTabs .nav-link').forEach(tab => tab.classList.remove('active'));
  document.getElementById('tab-' + status)?.classList.add('active');

  const select = document.getElementById('filtreTrajetsSelect');
  if (select) {
    select.value = status;
  }

  document.getElementById('empty-trajets-filter')?.classList.toggle('d-none', visibleCount > 0);
}
</script>
{% endblock %}
