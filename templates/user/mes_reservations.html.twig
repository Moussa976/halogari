{% extends 'base.html.twig' %}

{% block title %}HaloGari | Mes réservations{% endblock %}

{% set trajetLabels = {
  'annule': 'Annulé',
  'passe': 'Passé',
  'avenir': 'À venir',
  'en_cours': 'En cours',
  'all': 'Toutes'
} %}

{% set reservationLabels = {
  'en_attente': 'En attente',
  'acceptee': 'Acceptée',
  'refusee': 'Refusée',
  'annulee': 'Annulée',
  'payee': 'Payée'
} %}

{% block body %}
<section class="app-page-header app-page-header--compact">
  <div class="container">
    <p class="app-kicker">Passager</p>
    <h1>Mes réservations</h1>
    <p>Retrouvez vos demandes, vos trajets acceptés, vos paiements et les réservations passées.</p>
  </div>
</section>

<section class="container">
  <div class="app-panel">
    <div class="app-panel__header">
      <div>
        <h2>Suivi des trajets</h2>
        <p>Un statut clair pour savoir quoi faire : attendre, payer, contacter le conducteur ou laisser un avis.</p>
      </div>
      <a href="{{ path('app_chercher') }}" class="btn btn-orange btn-sm">
        <i class="bi bi-search"></i>
        Chercher
      </a>
    </div>

    <ul class="nav nav-pills app-tabs mb-4" id="filtreTabs" role="tablist">
      {% for key, label in trajetLabels %}
        <li class="nav-item" role="presentation">
          <button class="nav-link {{ loop.first ? 'active' : '' }}" id="tab-{{ key }}" type="button" onclick="filterReservations('{{ key }}')">{{ label }}</button>
        </li>
      {% endfor %}
    </ul>

    <div class="d-grid gap-3" id="liste-reservations">
      {% set nowTs = "now"|date("U") %}
      {% for res in reservations %}
        {% set trajet = res.trajet %}
        {% set datetimeDepStr = trajet.dateTrajet|date("Y-m-d") ~ " " ~ trajet.heureTrajet|date("H:i:s") %}
        {% set datetimeDep = datetimeDepStr|date("U") %}
        {% set datetimeFin = datetimeDepStr|date_modify("+3 hours")|date("U") %}
        {% set trajetStatus = trajet.isAnnule or res.statut in ['annulee', 'refusee'] ? 'annule' : (datetimeDep <= nowTs and nowTs < datetimeFin ? 'en_cours' : (datetimeDep > nowTs ? 'avenir' : 'passe')) %}

        <a href="{{ path('app_user_reservation', { id: res.id }) }}" class="hg-list-card text-decoration-none text-reset" data-status="{{ trajetStatus }}">
          <div class="d-flex flex-column flex-md-row gap-3 justify-content-between align-items-md-center">
            <div>
              <div class="fw-bold fs-5">{{ trajet.depart }} → {{ trajet.arrivee }}</div>
              <div class="text-muted">{{ trajet.dateTrajet|date_fr('l d F Y') }} à {{ trajet.heureTrajet|date('H:i') }}</div>
              <div class="small text-muted">{{ res.places }} place{{ res.places > 1 ? 's' : '' }} · {{ res.prixTotal|number_format(2, ',', ' ') }} €</div>
            </div>
            <div class="d-flex flex-wrap gap-2 justify-content-md-end">
              <span class="badge {% if res.statut in ['refusee', 'annulee'] %}bg-danger{% elseif res.statut == 'en_attente' %}bg-warning text-dark{% elseif res.statut in ['acceptee', 'payee'] %}bg-success{% else %}bg-primary{% endif %}">
                {{ reservationLabels[res.statut]|default(res.statut) }}
              </span>
              <span class="badge bg-light text-dark border">Trajet {{ trajetLabels[trajetStatus]|default(trajetStatus)|lower }}</span>
            </div>
          </div>
        </a>
      {% else %}
        <div class="alert alert-info mb-0">
          Vous n'avez pas encore de réservation. Lancez une recherche pour trouver un trajet adapté à votre journée.
          <div class="mt-3">
            <a href="{{ path('app_chercher') }}" class="btn btn-orange btn-sm">
              <i class="bi bi-search"></i>
              Chercher un trajet
            </a>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endblock %}

{% block javascripts %}
<script>
function filterReservations(status) {
  document.querySelectorAll('#liste-reservations [data-status]').forEach(item => {
    item.style.display = (status === 'all' || item.dataset.status === status) ? '' : 'none';
  });

  document.querySelectorAll('#filtreTabs .nav-link').forEach(tab => tab.classList.remove('active'));
  document.getElementById('tab-' + status)?.classList.add('active');
}
</script>
{% endblock %}
