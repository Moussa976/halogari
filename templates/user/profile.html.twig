{% extends 'base.html.twig' %}

{% set displayName = user.prenom == 'Utilisateur supprimé' ? 'Utilisateur supprimé' : user.prenom %}
{% set isOwner = app.user and app.user.id == user.id %}
{% set isProfileVerified = user.isProfilVerifieComplet %}

{% block title %}HaloGari | Profil de {{ displayName }}{% endblock %}

{% block body %}
<section class="app-page-header app-page-header--compact">
  <div class="container">
    <p class="app-kicker">Profil utilisateur</p>
    <h1>{{ displayName }}</h1>
    <p>Un profil clair aide chacun à voyager avec confiance avant, pendant et après le trajet.</p>
  </div>
</section>

<section class="container app-page-grid hg-profile-grid">
  <article class="app-panel hg-profile-main">
    <div class="hg-profile-summary">
      <div class="hg-profile-photo-wrap{% if isProfileVerified %} is-verified{% endif %}"
          {% if isProfileVerified %}
             tabindex="0"
             title="Profil vérifié : pièce d'identité validée"
          {% endif %}>
        <img src="{{ user.photo ? asset('uploads/photos/' ~ user.photo) : asset('images/profil.png') }}" alt="Photo de {{ displayName }}" class="hg-profile-photo">
        {% if isProfileVerified %}
          <span class="hg-verified-badge" aria-label="Profil vérifié">
            <i class="bi bi-patch-check-fill"></i>
          </span>
        {% endif %}
        {% if isOwner %}
          <a href="{{ path('app_compte', { section: 'informations' }) }}" class="btn btn-light border rounded-circle hg-profile-photo-edit" title="Modifier la photo">
            <i class="bi bi-pencil-fill"></i>
          </a>
        {% endif %}
      </div>
      <div class="text-center text-md-start flex-grow-1">
        <h2 class="mb-1">{{ displayName }}</h2>
        <p class="text-muted mb-2">
          {% if user.dateNaissance %}
            {{ date().diff(user.dateNaissance).y }} ans
          {% else %}
            Âge non renseigné
          {% endif %}
          · Membre depuis {{ dateMembre }}
        </p>
        <div class="d-flex flex-wrap gap-2 justify-content-center justify-content-md-start">
          <span class="badge bg-light text-dark border">{{ user.trajets|length }} trajet{{ user.trajets|length > 1 ? 's' : '' }} publié{{ user.trajets|length > 1 ? 's' : '' }}</span>
          <button class="btn btn-outline-warning btn-sm" type="button" data-bs-toggle="modal" data-bs-target="#modalNotes">
            <i class="bi bi-star-fill"></i>
            {{ noteMoyenne ? noteMoyenne ~ '/5' : 'Aucun avis' }}
          </button>
          {% if isOwner %}
            <a href="{{ path('app_compte', { section: 'informations' }) }}" class="btn btn-outline-primary btn-sm">
              <i class="bi bi-gear-fill"></i>
              Mon compte
            </a>
          {% endif %}
        </div>
      </div>
    </div>
  </article>

  <article class="app-panel">
    <div class="app-panel__header">
      <div>
        <h2>Confiance et vérifications</h2>
        <p>{{ verifOk }}/{{ verifTotal }} vérification{{ verifTotal > 1 ? 's' : '' }} complétée{{ verifOk > 1 ? 's' : '' }}.</p>
      </div>
      <span class="badge {{ verifOk >= 2 ? 'bg-success' : 'bg-warning text-dark' }}">{{ verifOk }}/{{ verifTotal }}</span>
    </div>

    <div class="d-grid gap-2">
      <div class="d-flex justify-content-between align-items-center border rounded p-3">
        <span><i class="bi {{ verifications.identite ? 'bi-patch-check-fill text-success' : 'bi-patch-minus-fill text-danger' }} me-2"></i>Pièce d'identité</span>
        <strong>{{ verifications.identite ? 'Vérifiée' : 'À vérifier' }}</strong>
      </div>
      <div class="d-flex justify-content-between align-items-center border rounded p-3">
        <span><i class="bi {{ verifications.email ? 'bi-patch-check-fill text-success' : 'bi-patch-minus-fill text-danger' }} me-2"></i>Adresse e-mail</span>
        <strong>{{ verifications.email ? 'Vérifiée' : 'À vérifier' }}</strong>
      </div>
    </div>

    {% if isOwner and verifOk < verifTotal %}
      <div class="alert alert-info mt-3 mb-0">
        Complétez votre profil pour rassurer les autres utilisateurs et accéder aux fonctionnalités avancées.
        <div class="mt-2">
          <a href="{{ path('app_documents') }}" class="btn btn-outline-primary btn-sm">
            <i class="bi bi-file-earmark-arrow-up-fill"></i>
            Vérifier mes documents
          </a>
        </div>
      </div>
    {% endif %}
  </article>

  <article class="app-panel">
    <div class="app-panel__header">
      <div>
        <h2>Présentation</h2>
        <p>Quelques mots pour mieux connaître {{ displayName }} avant de voyager ensemble.</p>
      </div>
      {% if isOwner %}
        <button class="btn btn-outline-secondary btn-sm" type="button" data-bs-toggle="modal" data-bs-target="#modalDescription">
          <i class="bi bi-pencil-fill"></i>
          Modifier
        </button>
      {% endif %}
    </div>

    {% if user.description %}
      <p class="mb-0">{{ user.description|nl2br }}</p>
    {% else %}
      <div class="alert alert-light border mb-0">Aucune description renseignée.</div>
    {% endif %}
  </article>

  <aside class="app-panel app-tips-panel">
    <span class="app-panel__icon"><i class="bi bi-sliders"></i></span>
    <div class="d-flex justify-content-between align-items-center gap-2">
      <h2 class="mb-0">Préférences</h2>
      {% if isOwner %}
        <button class="btn btn-outline-secondary btn-sm" type="button" data-bs-toggle="modal" data-bs-target="#modalPreferences">
          <i class="bi bi-pencil-fill"></i>
        </button>
      {% endif %}
    </div>

    {% set prefLabels = {
      'chat': ['bi-chat-dots', "J'aime discuter"],
      'no_smoke': ['bi-slash-circle', 'Pas de cigarette'],
      'no_animals': ['bi-slash-circle', "Sans animaux"],
      'music': ['bi-music-note-beamed', "J'aime la musique"],
      'silence': ['bi-volume-mute', 'Trajet calme']
    } %}

    {% if user.preferences is not empty %}
      <div class="tip-list mt-3">
        {% for key in user.preferences %}
          {% if prefLabels[key] is defined %}
            <span><i class="bi {{ prefLabels[key][0] }}"></i> {{ prefLabels[key][1] }}</span>
          {% endif %}
        {% endfor %}
      </div>
    {% else %}
      <p class="text-muted mt-3">Aucune préférence indiquée.</p>
    {% endif %}
  </aside>
</section>

<div class="modal fade" id="modalNotes" tabindex="-1" aria-labelledby="modalNotesLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="modalNotesLabel">Avis sur {{ displayName }}</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
      </div>
      <div class="modal-body">
        {% if notesRecues is empty %}
          <p class="text-muted mb-0">Aucun avis pour le moment.</p>
        {% else %}
          {% for note in notesRecues %}
            <div class="border-bottom pb-3 mb-3">
              <div class="d-flex align-items-center justify-content-between gap-2">
                <strong>{{ note.noteur.prenom == 'Utilisateur supprimé' ? 'Utilisateur supprimé' : note.noteur.prenom }}</strong>
                <span class="text-warning">
                  {% for i in 1..5 %}<i class="bi {{ i <= note.note ? 'bi-star-fill' : 'bi-star' }}"></i>{% endfor %}
                </span>
              </div>
              <small class="text-muted">{{ note.createdAt|date_conversation }}</small>
              {% if note.commentaire %}
                <p class="mb-0 mt-2">{{ note.commentaire }}</p>
              {% endif %}
            </div>
          {% endfor %}
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% if isOwner %}
  <div class="modal fade" id="modalDescription" tabindex="-1" aria-labelledby="modalDescriptionLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <form method="post" action="{{ path('app_update_description') }}">
          <input type="hidden" name="_token" value="{{ csrf_token('profile_description_' ~ user.id) }}">
          <div class="modal-header">
            <h5 class="modal-title" id="modalDescriptionLabel">Modifier ma description</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
          </div>
          <div class="modal-body">
            <div class="form-floating">
              <textarea name="description" id="description" class="form-control app-message-textarea" rows="6" placeholder="Présentez-vous" required>{{ user.description }}</textarea>
              <label for="description">Votre description</label>
            </div>
          </div>
          <div class="modal-footer">
            <button type="submit" class="btn btn-orange w-100">
              <i class="bi bi-check-circle-fill"></i>
              Enregistrer
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <div class="modal fade" id="modalPreferences" tabindex="-1" aria-labelledby="modalPreferencesLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <form method="post" action="{{ path('app_preferences_update') }}">
          <input type="hidden" name="_token" value="{{ csrf_token('profile_preferences_' ~ user.id) }}">
          <div class="modal-header">
            <h5 class="modal-title" id="modalPreferencesLabel">Mes préférences de trajet</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
          </div>
          <div class="modal-body">
            {% set options = {
              'chat': "J'aime discuter pendant le trajet",
              'no_smoke': 'Pas de cigarette, svp',
              'no_animals': 'Je préfère sans animaux',
              'music': "J'aime écouter de la musique",
              'silence': 'Je préfère un trajet calme'
            } %}
            {% for key, label in options %}
              <div class="form-check mb-2">
                <input type="checkbox" class="form-check-input" name="preferences[]" value="{{ key }}" id="pref_{{ key }}" {% if key in user.preferences %}checked{% endif %}>
                <label class="form-check-label" for="pref_{{ key }}">{{ label }}</label>
              </div>
            {% endfor %}
          </div>
          <div class="modal-footer">
            <button type="submit" class="btn btn-orange w-100">
              <i class="bi bi-check-circle-fill"></i>
              Enregistrer
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
{% endif %}
{% endblock %}
