{% extends 'base.html.twig' %}
{% import 'partials/avatar.html.twig' as avatar %}

{% block title %}HaloGari | Mon trajet{% endblock %}

{% set reservationLabels = {
  'en_attente': 'En attente',
  'acceptee': 'Acceptée',
  'payee': 'Payée',
  'refusee': 'Refusée',
  'annulee': 'Annulée'
} %}

{% set paymentLabels = {
  'en_attente': 'Paiement à venir',
  'autorise': 'Paiement enregistré',
  'capture': 'Paiement confirmé',
  'rembourse': 'Remboursé',
  'echoue': 'Échoué',
  'annule': 'Annulé'
} %}

{% set activeReservations = reservations|filter(r => r.statut in ['en_attente', 'acceptee', 'payee']) %}
{% set pendingReservations = reservations|filter(r => r.statut == 'en_attente') %}
{% set confirmedReservations = reservations|filter(r => r.statut in ['acceptee', 'payee']) %}
{% set reservedPlaces = activeReservations|reduce((carry, r) => carry + r.places, 0) %}
{% set totalAutorise = reservations|reduce((carry, r) => carry + (r.paiement and r.paiement.statut == 'autorise' ? r.prixTotal : 0), 0) %}
{% set totalConfirme = reservations|reduce((carry, r) => carry + (r.paiement and r.paiement.statut == 'capture' ? r.prixTotal : 0), 0) %}

{% block body %}
<section class="app-page-header app-page-header--compact">
  <div class="container">
    <p class="app-kicker">Conducteur</p>
    <h1>{{ trajet.depart }} → {{ trajet.arrivee }}</h1>
    <p>Suivez les réservations reçues, contactez vos passagers et gardez le contrôle du trajet.</p>
  </div>
</section>

<section class="container hg-account-section ride-detail">
  <a href="{{ path('app_mes_trajets') }}" class="reservation-back-link">
    <i class="bi bi-arrow-left"></i>
    Voir mes trajets
  </a>

  <div class="ride-detail-layout">
    <article class="app-panel ride-detail-main">
      <div class="reservation-hero">
        <div>
          <span class="reservation-route-kicker">Trajet publié</span>
          <h2>{{ trajet.depart }} <i class="bi bi-arrow-right-short"></i> {{ trajet.arrivee }}</h2>
          <p>{{ ladateTrajet }} à {{ trajet.heureTrajet|date('H:i') }}</p>
        </div>
        {% if trajet.isAnnule() %}
          <span class="reservation-status reservation-status--annulee">
            <i class="bi bi-slash-circle-fill"></i>
            Annulé
          </span>
        {% elseif enCours %}
          <span class="reservation-status reservation-status--en_attente">
            <i class="bi bi-play-circle-fill"></i>
            En cours
          </span>
        {% elseif datePasse %}
          <span class="reservation-status reservation-status--payment-rembourse">
            <i class="bi bi-clock-history"></i>
            Passé
          </span>
        {% else %}
          <span class="reservation-status reservation-status--acceptee">
            <i class="bi bi-check-circle-fill"></i>
            Ouvert
          </span>
        {% endif %}
      </div>

      <div class="reservation-stats ride-detail-stats">
        <div class="reservation-stat">
          <span>Places restantes</span>
          <strong>{{ trajet.placesDisponibles }}</strong>
        </div>
        <div class="reservation-stat">
          <span>Places réservées</span>
          <strong>{{ reservedPlaces }}</strong>
        </div>
        <div class="reservation-stat">
          <span>Prix par place</span>
          <strong>{{ trajet.prix|number_format(2, ',', ' ') }} €</strong>
        </div>
        <div class="reservation-stat">
          <span>Demandes en attente</span>
          <strong>{{ pendingReservations|length }}</strong>
        </div>
      </div>

      <div class="ride-description-box">
        <div class="app-panel__header mb-0">
          <span class="app-panel__icon"><i class="bi bi-chat-left-text-fill"></i></span>
          <div>
            <h2>Description</h2>
            <p>Ce que les passagers voient avant de réserver.</p>
          </div>
        </div>
        {% if trajet.description %}
          <p>{{ trajet.description|nl2br }}</p>
        {% else %}
          <p class="text-muted mb-0">Aucune description n’a été ajoutée pour ce trajet.</p>
        {% endif %}
      </div>

      {% if not trajet.isAnnule() %}
        {% if datePasse %}
          <div class="alert alert-warning mb-0">Ce trajet est passé. Il n’est plus visible par les passagers.</div>
        {% elseif enCours %}
          <div class="alert alert-info mb-0">Ce trajet est en cours. Les nouvelles actions sont limitées.</div>
        {% else %}
          <form method="post" action="{{ path('trajet_annuler', { id: trajet.id }) }}" class="ride-cancel-form">
            <input type="hidden" name="_token" value="{{ csrf_token('annuler_trajet_' ~ trajet.id) }}">
            <button type="submit" class="btn btn-outline-danger" data-confirm="Attention : êtes-vous sûr de vouloir annuler ce trajet ? Cette action est irréversible.">
              <i class="bi bi-x-circle"></i>
              Annuler ce trajet
            </button>
          </form>
        {% endif %}
      {% else %}
        <div class="alert alert-warning mb-0">Ce trajet a été annulé. Il n’est plus visible par les passagers.</div>
      {% endif %}
    </article>

    <aside class="ride-detail-side">
      <article class="app-panel">
        <div class="app-panel__header">
          <span class="app-panel__icon"><i class="bi bi-cash-coin"></i></span>
          <div>
            <h2>Revenus</h2>
            <p>Suivi des paiements liés au trajet.</p>
          </div>
        </div>
        <dl class="reservation-info-list">
          <div>
            <dt>Enregistré</dt>
            <dd>{{ totalAutorise|number_format(2, ',', ' ') }} €</dd>
          </div>
          <div>
            <dt>Confirmé</dt>
            <dd>{{ totalConfirme|number_format(2, ',', ' ') }} €</dd>
          </div>
          <div>
            <dt>Passagers confirmés</dt>
            <dd>{{ confirmedReservations|length }}</dd>
          </div>
        </dl>
      </article>

      <article class="app-panel">
        <div class="app-panel__header">
          <span class="app-panel__icon"><i class="bi bi-person-badge-fill"></i></span>
          <div>
            <h2>Conducteur</h2>
            <p>Votre profil affiché aux passagers.</p>
          </div>
        </div>
        <div class="reservation-driver-card__identity">
          {{ avatar.formatSimple(trajet.conducteur, 58, 0, 1) }}
          <div>
            <span>{{ trajet.conducteur.isProfilVerifieComplet ? 'Profil vérifié' : 'Profil à compléter' }}</span>
            <strong>{{ trajet.conducteur.prenom == 'Utilisateur supprimé' ? 'Utilisateur supprimé' : trajet.conducteur.prenom }}</strong>
          </div>
        </div>
      </article>
    </aside>
  </div>

  <article class="app-panel ride-reservations-panel">
    <div class="app-panel__header">
      <span class="app-panel__icon"><i class="bi bi-people-fill"></i></span>
      <div>
        <h2>Réservations reçues</h2>
        <p>Acceptez, refusez ou contactez les passagers depuis un seul endroit.</p>
      </div>
    </div>

    {% if reservations|length > 0 %}
      <div class="ride-reservation-list">
        {% for reservation in reservations %}
          {% set passengerName = reservation.passager.prenom == 'Utilisateur supprimé' ? 'Utilisateur supprimé' : reservation.passager.prenom %}
          {% set statutPaiement = reservation.paiement ? reservation.paiement.statut : 'en_attente' %}
          {% set showPaymentBadge = (statutPaiement != 'en_attente' or reservation.statut == 'acceptee') and not (reservation.statut == 'payee' and statutPaiement == 'capture') %}
          <div class="ride-reservation-card">
            <a class="ride-reservation-card__user" href="{{ path('app_profile', { id: reservation.passager.id }) }}">
              {{ avatar.formatSimple(reservation.passager, 48, 0, 1) }}
              <div>
                <strong>{{ passengerName }}</strong>
                <span>{{ reservation.places }} place{{ reservation.places > 1 ? 's' : '' }} · {{ reservation.prixTotal|number_format(2, ',', ' ') }} €</span>
              </div>
            </a>

            <div class="ride-reservation-card__badges">
              <span class="reservation-status reservation-status--{{ reservation.statut }}">
                {{ reservationLabels[reservation.statut]|default(reservation.statut|capitalize) }}
              </span>
              {% if showPaymentBadge %}
                <span class="reservation-status reservation-status--payment-{{ statutPaiement }}">
                  {{ paymentLabels[statutPaiement]|default(statutPaiement|capitalize) }}
                </span>
              {% endif %}
            </div>

            <div class="ride-reservation-card__actions">
              {% if reservation.statut == 'en_attente' %}
                {% if not datePasse and not enCours %}
                  <form method="post" action="{{ path('reservation_accepter', { id: reservation.id }) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('reservation_action_' ~ reservation.id) }}">
                    <button type="submit" class="btn btn-success btn-sm">
                      <i class="bi bi-check-lg"></i>
                      Accepter
                    </button>
                  </form>
                  <form method="post" action="{{ path('reservation_refuser', { id: reservation.id }) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('reservation_action_' ~ reservation.id) }}">
                    <button type="submit" class="btn btn-outline-danger btn-sm">
                      <i class="bi bi-x-lg"></i>
                      Refuser
                    </button>
                  </form>
                {% else %}
                  <span class="text-muted small">Action indisponible</span>
                {% endif %}
              {% elseif datePasse and reservation.statut in ['acceptee', 'payee'] %}
                {% set noteExistante = false %}
                {% for note in reservation.passager.notesPour %}
                  {% if note.noteur.id == app.user.id and note.trajet.id == trajet.id %}
                    {% set noteExistante = true %}
                  {% endif %}
                {% endfor %}
                {% if not noteExistante %}
                  <a href="{{ path('app_noter_passager', { trajetId: trajet.id, passagerId: reservation.passager.id }) }}" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-star"></i>
                    Noter
                  </a>
                {% else %}
                  <span class="text-muted small">Déjà noté</span>
                {% endif %}
              {% endif %}

              <a href="{{ path('app_conversation', { userId: reservation.passager.id, trajetId: trajet.id }) }}" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-chat-dots"></i>
                Écrire
              </a>
              {% if reservation.statut in ['acceptee', 'payee'] and reservation.passager.telephone %}
                <a href="tel:{{ reservation.passager.telephone }}" class="btn btn-orange btn-sm">
                  <i class="bi bi-telephone"></i>
                  Appeler
                </a>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    {% else %}
      <div class="alert alert-info mb-0">Aucune réservation pour ce trajet pour le moment.</div>
    {% endif %}
  </article>
</section>
{% endblock %}
