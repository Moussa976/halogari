{% extends 'base.html.twig' %}
{% import 'partials/avatar.html.twig' as avatar %}

{% block title %}HaloGari | Ma réservation{% endblock %}

{% set reservationLabels = {
  'en_attente': 'En attente',
  'acceptee': 'Acceptée',
  'payee': 'Payée',
  'refusee': 'Refusée',
  'annulee': 'Annulée'
} %}

{% set reservationIcons = {
  'en_attente': 'bi-hourglass-split',
  'acceptee': 'bi-hand-thumbs-up-fill',
  'payee': 'bi-check-circle-fill',
  'refusee': 'bi-x-circle-fill',
  'annulee': 'bi-slash-circle-fill'
} %}

{% set paymentLabels = {
  'autorise': 'Autorisé',
  'capture': 'Payé',
  'annule': 'Annulé',
  'rembourse': 'Remboursé',
  'echoue': 'Échoué',
  'en_attente': 'Non payé'
} %}

{% set paymentIcons = {
  'autorise': 'bi-shield-check',
  'capture': 'bi-check-circle-fill',
  'annule': 'bi-x-circle',
  'rembourse': 'bi-arrow-counterclockwise',
  'echoue': 'bi-exclamation-triangle-fill',
  'en_attente': 'bi-clock'
} %}

{% set statutResa = reservation.statut %}
{% set statutPaiement = reservation.paiement ? reservation.paiement.statut : 'en_attente' %}
{% set trajetDateTime = trajet.dateTrajet|date('Y-m-d') ~ ' ' ~ trajet.heureTrajet|date('H:i:s') %}
{% set trajetTimestamp = trajetDateTime|date('U') %}
{% set nowTimestamp = 'now'|date('U') %}
{% set trajetPasse = trajetTimestamp < nowTimestamp %}
{% set peutPayer = reservation.statut == 'acceptee' and (reservation.paiement is null or reservation.paiement.paymentIntentId is null or reservation.paiement.statut == 'en_attente') %}
{% set peutAnnuler = reservation.statut in ['en_attente', 'acceptee'] and not trajetPasse %}
{% set paiementEngage = reservation.paiement and reservation.paiement.statut in ['autorise', 'capture'] %}

{% set dejaNote = false %}
{% set maNote = null %}
{% for note in trajet.conducteur.notesPour %}
  {% if note.noteur.id == app.user.id and note.trajet.id == trajet.id %}
    {% set dejaNote = true %}
    {% set maNote = note %}
  {% endif %}
{% endfor %}

{% block body %}
<section class="app-page-header app-page-header--compact">
  <div class="container">
    <p class="app-kicker">Réservation</p>
    <h1>{{ trajet.depart }} → {{ trajet.arrivee }}</h1>
    <p>Suivez votre demande, votre paiement et les informations utiles pour voyager sereinement.</p>
  </div>
</section>

<section class="container hg-account-section reservation-detail">
  <a href="{{ path('app_mes_reservations') }}" class="reservation-back-link">
    <i class="bi bi-arrow-left"></i>
    Voir mes réservations
  </a>

  <div class="reservation-layout">
    <article class="app-panel reservation-main">
      <div class="reservation-hero">
        <div>
          <span class="reservation-route-kicker">Trajet réservé</span>
          <h2>{{ trajet.depart }} <i class="bi bi-arrow-right-short"></i> {{ trajet.arrivee }}</h2>
          <p>{{ ladateTrajet }} à {{ trajet.heureTrajet|date('H:i') }}</p>
        </div>
        <span class="reservation-status reservation-status--{{ statutResa }}">
          <i class="bi {{ reservationIcons[statutResa]|default('bi-question-circle') }}"></i>
          {{ reservationLabels[statutResa]|default(statutResa|capitalize) }}
        </span>
      </div>

      <div class="reservation-stats">
        <div class="reservation-stat">
          <span>Places</span>
          <strong>{{ reservation.places }}</strong>
        </div>
        <div class="reservation-stat">
          <span>Prix par place</span>
          <strong>{{ reservation.prix|number_format(2, ',', ' ') }} €</strong>
        </div>
        <div class="reservation-stat">
          <span>Total</span>
          <strong>{{ reservation.prixTotal|number_format(2, ',', ' ') }} €</strong>
        </div>
      </div>

      <div class="reservation-timeline" aria-label="Suivi de la réservation">
        <div class="reservation-timeline__item is-done">
          <span><i class="bi bi-send-check-fill"></i></span>
          <div>
            <strong>Demande envoyée</strong>
            <p>{{ reservation.createdAt|date_fr('l d F Y à H:i') }}</p>
          </div>
        </div>
        <div class="reservation-timeline__item {{ reservation.statut in ['acceptee', 'payee'] ? 'is-done' : (reservation.statut == 'en_attente' ? 'is-current' : 'is-muted') }}">
          <span><i class="bi bi-person-check-fill"></i></span>
          <div>
            <strong>Validation conducteur</strong>
            <p>
              {% if reservation.statut == 'en_attente' %}
                En attente de réponse.
              {% elseif reservation.statut == 'refusee' %}
                La demande a été refusée.
              {% elseif reservation.statut == 'annulee' %}
                La réservation a été annulée.
              {% else %}
                Le conducteur a accepté la réservation.
              {% endif %}
            </p>
          </div>
        </div>
        <div class="reservation-timeline__item {{ statutPaiement in ['capture', 'autorise'] ? 'is-done' : (peutPayer ? 'is-current' : 'is-muted') }}">
          <span><i class="bi {{ paymentIcons[statutPaiement]|default('bi-credit-card') }}"></i></span>
          <div>
            <strong>Paiement</strong>
            <p>{{ paymentLabels[statutPaiement]|default(statutPaiement|capitalize) }}{% if peutPayer %} · action requise{% endif %}</p>
          </div>
        </div>
      </div>

      <div class="reservation-actions">
        {% if peutPayer %}
          <a href="{{ path('paiement_form', { id: reservation.id }) }}" class="btn btn-success">
            <i class="bi bi-credit-card-2-front"></i>
            Payer maintenant
          </a>
        {% endif %}

        {% if reservation.statut in ['acceptee', 'payee'] and trajet.conducteur.nom != 'Utilisateur supprimé' %}
          <a href="{{ path('app_conversation', { userId: trajet.conducteur.id, trajetId: trajet.id }) }}" class="btn btn-outline-primary">
            <i class="bi bi-chat-dots"></i>
            Écrire au conducteur
          </a>
          {% if trajet.conducteur.telephone %}
            <a href="tel:{{ trajet.conducteur.telephone }}" class="btn btn-outline-success">
              <i class="bi bi-telephone"></i>
              Appeler
            </a>
          {% endif %}
        {% endif %}

        {% if reservation.statut == 'payee' and trajetPasse and not dejaNote %}
          <a href="{{ path('app_noter_conducteur', { id: trajet.id }) }}" class="btn btn-outline-warning">
            <i class="bi bi-star"></i>
            Noter le conducteur
          </a>
        {% endif %}
      </div>

      {% if peutPayer %}
        <div class="reservation-note">
          <i class="bi bi-exclamation-circle-fill"></i>
          <p><strong>Paiement attendu.</strong> Le conducteur a accepté votre demande : payez rapidement pour confirmer votre place et éviter une annulation avant le départ.</p>
        </div>
      {% endif %}

      {% if dejaNote and maNote is not null %}
        <div class="reservation-rating">
          <span>Votre avis</span>
          <div>
            {% for i in 1..5 %}
              <i class="bi {{ i <= maNote.note ? 'bi-star-fill text-warning' : 'bi-star text-muted' }}"></i>
            {% endfor %}
          </div>
          {% if maNote.commentaire %}
            <p>“{{ maNote.commentaire }}”</p>
          {% endif %}
        </div>
      {% endif %}
    </article>

    <aside class="reservation-side">
      <article class="app-panel reservation-driver-card">
        <div class="reservation-driver-card__identity">
          {{ avatar.formatSimple(trajet.conducteur, 58, 0, 1) }}
          <div>
            <span>Conducteur</span>
            {% if trajet.conducteur.prenom == 'Utilisateur supprimé' %}
              <strong>Utilisateur supprimé</strong>
            {% else %}
              <a href="{{ path('app_profile', { id: trajet.conducteur.id }) }}">{{ trajet.conducteur.prenom }}</a>
            {% endif %}
          </div>
        </div>
        <dl class="reservation-info-list">
          <div>
            <dt>Date</dt>
            <dd>{{ ladateTrajet }}</dd>
          </div>
          <div>
            <dt>Heure</dt>
            <dd>{{ trajet.heureTrajet|date('H:i') }}</dd>
          </div>
          <div>
            <dt>Réservé le</dt>
            <dd>{{ reservation.createdAt|date_fr('d F Y à H:i') }}</dd>
          </div>
          <div>
            <dt>Paiement</dt>
            <dd>
              <span class="reservation-status reservation-status--payment-{{ statutPaiement }}">
                <i class="bi {{ paymentIcons[statutPaiement]|default('bi-credit-card') }}"></i>
                {{ paymentLabels[statutPaiement]|default(statutPaiement|capitalize) }}
              </span>
            </dd>
          </div>
        </dl>
      </article>

      {% if reservation.statut in ['acceptee', 'payee'] %}
        <article class="app-panel reservation-passengers">
          <div class="app-panel__header">
            <span class="app-panel__icon"><i class="bi bi-people-fill"></i></span>
            <div>
              <h2>Passagers</h2>
              <p>Les personnes confirmées sur ce trajet.</p>
            </div>
          </div>

          {% set autresPassagers = trajet.reservations|filter(r => r.passager.id != app.user.id and r.statut in ['acceptee', 'payee']) %}
          {% if autresPassagers|length > 0 %}
            <div class="reservation-passenger-list">
              {% for autre in autresPassagers %}
                <div class="reservation-passenger">
                  {{ avatar.formatSimple(autre.passager, 42, 0, 1) }}
                  <span>{{ autre.passager.prenom == 'Utilisateur supprimé' ? 'Utilisateur supprimé' : autre.passager.prenom }}</span>
                </div>
              {% endfor %}
            </div>
          {% else %}
            <p class="mb-0 text-muted">Vous êtes le seul passager confirmé pour l’instant.</p>
          {% endif %}
        </article>
      {% endif %}

      {% if peutAnnuler %}
        <article class="app-panel reservation-cancel-policy">
          <h2>Conditions d’annulation</h2>
          {% if paiementEngage %}
            <p>Votre paiement est déjà autorisé ou confirmé. En cas d’annulation, HaloGari applique la politique de remboursement selon le délai avant le départ.</p>
            <ul>
              <li>Plus de 24 h avant le départ : remboursement total.</li>
              <li>Entre 24 h et 3 h avant le départ : remboursement partiel possible.</li>
              <li>Moins de 3 h avant le départ : remboursement non garanti.</li>
            </ul>
          {% elseif reservation.statut == 'acceptee' %}
            <p>Votre réservation est acceptée, mais le paiement n’est pas finalisé. Si vous annulez maintenant, les places seront remises à disposition du conducteur.</p>
          {% else %}
            <p>Votre demande est encore en attente. Vous pouvez l’annuler sans paiement ni remboursement à gérer.</p>
          {% endif %}
        </article>

        <article class="app-panel reservation-danger">
          <h2>Besoin d’annuler ?</h2>
          <p>Annulez seulement si vous ne pouvez vraiment pas voyager. Cette action change le statut de votre réservation.</p>
          <form method="POST" action="{{ path('reservation_annuler', { id: reservation.id }) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir annuler cette réservation ? Cette action est irréversible.');">
            <input type="hidden" name="_token" value="{{ csrf_token('annuler_reservation_' ~ reservation.id) }}">
            <button type="submit" class="btn btn-outline-danger w-100">
              <i class="bi bi-x-circle"></i>
              Annuler ma réservation
            </button>
          </form>
        </article>
      {% endif %}
    </aside>
  </div>
</section>
{% endblock %}
