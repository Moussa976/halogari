{% extends 'base.html.twig' %}

{% block title %}HaloGari | Mes paiements{% endblock %}

{% set paiementLabels = {
  'en_attente': 'En attente',
  'autorise': 'Autorisé',
  'capture': 'Confirmé',
  'rembourse': 'Remboursé',
  'echoue': 'Échoué',
  'annule': 'Annulé'
} %}

{% block body %}
<section class="app-page-header app-page-header--compact">
  <div class="container">
    <p class="app-kicker">Portefeuille</p>
    <h1>Mes paiements</h1>
    <p>Suivez vos paiements, remboursements et autorisations liés aux trajets HaloGari.</p>
  </div>
</section>

<section class="container app-page-grid">
  <article class="app-panel">
    <div class="app-panel__header">
      <div>
        <h2>Historique</h2>
        <p>Les paiements sont sécurisés par Stripe. HaloGari n'enregistre jamais les numéros complets de carte bancaire.</p>
      </div>
      <span class="badge bg-light text-dark border">{{ paiements|length }} opération{{ paiements|length > 1 ? 's' : '' }}</span>
    </div>

    {% if paiements is empty %}
      <div class="alert alert-info mb-0">
        Aucun paiement pour le moment. Vos opérations apparaîtront ici après une réservation acceptée ou un paiement conducteur.
      </div>
    {% else %}
      <div class="table-responsive">
        <table class="table align-middle responsive-card-table">
          <thead>
            <tr>
              <th>Date</th>
              <th>Trajet</th>
              <th>Rôle</th>
              <th>Montant</th>
              <th>Statut</th>
            </tr>
          </thead>
          <tbody>
            {% for paiement in paiements %}
              {% set reservation = paiement.reservation %}
              {% set trajet = reservation.trajet %}
              {% set role = reservation.passager == app.user ? 'Passager' : 'Conducteur' %}
              <tr>
                <td data-label="Date">{{ paiement.createdAt ? paiement.createdAt|date_conversation : '-' }}</td>
                <td data-label="Trajet">
                  <strong>{{ trajet.depart }} → {{ trajet.arrivee }}</strong><br>
                  <small class="text-muted">{{ trajet.dateTrajet|date_fr('d F Y') }} à {{ trajet.heureTrajet|date('H:i') }}</small>
                </td>
                <td data-label="Rôle">{{ role }}</td>
                <td data-label="Montant"><strong>{{ paiement.montant|number_format(2, ',', ' ') }} €</strong></td>
                <td data-label="Statut">
                  <span class="badge {% if paiement.statut in ['capture', 'autorise'] %}bg-success{% elseif paiement.statut in ['rembourse'] %}bg-info text-dark{% elseif paiement.statut in ['annule', 'echoue'] %}bg-danger{% else %}bg-warning text-dark{% endif %}">
                    {{ paiementLabels[paiement.statut]|default(paiement.statut) }}
                  </span>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    {% endif %}
  </article>

  <aside class="app-panel app-tips-panel">
    <span class="app-panel__icon"><i class="bi bi-shield-check"></i></span>
    <h2>À savoir</h2>
    <div class="tip-list">
      <span><i class="bi bi-check-circle-fill"></i> Autorisation avant capture</span>
      <span><i class="bi bi-check-circle-fill"></i> Remboursement selon la politique HaloGari</span>
      <span><i class="bi bi-check-circle-fill"></i> Reçus et opérations gérés via Stripe</span>
    </div>
    <a class="btn btn-outline-primary w-100 mt-3" href="{{ path('app_conditionsutisation') }}#remboursement">
      <i class="bi bi-arrow-repeat"></i>
      Politique de remboursement
    </a>
  </aside>
</section>
{% endblock %}
