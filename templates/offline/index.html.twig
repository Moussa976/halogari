<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow">
  <title>HaloGari arrive bientôt</title>
  <link rel="icon" href="{{ asset('images/icons/favicon.ico') }}">
  <style>
    :root {
      --hg-green: #1f6b3a;
      --hg-dark: #17201b;
      --hg-orange: #ff8200;
      --hg-soft: #f7fbf7;
    }

    * {
      box-sizing: border-box;
    }

    body {
      min-height: 100vh;
      margin: 0;
      display: grid;
      place-items: center;
      padding: 24px;
      font-family: Arial, Helvetica, sans-serif;
      color: var(--hg-dark);
      background:
        radial-gradient(circle at 15% 20%, rgba(255, 130, 0, 0.12), transparent 28%),
        radial-gradient(circle at 85% 80%, rgba(31, 107, 58, 0.14), transparent 30%),
        linear-gradient(135deg, #fffaf2, var(--hg-soft));
    }

    .offline-card {
      width: min(680px, 100%);
      padding: clamp(28px, 6vw, 56px);
      border: 1px solid rgba(31, 107, 58, 0.16);
      border-radius: 28px;
      background: rgba(255, 255, 255, 0.88);
      box-shadow: 0 28px 80px rgba(23, 32, 27, 0.12);
      text-align: center;
    }

    .offline-card img {
      width: min(260px, 72vw);
      height: auto;
      margin-bottom: 28px;
    }

    .offline-eyebrow {
      margin: 0 0 12px;
      color: var(--hg-orange);
      font-size: 0.82rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    h1 {
      margin: 0 0 16px;
      color: var(--hg-green);
      font-size: clamp(2rem, 7vw, 3.7rem);
      line-height: 1;
    }

    p {
      margin: 0 auto;
      max-width: 520px;
      color: #56635b;
      font-size: clamp(1rem, 2.8vw, 1.2rem);
      line-height: 1.55;
    }

    .offline-footer {
      margin-top: 28px;
      color: #6d796f;
      font-size: 0.95rem;
    }
  </style>
</head>
<body>
  <main class="offline-card" role="main">
    <img src="{{ asset('images/logo/logo-787x298.png') }}" alt="HaloGari">
    <p class="offline-eyebrow">Préparation en cours</p>
    <h1>HaloGari arrive bientôt</h1>
    <p>{{ offlineMessage }}</p>
    <div class="offline-footer">WEB976 prépare l’ouverture du covoiturage local à Mayotte.</div>
  </main>
</body>
</html>
