{% extends 'base.html.twig' %}
{% import 'partials/avatar.html.twig' as avatar %}

{% block title %}HaloGari | Mes conversations{% endblock %}

{% block body %}
<section class="app-page-header app-page-header--compact">
  <div class="container">
    <p class="app-kicker">Messagerie</p>
    <h1>Mes conversations</h1>
    <p>Retrouvez les échanges liés à vos trajets et réservations.</p>
  </div>
</section>

<section class="container hg-chat-section">
  <div class="app-panel hg-chat-index">
    <div class="app-panel__header">
      <div>
        <h2>Conversations</h2>
        <p>{{ conversations|length }} échange{{ conversations|length > 1 ? 's' : '' }}</p>
      </div>
      <a href="{{ path('app_chercher') }}" class="btn btn-outline-primary btn-sm">
        <i class="bi bi-search"></i>
        Chercher
      </a>
    </div>

    {% if conversations is empty %}
      <div class="empty-state mb-0">
        <i class="bi bi-chat-dots"></i>
        <h3>Aucune conversation</h3>
        <p>Quand une réservation est acceptée, vous pouvez discuter avec l'autre personne ici.</p>
      </div>
    {% else %}
      <div class="hg-chat-index-list">
        {% for conv in conversations %}
          {% set convName = conv.user.prenom == 'Utilisateur supprimé' ? 'Utilisateur supprimé' : conv.user.prenom %}
          <a href="{{ path('app_conversation', { userId: conv.user.id, trajetId: conv.trajet.id }) }}" class="hg-chat-index-item">
            {{ avatar.formatSimple(conv.user, 48, 0, true) }}
            <span class="hg-chat-item__body">
              <span class="hg-chat-item__top">
                <strong>{{ convName }}</strong>
                <small>{{ conv.lastMessage.createdAt|date_conversation }}</small>
              </span>
              <span class="hg-chat-item__route">{{ conv.trajet.depart }} → {{ conv.trajet.arrivee }}</span>
              <span class="hg-chat-item__preview">
                {% if conv.lastMessage.contenu %}
                  {{ conv.lastMessage.contenu|slice(0, 80) }}{{ conv.lastMessage.contenu|length > 80 ? '…' : '' }}
                {% else %}
                  Photo envoyée
                {% endif %}
              </span>
            </span>
            {% if conv.unreadCount > 0 %}
              <span class="badge bg-danger rounded-pill">{{ conv.unreadCount }}</span>
            {% endif %}
          </a>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>
{% endblock %}
