{% extends 'base.html.twig' %}

{% set otherName = otherUser.prenom == 'Utilisateur supprimé' ? 'Utilisateur supprimé' : otherUser.prenom %}

{% block title %}HaloGari | Conversation avec {{ otherName }}{% endblock %}

{% block body %}
<section class="app-page-header app-page-header--compact">
  <div class="container">
    <p class="app-kicker">Messagerie</p>
    <h1>Conversation</h1>
    <p>Organisez les détails du trajet dans un espace clair, lié à votre réservation.</p>
  </div>
</section>

<section class="container hg-chat-section">
  <div class="hg-chat-shell">
    <aside class="app-panel hg-chat-sidebar">
      <div class="app-panel__header">
        <div>
          <h2>Conversations</h2>
          <p>{{ conversations|length }} échange{{ conversations|length > 1 ? 's' : '' }}</p>
        </div>
      </div>

      {% if conversations is empty %}
        <div class="alert alert-light border mb-0">Aucune conversation.</div>
      {% else %}
        <div class="hg-chat-list">
          {% for conv in conversations %}
            {% set convName = conv.user.prenom == 'Utilisateur supprimé' ? 'Utilisateur supprimé' : conv.user.prenom %}
            <a href="{{ path('app_conversation', { userId: conv.user.id, trajetId: conv.trajet.id }) }}" class="hg-chat-item {{ conv.key == activeConversationKey ? 'is-active' : '' }}">
              <span class="hg-avatar-wrap hg-chat-item__avatar-wrap{% if conv.user.isProfilVerifieComplet %} is-verified{% endif %}"
                    {% if conv.user.isProfilVerifieComplet %}
                      tabindex="0"
                      data-bs-toggle="tooltip"
                      data-bs-title="Profil vérifié : pièce d'identité et adresse e-mail validées"
                      title="Profil vérifié : pièce d'identité et adresse e-mail validées"
                    {% endif %}>
                <img src="{{ conv.user.photo ? asset('uploads/photos/' ~ conv.user.photo) : asset('images/profil.png') }}" alt="Photo de {{ convName }}" class="hg-chat-item__avatar">
                {% if conv.user.isProfilVerifieComplet %}
                  <span class="hg-verified-badge" aria-label="Profil vérifié">
                    <i class="bi bi-patch-check-fill"></i>
                  </span>
                {% endif %}
              </span>
              <span class="hg-chat-item__body">
                <span class="hg-chat-item__top">
                  <strong>{{ convName }}</strong>
                  <small>{{ conv.lastMessage.createdAt|date_conversation }}</small>
                </span>
                <span class="hg-chat-item__route">{{ conv.trajet.depart }} → {{ conv.trajet.arrivee }}</span>
                <span class="hg-chat-item__preview">
                  {% if conv.lastMessage.contenu %}
                    {{ conv.lastMessage.contenu|slice(0, 58) }}{{ conv.lastMessage.contenu|length > 58 ? '…' : '' }}
                  {% else %}
                    Photo envoyée
                  {% endif %}
                </span>
              </span>
              {% if conv.unreadCount > 0 %}
                <span class="badge bg-danger rounded-pill">{{ conv.unreadCount }}</span>
              {% endif %}
            </a>
          {% endfor %}
        </div>
      {% endif %}
    </aside>

    <article class="app-panel hg-chat-panel">
      <header class="hg-chat-header">
        <a href="{{ path('app_message') }}" class="btn btn-outline-secondary btn-sm hg-chat-back">
          <i class="bi bi-arrow-left"></i>
          Conversations
        </a>
        <div class="d-flex align-items-center gap-3">
          <a href="{{ path('app_profile', { id: otherUser.id }) }}" class="hg-avatar-wrap hg-chat-header__avatar-wrap{% if otherUser.isProfilVerifieComplet %} is-verified{% endif %}"
             {% if otherUser.isProfilVerifieComplet %}
               tabindex="0"
               data-bs-toggle="tooltip"
               data-bs-title="Profil vérifié : pièce d'identité et adresse e-mail validées"
               title="Profil vérifié : pièce d'identité et adresse e-mail validées"
             {% endif %}>
            <img src="{{ otherUser.photo ? asset('uploads/photos/' ~ otherUser.photo) : asset('images/profil.png') }}" alt="Photo de {{ otherName }}" class="hg-chat-header__avatar">
            {% if otherUser.isProfilVerifieComplet %}
              <span class="hg-verified-badge" aria-label="Profil vérifié">
                <i class="bi bi-patch-check-fill"></i>
              </span>
            {% endif %}
          </a>
          <div>
            <h2><a href="{{ path('app_profile', { id: otherUser.id }) }}" class="text-reset text-decoration-none">{{ otherName }}</a></h2>
            <p>{{ trajet.depart }} → {{ trajet.arrivee }} · {{ ladateTrajet }} à {{ trajet.heureTrajet|date('H:i') }}</p>
          </div>
        </div>
      </header>

      <div class="hg-chat-messages" id="messages-container">
        {% for message in messages %}
          {% set isMine = message.expediteur.id == app.user.id %}
          {% set senderName = message.expediteur.prenom == 'Utilisateur supprimé' ? 'Utilisateur supprimé' : message.expediteur.prenom %}
          <div class="hg-message {{ isMine ? 'is-mine' : '' }}">
            <a href="{{ path('app_profile', { id: message.expediteur.id }) }}" class="hg-avatar-wrap hg-message__avatar-wrap{% if message.expediteur.isProfilVerifieComplet %} is-verified{% endif %}"
               {% if message.expediteur.isProfilVerifieComplet %}
                 tabindex="0"
                 data-bs-toggle="tooltip"
                 data-bs-title="Profil vérifié : pièce d'identité et adresse e-mail validées"
                 title="Profil vérifié : pièce d'identité et adresse e-mail validées"
               {% endif %}>
              <img src="{{ message.expediteur.photo ? asset('uploads/photos/' ~ message.expediteur.photo) : asset('images/profil.png') }}" alt="Photo de {{ senderName }}" class="hg-message__avatar">
              {% if message.expediteur.isProfilVerifieComplet %}
                <span class="hg-verified-badge" aria-label="Profil vérifié">
                  <i class="bi bi-patch-check-fill"></i>
                </span>
              {% endif %}
            </a>
            <div class="hg-message__content">
              <div class="hg-message__bubble">
                {% if message.imageFilename %}
                  <a href="{{ asset('uploads/messages/' ~ message.imageFilename) }}" target="_blank" rel="noopener" class="hg-message__image-link">
                    <img src="{{ asset('uploads/messages/' ~ message.imageFilename) }}" alt="Photo envoyée par {{ senderName }}" class="hg-message__image">
                  </a>
                {% endif %}
                {% if message.contenu %}
                  <div class="hg-message__text">{{ message.contenu|nl2br }}</div>
                {% endif %}
              </div>
              <div class="hg-message__date">{{ message.createdAt|date_conversation }}</div>
            </div>
          </div>
        {% else %}
          <div class="alert alert-light border text-center mb-0">Aucun message pour le moment.</div>
        {% endfor %}
      </div>

      <form id="message-form" class="hg-chat-form" enctype="multipart/form-data">
        <input type="file" id="message-image" name="image" accept="image/jpeg,image/png,image/webp" hidden>
        <div class="hg-chat-composer">
          <button class="btn hg-chat-photo-btn" type="button" id="message-image-button" title="Ajouter une photo" aria-label="Ajouter une photo">
            <i class="bi bi-image"></i>
          </button>
          <textarea id="message-input" name="contenu" class="form-control" placeholder="Message..." maxlength="2000" autocomplete="off" rows="1"></textarea>
          <button class="btn btn-orange hg-chat-send-btn" type="submit" aria-label="Envoyer">
            <i class="bi bi-send-fill"></i>
          </button>
        </div>
        <div class="hg-chat-image-preview" id="message-image-preview" hidden></div>
      </form>
    </article>
  </div>
</section>
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function () {
  const container = document.getElementById('messages-container');
  if (container) {
    container.scrollTop = container.scrollHeight;
  }

  const form = document.getElementById('message-form');
  const input = document.getElementById('message-input');
  const imageInput = document.getElementById('message-image');
  const imageButton = document.getElementById('message-image-button');
  const imagePreview = document.getElementById('message-image-preview');
  const destinataireId = {{ otherUser.id|json_encode }};
  const trajetId = {{ trajet.id|json_encode }};
  let previewUrl = null;

  const clearImagePreview = () => {
    if (previewUrl) {
      URL.revokeObjectURL(previewUrl);
      previewUrl = null;
    }
    if (imageInput) {
      imageInput.value = '';
    }
    imagePreview.hidden = true;
    imagePreview.innerHTML = '';
  };

  imageButton?.addEventListener('click', () => imageInput?.click());

  imageInput?.addEventListener('change', function () {
    const file = imageInput.files?.[0];
    if (!file) {
      clearImagePreview();
      return;
    }

    if (!file.type.startsWith('image/')) {
      Swal.fire({
        icon: 'error',
        title: 'Photo invalide',
        text: 'Ajoutez une image JPG, PNG ou WebP.'
      });
      clearImagePreview();
      return;
    }

    if (file.size > 4 * 1024 * 1024) {
      Swal.fire({
        icon: 'error',
        title: 'Photo trop lourde',
        text: 'La photo doit faire 4 Mo maximum.'
      });
      clearImagePreview();
      return;
    }

    if (previewUrl) {
      URL.revokeObjectURL(previewUrl);
    }
    previewUrl = URL.createObjectURL(file);
    imagePreview.hidden = false;
    imagePreview.innerHTML = '';

    const figure = document.createElement('figure');
    figure.className = 'hg-chat-preview-card';

    const image = document.createElement('img');
    image.src = previewUrl;
    image.alt = 'Aperçu de la photo à envoyer';

    const removeButton = document.createElement('button');
    removeButton.type = 'button';
    removeButton.className = 'hg-chat-preview-remove';
    removeButton.setAttribute('aria-label', 'Retirer la photo');
    removeButton.innerHTML = '<i class="bi bi-x-lg"></i>';

    figure.appendChild(image);
    figure.appendChild(removeButton);
    imagePreview.appendChild(figure);

    removeButton.addEventListener('click', clearImagePreview);
  });

  input?.addEventListener('keydown', function (event) {
    if ((event.ctrlKey || event.metaKey) && event.key === 'Enter') {
      event.preventDefault();
      form?.requestSubmit();
    }
  });

  form?.addEventListener('submit', function (event) {
    event.preventDefault();
    const contenu = input.value.trim();
    const image = imageInput.files?.[0] || null;
    if (contenu === '' && !image) return;

    const formData = new FormData();
    formData.append('contenu', contenu);
    formData.append('destinataire', destinataireId);
    formData.append('trajet', trajetId);
    if (image) {
      formData.append('image', image);
    }

    fetch('{{ path('api_message_send') }}', {
      method: 'POST',
      body: formData
    })
      .then(response => response.json())
      .then(data => {
        if (data.status !== 'sent') {
          Swal.fire({
            icon: 'error',
            title: 'Message non envoyé',
            text: data.message || 'Impossible d’envoyer le message.'
          });
          return;
        }

        const message = document.createElement('div');
        message.className = 'hg-message is-mine';

        const avatarWrap = document.createElement('a');
        avatarWrap.className = 'hg-avatar-wrap hg-message__avatar-wrap';
        avatarWrap.href = data.profileUrl || '#';
        if (data.isVerifiedProfile) {
          avatarWrap.classList.add('is-verified');
          avatarWrap.tabIndex = 0;
          avatarWrap.setAttribute('data-bs-toggle', 'tooltip');
          avatarWrap.setAttribute('data-bs-title', "Profil vérifié : pièce d'identité et adresse e-mail validées");
          avatarWrap.setAttribute('title', "Profil vérifié : pièce d'identité et adresse e-mail validées");
        }

        const avatar = document.createElement('img');
        avatar.className = 'hg-message__avatar';
        avatar.src = data.avatarUrl || '{{ asset('images/profil.png') }}';
        avatar.alt = data.avatarAlt || 'Photo de profil';

        avatarWrap.appendChild(avatar);
        if (data.isVerifiedProfile) {
          const badge = document.createElement('span');
          badge.className = 'hg-verified-badge';
          badge.setAttribute('aria-label', 'Profil vérifié');
          badge.innerHTML = '<i class="bi bi-patch-check-fill"></i>';
          avatarWrap.appendChild(badge);
          bootstrap.Tooltip.getOrCreateInstance(avatarWrap);
        }

        const content = document.createElement('div');
        content.className = 'hg-message__content';

        const bubble = document.createElement('div');
        bubble.className = 'hg-message__bubble';

        if (data.imageUrl) {
          const imageLink = document.createElement('a');
          imageLink.href = data.imageUrl;
          imageLink.target = '_blank';
          imageLink.rel = 'noopener';
          imageLink.className = 'hg-message__image-link';

          const imageElement = document.createElement('img');
          imageElement.src = data.imageUrl;
          imageElement.alt = 'Photo envoyée';
          imageElement.className = 'hg-message__image';

          imageLink.appendChild(imageElement);
          bubble.appendChild(imageLink);
        }

        if (data.contenu) {
          const text = document.createElement('div');
          text.className = 'hg-message__text';
          text.textContent = data.contenu;
          bubble.appendChild(text);
        }

        const date = document.createElement('div');
        date.className = 'hg-message__date';
        date.textContent = data.createdAt;

        content.appendChild(bubble);
        content.appendChild(date);
        message.appendChild(avatarWrap);
        message.appendChild(content);
        container.appendChild(message);
        container.scrollTop = container.scrollHeight;
        input.value = '';
        clearImagePreview();
      })
      .catch(() => {
        Swal.fire({
          icon: 'error',
          title: 'Connexion impossible',
          text: 'Veuillez réessayer dans quelques instants.'
        });
      });
  });
});
</script>
{% endblock %}
