{% extends 'base_admin.html.twig' %}

{% block title %}Trajets | Admin{% endblock %}

{% block body %}
  <div class="container-fluid px-1">
    <div class="d-flex flex-column flex-md-row justify-content-between gap-3 mb-4">
      <div>
        <h1 class="h3 mb-1">Trajets</h1>
        <p class="text-muted mb-0">Tous les trajets publiés, annulés ou passés.</p>
      </div>
      <span class="badge bg-primary align-self-start">{{ trajets|length }} trajet{{ trajets|length > 1 ? 's' : '' }}</span>
    </div>

    <div class="card">
      <div class="card-body table-responsive">
        <table class="table table-hover align-middle">
          <thead class="table-light">
            <tr>
              <th>ID</th>
              <th>Trajet</th>
              <th>Conducteur</th>
              <th>Date</th>
              <th>Places</th>
              <th>Prix</th>
              <th>Statut</th>
              <th>Demandes</th>
            </tr>
          </thead>
          <tbody>
            {% for trajet in trajets %}
              {% set dateDepart = trajet.dateTrajet ? trajet.dateTrajet|date('Y-m-d') ~ ' ' ~ trajet.heureTrajet|date('H:i:s') : null %}
              {% set isPast = dateDepart ? date(dateDepart) < date() : false %}
              {% set activeReservations = trajet.reservations|filter(r => r.statut in ['en_attente', 'acceptee', 'payee'])|length %}
              <tr>
                <td>#{{ trajet.id }}</td>
                <td>
                  <strong>{{ trajet.depart }}</strong>
                  <span class="text-muted">→</span>
                  <strong>{{ trajet.arrivee }}</strong>
                </td>
                <td>
                  {% if trajet.conducteur %}
                    <a href="{{ path('admin_user_show', { id: trajet.conducteur.id }) }}">
                      {{ trajet.conducteur.prenom }} {{ trajet.conducteur.nom }}
                    </a>
                  {% else %}
                    <span class="text-muted">-</span>
                  {% endif %}
                </td>
                <td>{{ trajet.dateTrajet|date('d/m/Y') }} à {{ trajet.heureTrajet|date('H:i') }}</td>
                <td>{{ trajet.placesDisponibles }}/{{ trajet.places }}</td>
                <td>{{ trajet.prix|number_format(2, ',', ' ') }} €</td>
                <td>
                  {% if trajet.isAnnule %}
                    <span class="badge bg-danger">Annulé</span>
                  {% elseif isPast %}
                    <span class="badge bg-secondary">Passé</span>
                  {% else %}
                    <span class="badge bg-success">À venir</span>
                  {% endif %}
                </td>
                <td>{{ activeReservations }} active{{ activeReservations > 1 ? 's' : '' }}</td>
              </tr>
            {% else %}
              <tr>
                <td colspan="8" class="text-center text-muted">Aucun trajet.</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  </div>
{% endblock %}
