{% extends 'base_admin.html.twig' %}
{% import 'partials/avatar.html.twig' as avatar %}

{% block title %}Trajets | Admin{% endblock %}

{% block body %}
  {% set reservationLabels = {
    'en_attente': 'En attente',
    'acceptee': 'Acceptée',
    'refusee': 'Refusée',
    'payee': 'Payée',
    'annulee': 'Annulée'
  } %}
  {% set reservationClasses = {
    'en_attente': 'warning text-dark',
    'acceptee': 'success',
    'refusee': 'danger',
    'payee': 'primary',
    'annulee': 'secondary'
  } %}
  {% set trajetClasses = {
    'annule': 'danger',
    'litige': 'danger',
    'valide': 'success',
    'termine': 'secondary',
    'en_cours': 'info text-dark',
    'avenir': 'success',
    'inconnu': 'secondary'
  } %}
  {% set trajetLabels = {
    'annule': 'Annulé',
    'litige': 'Litige',
    'valide': 'Validé',
    'termine': 'Terminé',
    'en_cours': 'En cours',
    'avenir': 'À venir',
    'inconnu': 'Inconnu'
  } %}

  <div class="container-fluid px-1">
    <div class="d-flex flex-column flex-md-row justify-content-between gap-3 mb-4">
      <div>
        <h1 class="h3 mb-1">Trajets</h1>
        <p class="text-muted mb-0">Vue complète des trajets, passagers, places, paiements et conversations associées.</p>
      </div>
      <span class="badge bg-primary align-self-start">{{ trajets|length }} trajet{{ trajets|length > 1 ? 's' : '' }}</span>
    </div>

    <div class="card">
      <div class="card-body table-responsive">
        <table class="table table-hover align-middle js-admin-table">
          <thead class="table-light">
            <tr>
              <th>ID</th>
              <th>Trajet</th>
              <th>Conducteur</th>
              <th>Date</th>
              <th>Places</th>
              <th>Prix</th>
              <th>Statut</th>
              <th>Facebook</th>
              <th>Passagers</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            {% for trajet in trajets %}
              {% set statutOperationnel = trajet.statutOperationnel %}
              {% set activeReservations = trajet.reservations|filter(r => r.statut in ['en_attente', 'acceptee', 'payee']) %}
              {% set paidReservations = trajet.reservations|filter(r => r.statut == 'payee') %}
              <tr>
                <td>#{{ trajet.id }}</td>
                <td>
                  <strong>{{ trajet.depart }}</strong>
                  <span class="text-muted">→</span>
                  <strong>{{ trajet.arrivee }}</strong>
                  {% if trajet.description %}
                    <div class="small text-muted text-truncate" style="max-width: 260px;">{{ trajet.description }}</div>
                  {% endif %}
                </td>
                <td>
                  {% if trajet.conducteur %}
                    <div class="d-flex align-items-center gap-2">
                      {{ avatar.formatSimple(trajet.conducteur, 42, 0, 1) }}
                      <div class="min-w-0">
                        <a href="{{ path('admin_user_show', { id: trajet.conducteur.id }) }}">
                          {{ trajet.conducteur.prenom }} {{ trajet.conducteur.nom }}
                        </a>
                        {% if trajet.conducteur.isProfilVerifieComplet %}
                          <span class="badge bg-success-subtle text-success border border-success-subtle ms-1">Profil vérifié</span>
                        {% endif %}
                        <div class="small text-muted text-truncate" style="max-width: 210px;">{{ trajet.conducteur.telephone ?: trajet.conducteur.email }}</div>
                      </div>
                    </div>
                  {% else %}
                    <span class="text-muted">-</span>
                  {% endif %}
                </td>
                <td>{{ trajet.dateTrajet|date('d/m/Y') }} à {{ trajet.heureTrajet|date('H:i') }}</td>
                <td>{{ trajet.placesDisponibles }}/{{ trajet.places }}</td>
                <td>{{ trajet.prix|number_format(2, ',', ' ') }} €</td>
                <td>
                  <span class="badge bg-{{ trajetClasses[statutOperationnel]|default('secondary') }}">{{ trajetLabels[statutOperationnel]|default(statutOperationnel) }}</span>
                </td>
                <td>
                  {% if trajet.facebookPostId %}
                    <span class="badge bg-success">Publié</span>
                    {% if trajet.facebookPostedAt %}
                      <div class="small text-muted">{{ trajet.facebookPostedAt|date('d/m/Y H:i') }}</div>
                    {% endif %}
                  {% elseif trajet.facebookPostError %}
                    <span class="badge bg-danger">Erreur</span>
                    <div class="small text-muted text-truncate" style="max-width: 180px;">{{ trajet.facebookPostError }}</div>
                  {% else %}
                    <span class="badge bg-light text-dark border">Non publié</span>
                  {% endif %}
                </td>
                <td>
                  <strong>{{ trajet.reservations|length }}</strong>
                  <div class="small text-muted">{{ activeReservations|length }} active{{ activeReservations|length > 1 ? 's' : '' }}, {{ paidReservations|length }} payée{{ paidReservations|length > 1 ? 's' : '' }}</div>
                </td>
                <td>
                  <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#trajet-modal-{{ trajet.id }}">
                    Voir détail
                  </button>
                </td>
              </tr>
            {% else %}
              <tr>
                <td colspan="10" class="text-center text-muted">Aucun trajet.</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>

    {% for trajet in trajets %}
      {% set statutOperationnel = trajet.statutOperationnel %}
      <div class="modal fade" id="trajet-modal-{{ trajet.id }}" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
          <div class="modal-content">
            <div class="modal-header">
              <div>
                <h5 class="modal-title">Trajet #{{ trajet.id }} - {{ trajet.depart }} → {{ trajet.arrivee }}</h5>
                <div class="text-muted small">{{ trajet.dateTrajet|date('d/m/Y') }} à {{ trajet.heureTrajet|date('H:i') }}</div>
              </div>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
            </div>
            <div class="modal-body">
              <div class="row g-3 mb-4">
                <div class="col-md-3">
                  <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Conducteur</div>
                    {% if trajet.conducteur %}
                      <div class="d-flex align-items-center gap-2 mb-2">
                        {{ avatar.formatSimple(trajet.conducteur, 48, 0, 1) }}
                        <div class="min-w-0">
                          <a class="fw-bold" href="{{ path('admin_user_show', { id: trajet.conducteur.id }) }}">{{ trajet.conducteur.prenom }} {{ trajet.conducteur.nom }}</a>
                          {% if trajet.conducteur.isProfilVerifieComplet %}
                            <div><span class="badge bg-success-subtle text-success border border-success-subtle">Profil vérifié</span></div>
                          {% endif %}
                        </div>
                      </div>
                      <div class="small text-truncate">{{ trajet.conducteur.email }}</div>
                      <div class="small">{{ trajet.conducteur.telephone ?: '-' }}</div>
                    {% else %}
                      <strong>-</strong>
                    {% endif %}
                  </div>
                </div>
                <div class="col-md-3">
                  <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Places</div>
                    <strong>{{ trajet.placesDisponibles }}/{{ trajet.places }}</strong>
                  </div>
                </div>
                <div class="col-md-3">
                  <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Prix</div>
                    <strong>{{ trajet.prix|number_format(2, ',', ' ') }} € / place</strong>
                  </div>
                </div>
                <div class="col-md-3">
                  <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Suivi</div>
                    <span class="badge bg-{{ trajetClasses[statutOperationnel]|default('secondary') }}">{{ trajetLabels[statutOperationnel]|default(statutOperationnel) }}</span>
                    {% if trajet.statusUpdatedAt %}
                      <div class="small text-muted mt-1">{{ trajet.statusUpdatedAt|date('d/m/Y à H:i') }}</div>
                    {% endif %}
                  </div>
                </div>
              </div>

              <div class="border rounded p-3 mb-4">
                <h6>Modifier la date et l&rsquo;heure</h6>
                <p class="small text-muted mb-3">&Agrave; utiliser seulement pour corriger une erreur ou apr&egrave;s accord avec les personnes concern&eacute;es.</p>
                <form method="post" action="{{ path('admin_trajet_horaire', { id: trajet.id }) }}" class="row g-2 align-items-end">
                  <input type="hidden" name="_token" value="{{ csrf_token('admin_trajet_horaire_' ~ trajet.id) }}">
                  <div class="col-md-4">
                    <label for="trajet-date-{{ trajet.id }}" class="form-label small text-muted">Date</label>
                    <input type="date" id="trajet-date-{{ trajet.id }}" name="date_trajet" class="form-control" value="{{ trajet.dateTrajet|date('Y-m-d') }}" required>
                  </div>
                  <div class="col-md-3">
                    <label for="trajet-heure-{{ trajet.id }}" class="form-label small text-muted">Heure</label>
                    <input type="time" id="trajet-heure-{{ trajet.id }}" name="heure_trajet" class="form-control" value="{{ trajet.heureTrajet|date('H:i') }}" required>
                  </div>
                  <div class="col-md-5">
                    <button type="submit" class="btn btn-primary w-100" onclick="return confirm('Modifier la date et l'heure de ce trajet ? Les personnes concernees recevront une notification.')">
                      <i class="bi bi-calendar-check"></i>
                      Enregistrer l&rsquo;horaire
                    </button>
                  </div>
                </form>
              </div>

              <div class="border rounded p-3 mb-4">
                <h6>Que faire pour ce trajet ?</h6>
                <p class="small text-muted mb-3">
                  Choisissez seulement si vous avez vérifié le dossier. En cas de problème, bloquez le versement avec un litige.
                </p>
                <form method="post" action="{{ path('admin_trajet_suivi', { id: trajet.id, statut: 'valide' }) }}" class="d-inline-flex flex-wrap gap-2 mb-2">
                  <input type="hidden" name="_token" value="{{ csrf_token('admin_trajet_suivi_' ~ trajet.id) }}">
                  <input type="hidden" name="note" value="Trajet validé depuis la page admin.">
                  <button class="btn btn-sm btn-success" title="Le trajet s’est bien passé : le versement conducteur pourra être traité." onclick="return confirm('Confirmer que le trajet s’est bien passé ?')">
                    Trajet OK
                  </button>
                </form>
                <form method="post" action="{{ path('admin_trajet_suivi', { id: trajet.id, statut: 'litige' }) }}" class="d-inline-flex flex-wrap gap-2 mb-2">
                  <input type="hidden" name="_token" value="{{ csrf_token('admin_trajet_suivi_' ~ trajet.id) }}">
                  <input type="hidden" name="note" value="Litige ouvert depuis la page admin.">
                  <button class="btn btn-sm btn-outline-danger" title="Il y a un problème à vérifier : le versement conducteur est bloqué." onclick="return confirm('Ouvrir un litige et bloquer le versement conducteur ?')">
                    Problème à vérifier
                  </button>
                </form>
                <form method="post" action="{{ path('admin_trajet_suivi', { id: trajet.id, statut: 'auto' }) }}" class="d-inline-flex flex-wrap gap-2 mb-2">
                  <input type="hidden" name="_token" value="{{ csrf_token('admin_trajet_suivi_' ~ trajet.id) }}">
                  <input type="hidden" name="note" value="Retour au suivi automatique.">
                  <button class="btn btn-sm btn-outline-secondary" title="Annule votre décision manuelle : HaloGari se base à nouveau sur l’heure du trajet.">
                    Laisser HaloGari décider
                  </button>
                </form>
                {% if trajet.statusNote %}
                  <div class="small text-muted mt-2">{{ trajet.statusNote }}</div>
                {% endif %}
              </div>

              <h6>Passagers et demandes</h6>
              <div class="table-responsive mb-4">
                <table class="table table-sm table-bordered align-middle">
                  <thead class="table-light">
                    <tr>
                      <th>Réservation</th>
                      <th>Passager</th>
                      <th>Places</th>
                      <th>Total</th>
                      <th>Statut</th>
                      <th>Paiement</th>
                      <th>Contact</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for reservation in trajet.reservations %}
                      {% set reservationLabel = reservation.statut == 'annulee' and reservation.cancellationLabel ? reservation.cancellationLabel : reservationLabels[reservation.statut]|default(reservation.statut) %}
                      <tr>
                        <td>#{{ reservation.id }}</td>
                        <td>
                          {% if reservation.passager %}
                            <div class="d-flex align-items-center gap-2">
                              {{ avatar.formatSimple(reservation.passager, 38, 0, 1) }}
                              <div class="min-w-0">
                                <a href="{{ path('admin_user_show', { id: reservation.passager.id }) }}">{{ reservation.passager.prenom }} {{ reservation.passager.nom }}</a>
                                {% if reservation.passager.isProfilVerifieComplet %}
                                  <div><span class="badge bg-success-subtle text-success border border-success-subtle">Profil vérifié</span></div>
                                {% endif %}
                              </div>
                            </div>
                          {% else %}
                            <span class="text-muted">-</span>
                          {% endif %}
                        </td>
                        <td>{{ reservation.places }}</td>
                        <td>{{ reservation.prixTotal|number_format(2, ',', ' ') }} €</td>
                        <td>
                          <span class="badge bg-{{ reservationClasses[reservation.statut]|default('secondary') }}">{{ reservationLabel }}</span>
                          {% if reservation.canceledAt %}
                            <div class="small text-muted">{{ reservation.canceledAt|date('d/m/Y à H:i') }}</div>
                          {% endif %}
                        </td>
                        <td>
                          {% if reservation.paiement %}
                            <span class="badge bg-light text-dark border">{{ reservation.paiement.statutLabel }}</span>
                          {% else %}
                            <span class="text-muted">Aucun</span>
                          {% endif %}
                        </td>
                        <td>
                          {% if reservation.passager %}
                            <span class="small">{{ reservation.passager.telephone ?: reservation.passager.email }}</span>
                          {% else %}
                            <span class="text-muted">-</span>
                          {% endif %}
                        </td>
                      </tr>
                    {% else %}
                      <tr>
                        <td colspan="7" class="text-center text-muted">Aucun passager sur ce trajet.</td>
                      </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>

              <h6>Description</h6>
              <p class="mb-0">{{ trajet.description ?: 'Aucune description.' }}</p>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Fermer</button>
            </div>
          </div>
        </div>
      </div>
    {% endfor %}
  </div>
{% endblock %}
