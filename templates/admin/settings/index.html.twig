{% extends 'base_admin.html.twig' %}

{% block title %}Paramètres | Admin{% endblock %}

{% block body %}
  <div class="container-fluid p-0">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
      <div>
        <h1 class="h3 mb-1">Paramètres</h1>
        <p class="text-muted mb-0">Réglages sensibles de la plateforme. À modifier seulement quand c’est nécessaire.</p>
      </div>
      <a href="{{ path('admin_help') }}" class="btn btn-outline-secondary btn-sm">Aide admin</a>
    </div>

    <div class="alert alert-light border mb-4">
      <strong>Repère rapide :</strong> Stripe sert aux paiements, Facebook aux publications automatiques, Production à la préparation du passage en ligne, et Sauvegarde aux commandes de secours.
    </div>

    <div class="nav nav-pills flex-column flex-md-row gap-2 mb-4">
      <a class="nav-link active" href="#settings-stripe">Stripe</a>
      <a class="nav-link" href="#settings-facebook">Facebook</a>
      <a class="nav-link" href="#settings-sms">SMS</a>
      <a class="nav-link" href="#settings-production">Production</a>
      <a class="nav-link" href="#settings-backup">Sauvegarde</a>
      <a class="nav-link" href="#settings-checks">Contrôles</a>
    </div>

    <div class="row g-4">
      <div class="col-12 col-xl-8">
        <div class="card mb-4" id="settings-stripe">
          <div class="card-header">
            <h2 class="h5 mb-1">Paiements Stripe</h2>
            <p class="text-muted mb-0">Clés utilisées pour encaisser, autoriser les paiements et recevoir les webhooks. Les secrets complets ne sont jamais affichés.</p>
          </div>
          <div class="card-body">
            <form method="post">
              <input type="hidden" name="settings_section" value="stripe">
              <input type="hidden" name="_token" value="{{ csrf_token('admin_settings_stripe') }}">

              <div class="alert alert-{{ stripeMode == 'Mode live' ? 'success' : 'warning' }} mb-3">
                Mode détecté : <strong>{{ stripeMode }}</strong>
              </div>

              <div class="mb-3">
                <label for="stripe_public_key" class="form-label">Clé publique Stripe</label>
                <input type="password" id="stripe_public_key" name="stripe_public_key" class="form-control" placeholder="{{ hasStripePublicKey ? 'Laisser vide pour conserver la clé actuelle' : 'pk_test_ ou pk_live_' }}" autocomplete="off">
                <div class="form-text">Clé actuelle : <strong>{{ stripePublicKeyMasked }}</strong></div>
              </div>

              <div class="mb-3">
                <label for="stripe_secret_key" class="form-label">Clé secrète Stripe</label>
                <input type="password" id="stripe_secret_key" name="stripe_secret_key" class="form-control" placeholder="{{ hasStripeSecretKey ? 'Laisser vide pour conserver la clé actuelle' : 'sk_test_ ou sk_live_' }}" autocomplete="off">
                <div class="form-text">Clé actuelle : <strong>{{ stripeSecretKeyMasked }}</strong></div>
              </div>

              <div class="mb-4">
                <label for="stripe_webhook_secret" class="form-label">Secret webhook Stripe</label>
                <input type="password" id="stripe_webhook_secret" name="stripe_webhook_secret" class="form-control" placeholder="{{ hasStripeWebhookSecret ? 'Laisser vide pour conserver le secret actuel' : 'whsec_...' }}" autocomplete="off">
                <div class="form-text">Secret actuel : <strong>{{ stripeWebhookSecretMasked }}</strong></div>
              </div>

              <button type="submit" class="btn btn-primary">Enregistrer Stripe</button>
            </form>
          </div>
        </div>

        <div class="card mb-4" id="settings-facebook">
          <div class="card-header">
            <h2 class="h5 mb-1">Publication Facebook</h2>
            <p class="text-muted mb-0">Ces informations servent à publier automatiquement les affiches de trajets sur la Page HaloGari.</p>
          </div>
          <div class="card-body">
            <form method="post">
              <input type="hidden" name="settings_section" value="facebook">
              <input type="hidden" name="_token" value="{{ csrf_token('admin_settings_facebook') }}">

              <div class="mb-3">
                <label for="facebook_page_id" class="form-label">ID de la Page Facebook</label>
                <input
                  type="text"
                  id="facebook_page_id"
                  name="facebook_page_id"
                  class="form-control"
                  value="{{ facebookPageId }}"
                  placeholder="1202754536249735"
                  required
                >
              </div>

              <div class="mb-3">
                <label for="facebook_page_access_token" class="form-label">Token d'accès de la Page</label>
                <input
                  type="password"
                  id="facebook_page_access_token"
                  name="facebook_page_access_token"
                  class="form-control"
                  placeholder="{{ hasFacebookToken ? 'Laisser vide pour conserver le token actuel' : 'Coller le token de Page' }}"
                  autocomplete="off"
                >
                <div class="form-text">
                  Token actuel : <strong>{{ facebookTokenMasked }}</strong>. Le token complet n'est jamais affiché.
                </div>
              </div>

              <div class="form-check form-switch mb-4">
                <input
                  class="form-check-input"
                  type="checkbox"
                  role="switch"
                  id="facebook_auto_post"
                  name="facebook_auto_post"
                  value="1"
                  {% if facebookAutoPost %}checked{% endif %}
                >
                <label class="form-check-label" for="facebook_auto_post">Publier automatiquement les nouveaux trajets sur Facebook</label>
              </div>

              <div class="d-flex flex-wrap gap-2">
                <button type="submit" class="btn btn-primary">Enregistrer</button>
                <a href="https://www.facebook.com/profile.php?id={{ facebookPageId }}" target="_blank" rel="noopener" class="btn btn-outline-secondary">Ouvrir la Page</a>
              </div>
            </form>
          </div>
        </div>

        <div class="card" id="settings-sms">
          <div class="card-header">
            <h2 class="h5 mb-1">SMS automatiques</h2>
            <p class="text-muted mb-0">Envoi automatique au passager quand le conducteur accepte, refuse ou annule un trajet.</p>
          </div>
          <div class="card-body">
            <form method="post">
              <input type="hidden" name="settings_section" value="sms">
              <input type="hidden" name="_token" value="{{ csrf_token('admin_settings_sms') }}">

              <div class="form-check form-switch mb-3">
                <input class="form-check-input" type="checkbox" role="switch" id="sms_enabled" name="sms_enabled" value="1" {% if smsEnabled %}checked{% endif %}>
                <label class="form-check-label" for="sms_enabled">Activer les SMS automatiques</label>
              </div>

              <div class="alert alert-info small">
                <strong>Les SMS partent uniquement pour :</strong>
                rÃ©servation acceptÃ©e, rÃ©servation refusÃ©e, trajet annulÃ© par le conducteur,
                rÃ©servation annulÃ©e par le passager et horaire modifiÃ© par l'admin.
              </div>

              <div class="row g-3">
                <div class="col-12 col-md-6">
                  <label for="sms_provider" class="form-label">Fournisseur</label>
                  <select id="sms_provider" name="sms_provider" class="form-select">
                    <option value="ovh" {% if smsProvider == 'ovh' %}selected{% endif %}>OVHcloud SMS</option>
                  </select>
                  <div class="form-text">OVH est recommandé puisque vous avez déjà un pack de 100 SMS.</div>
                </div>
                <div class="col-12 col-md-6">
                  <label for="sms_from" class="form-label">Numéro expéditeur</label>
                  <input type="text" id="sms_from" name="sms_from" class="form-control" value="{{ smsFrom }}" placeholder="Ex : HaloGari ou numéro expéditeur OVH">
                  <div class="form-text">Avec OVH, laissez vide si l'expéditeur personnalisé n'est pas encore validé. HaloGari réessaiera sans expéditeur personnalisé si OVH le refuse.</div>
                </div>
              </div>

              <div class="border rounded p-3 mt-3">
                <h3 class="h6 mb-3">OVHcloud SMS</h3>
                <div class="row g-3">
                  <div class="col-12 col-md-6">
                    <label for="sms_ovh_service_name" class="form-label">Service SMS OVH</label>
                    <input type="text" id="sms_ovh_service_name" name="sms_ovh_service_name" class="form-control" value="{{ smsOvhServiceName }}" placeholder="Ex : sms-xx0000-1">
                  </div>
                  <div class="col-12 col-md-6">
                    <label for="sms_ovh_application_key" class="form-label">Application key</label>
                    <input type="password" id="sms_ovh_application_key" name="sms_ovh_application_key" class="form-control" placeholder="{{ hasSmsOvhApplicationKey ? 'Laisser vide pour conserver la clé actuelle' : 'Application key OVH' }}" autocomplete="off">
                    <div class="form-text">Clé actuelle : <strong>{{ smsOvhApplicationKeyMasked }}</strong></div>
                  </div>
                  <div class="col-12 col-md-6">
                    <label for="sms_ovh_application_secret" class="form-label">Application secret</label>
                    <input type="password" id="sms_ovh_application_secret" name="sms_ovh_application_secret" class="form-control" placeholder="{{ hasSmsOvhApplicationSecret ? 'Laisser vide pour conserver le secret actuel' : 'Application secret OVH' }}" autocomplete="off">
                    <div class="form-text">Secret actuel : <strong>{{ smsOvhApplicationSecretMasked }}</strong></div>
                  </div>
                  <div class="col-12 col-md-6">
                    <label for="sms_ovh_consumer_key" class="form-label">Consumer key</label>
                    <input type="password" id="sms_ovh_consumer_key" name="sms_ovh_consumer_key" class="form-control" placeholder="{{ hasSmsOvhConsumerKey ? 'Laisser vide pour conserver la clé actuelle' : 'Consumer key OVH' }}" autocomplete="off">
                    <div class="form-text">Clé actuelle : <strong>{{ smsOvhConsumerKeyMasked }}</strong></div>
                  </div>
                </div>
              </div>

              <details class="mt-3 d-none">
                <summary class="fw-bold">Paramètres Twilio en secours</summary>
                <div class="row g-3 mt-1">
                <div class="col-12 col-md-6">
                  <label for="sms_twilio_account_sid" class="form-label">Account SID</label>
                  <input type="password" id="sms_twilio_account_sid" name="sms_twilio_account_sid" class="form-control" placeholder="{{ hasSmsAccountSid ? 'Laisser vide pour conserver le SID actuel' : 'AC...' }}" autocomplete="off">
                  <div class="form-text">SID actuel : <strong>{{ smsAccountSidMasked }}</strong></div>
                </div>
                <div class="col-12 col-md-6">
                  <label for="sms_twilio_auth_token" class="form-label">Auth token</label>
                  <input type="password" id="sms_twilio_auth_token" name="sms_twilio_auth_token" class="form-control" placeholder="{{ hasSmsAuthToken ? 'Laisser vide pour conserver le token actuel' : 'Token Twilio' }}" autocomplete="off">
                  <div class="form-text">Token actuel : <strong>{{ smsAuthTokenMasked }}</strong></div>
                </div>
              </div>
              </details>

              <button type="submit" class="btn btn-primary mt-4">Enregistrer SMS</button>
            </form>

            <div class="border rounded p-3 mt-4 bg-light">
              <h3 class="h6 mb-2">Tester l'envoi</h3>
              <p class="small text-muted mb-3">Envoyez un SMS réel pour voir si OVH accepte la configuration actuelle.</p>
              <form method="post" class="row g-2 align-items-end">
                <input type="hidden" name="settings_section" value="sms_test">
                <input type="hidden" name="_token" value="{{ csrf_token('admin_settings_sms_test') }}">
                <div class="col-12 col-md">
                  <label for="sms_test_phone" class="form-label">Numéro de test</label>
                  <input type="tel" id="sms_test_phone" name="sms_test_phone" class="form-control" placeholder="Ex : 0639..." required>
                </div>
                <div class="col-12 col-md-auto">
                  <button type="submit" class="btn btn-outline-primary w-100">
                    <i class="bi bi-send-fill"></i>
                    Envoyer un test
                  </button>
                </div>
              </form>
            </div>

            <hr>

            <h3 class="h6 mb-3">Derniers SMS</h3>
            <div class="table-responsive">
              <table class="table table-sm align-middle mb-0">
                <thead>
                  <tr>
                    <th>Date</th>
                    <th>Passager</th>
                    <th>Événement</th>
                    <th>Statut</th>
                  </tr>
                </thead>
                <tbody>
                  {% for sms in smsLogs %}
                    <tr>
                      <td class="small">{{ sms.createdAt|date('d/m/Y H:i') }}</td>
                      <td>
                        <div>{{ sms.user ? sms.user.prenom : 'Utilisateur supprimé' }}</div>
                        <div class="small text-muted">{{ sms.phone }}</div>
                      </td>
                      <td class="small">{{ sms.eventType|replace({'reservation_': '', '_': ' '}) }}</td>
                      <td>
                        <span class="badge {{ sms.status == 'sent' ? 'bg-success' : (sms.status == 'failed' ? 'bg-danger' : 'bg-secondary') }}">
                          {{ sms.status == 'sent' ? 'Envoyé' : (sms.status == 'failed' ? 'Échec' : 'Ignoré') }}
                        </span>
                        {% if sms.error %}
                          <div class="small text-muted text-truncate" style="max-width: 220px;">{{ sms.error }}</div>
                        {% endif %}
                      </td>
                    </tr>
                  {% else %}
                    <tr>
                      <td colspan="4" class="text-muted small">Aucun SMS enregistré pour le moment.</td>
                    </tr>
                  {% endfor %}
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

      <div class="col-12 col-xl-4">
        <div class="card mb-4" id="settings-production">
          <div class="card-header">
            <h2 class="h5 mb-1">Préparation production</h2>
            <p class="text-muted mb-0">URL publique, e-mail support et validation manuelle avant mise en ligne.</p>
          </div>
          <div class="card-body">
            <form method="post" class="mb-4">
              <input type="hidden" name="settings_section" value="production">
              <input type="hidden" name="_token" value="{{ csrf_token('admin_settings_production') }}">

              <div class="mb-3">
                <label for="production_public_url" class="form-label">URL publique</label>
                <input type="url" id="production_public_url" name="production_public_url" class="form-control" value="{{ productionPublicUrl }}">
              </div>

              <div class="mb-3">
                <label for="production_support_email" class="form-label">E-mail support</label>
                <input type="email" id="production_support_email" name="production_support_email" class="form-control" value="{{ productionSupportEmail }}">
              </div>

              <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="mark_database_backup" name="mark_database_backup" value="1">
                <label class="form-check-label" for="mark_database_backup">J’ai fait une sauvegarde BDD et fichiers</label>
              </div>

              <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" id="confirm_prelaunch" name="confirm_prelaunch" value="1">
                <label class="form-check-label" for="confirm_prelaunch">Checklist production relue</label>
              </div>

              <button type="submit" class="btn btn-outline-primary w-100">Enregistrer production</button>
            </form>

            <p class="small text-muted mb-1">Dernière sauvegarde déclarée : <strong>{{ databaseBackupLastAt ?: 'Jamais' }}</strong></p>
            <p class="small text-muted mb-0">Dernière validation : <strong>{{ prelaunchConfirmedAt ?: 'Jamais' }}</strong></p>
          </div>
        </div>

        <div class="card mb-4" id="settings-checks">
          <div class="card-header">
            <h2 class="h5 mb-0">État production</h2>
          </div>
          <div class="card-body">
            <div class="list-group list-group-flush">
              {% for check in productionChecks %}
                <div class="list-group-item px-0">
                  <div class="d-flex justify-content-between gap-2">
                    <strong>{{ check.label }}</strong>
                    <span class="badge {{ check.ok ? 'bg-success' : 'bg-warning text-dark' }}">{{ check.ok ? 'OK' : 'À vérifier' }}</span>
                  </div>
                  <div class="small text-muted">{{ check.value }}</div>
                  {% if not check.ok %}
                    <div class="small text-danger">{{ check.help }}</div>
                  {% endif %}
                </div>
              {% endfor %}
            </div>
          </div>
        </div>

        <div class="card mb-4" id="settings-backup">
          <div class="card-header">
            <h2 class="h5 mb-0">Sauvegarde</h2>
          </div>
          <div class="card-body">
            <p class="text-muted">Commandes repères à adapter sur le serveur avant production.</p>
            {% for label, command in backupCommands %}
              <label class="form-label small text-muted">{{ label }}</label>
              <pre class="bg-light border rounded p-2 small"><code>{{ command }}</code></pre>
            {% endfor %}
          </div>
        </div>

        <div class="card">
          <div class="card-header">
            <h2 class="h5 mb-0">À garder en tête</h2>
          </div>
          <div class="card-body text-muted">
            <p>Collez uniquement un token de Page Facebook, pas un token utilisateur.</p>
            <p>Si Facebook refuse une publication, régénérez un token avec <code>pages_read_engagement</code> et <code>pages_manage_posts</code>.</p>
            <p class="mb-0">Commencez avec la publication automatique désactivée tant que les tests ne sont pas terminés.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
{% endblock %}
