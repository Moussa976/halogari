{% extends 'base_admin.html.twig' %}

{% block title %}Statistiques visiteurs | Admin{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
{% endblock %}

{% block body %}
  <div class="container-fluid px-1">
    <div class="d-flex flex-column flex-xl-row justify-content-between gap-3 mb-4">
      <div>
        <h1 class="h3 mb-1">Statistiques visiteurs</h1>
        <p class="text-muted mb-0">Suivi léger des machines anonymes qui consultent le site public HaloGari.</p>
      </div>
      <a href="{{ path('admin_dashboard') }}" class="btn btn-outline-primary btn-sm align-self-xl-start">
        Retour au tableau de bord
      </a>
    </div>

    <div class="alert alert-info small">
      Les statistiques excluent les admins, les superadmins, les pages d'administration et les appels API.
      Un cookie technique anonyme permet d'éviter de recompter la même machine plusieurs fois dans la même journée.
    </div>

    <div class="row g-3 mb-4">
      <div class="col-sm-6 col-xl-3">
        <div class="card h-100">
          <div class="card-body">
            <div class="text-muted small">Visiteurs aujourd'hui</div>
            <h2 class="mb-1">{{ todayStat ? todayStat.uniqueVisitors : 0 }}</h2>
            <div class="small text-muted">Machines uniques</div>
          </div>
        </div>
      </div>
      <div class="col-sm-6 col-xl-3">
        <div class="card h-100">
          <div class="card-body">
            <div class="text-muted small">Pages vues aujourd'hui</div>
            <h2 class="mb-1">{{ todayStat ? todayStat.pageViews : 0 }}</h2>
            <div class="small text-muted">Consultations publiques</div>
          </div>
        </div>
      </div>
      <div class="col-sm-6 col-xl-3">
        <div class="card h-100">
          <div class="card-body">
            <div class="text-muted small">Visiteurs depuis toujours</div>
            <h2 class="mb-1">{{ totalVisitors }}</h2>
            <div class="small text-muted">Machines anonymes connues</div>
          </div>
        </div>
      </div>
      <div class="col-sm-6 col-xl-3">
        <div class="card h-100">
          <div class="card-body">
            <div class="text-muted small">Pages vues depuis toujours</div>
            <h2 class="mb-1">{{ totalPageViews }}</h2>
            <div class="small text-muted">Total cumulé</div>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-3">
      <div class="col-xl-8">
        <div class="card h-100">
          <div class="card-header d-flex justify-content-between align-items-center">
            <span>Évolution des visites</span>
            <span class="text-muted small">30 derniers jours</span>
          </div>
          <div class="card-body">
            <div class="admin-dashboard-chart">
              <canvas id="visitorStatsChart"></canvas>
            </div>
          </div>
        </div>
      </div>

      <div class="col-xl-4">
        <div class="card h-100">
          <div class="card-header">Détail par jour</div>
          <div class="card-body table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th>Date</th>
                  <th>Visiteurs</th>
                  <th>Pages vues</th>
                </tr>
              </thead>
              <tbody>
                {% for stat in lastDays %}
                  <tr>
                    <td>{{ stat.visitedOn|date('d/m/Y') }}</td>
                    <td>{{ stat.uniqueVisitors }}</td>
                    <td>{{ stat.pageViews }}</td>
                  </tr>
                {% else %}
                  <tr>
                    <td colspan="3" class="text-muted">Aucune visite publique enregistrée pour le moment.</td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const canvas = document.getElementById('visitorStatsChart');
      if (!canvas || typeof Chart === 'undefined') {
        return;
      }

      new Chart(canvas, {
        type: 'line',
        data: {
          labels: {{ chartLabels|json_encode|raw }},
          datasets: [
            {
              label: 'Visiteurs uniques',
              data: {{ chartUniqueVisitors|json_encode|raw }},
              borderColor: '#1f7a3f',
              backgroundColor: 'rgba(31, 122, 63, 0.12)',
              tension: 0.35,
              fill: true
            },
            {
              label: 'Pages vues',
              data: {{ chartPageViews|json_encode|raw }},
              borderColor: '#ff8800',
              backgroundColor: 'rgba(255, 136, 0, 0.10)',
              tension: 0.35,
              fill: true
            }
          ]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { position: 'bottom' }
          },
          scales: {
            y: {
              beginAtZero: true,
              ticks: { precision: 0 }
            }
          }
        }
      });
    });
  </script>
{% endblock %}
