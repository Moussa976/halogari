{% extends 'base_admin.html.twig' %}

{% block title %}Réservations | Admin{% endblock %}

{% block body %}
  {% set labels = {
    'en_attente': 'En attente',
    'acceptee': 'Acceptée',
    'refusee': 'Refusée',
    'payee': 'Payée',
    'annulee': 'Annulée'
  } %}
  {% set classes = {
    'en_attente': 'warning text-dark',
    'acceptee': 'success',
    'refusee': 'danger',
    'payee': 'primary',
    'annulee': 'secondary'
  } %}

  <div class="container-fluid px-1">
    <div class="d-flex flex-column flex-md-row justify-content-between gap-3 mb-4">
      <div>
        <h1 class="h3 mb-1">Réservations</h1>
        <p class="text-muted mb-0">Demandes passagers, paiements associés et état des places.</p>
      </div>
      <span class="badge bg-primary align-self-start">{{ reservations|length }} réservation{{ reservations|length > 1 ? 's' : '' }}</span>
    </div>

    <div class="card">
      <div class="card-body table-responsive">
        <table class="table table-hover align-middle">
          <thead class="table-light">
            <tr>
              <th>ID</th>
              <th>Passager</th>
              <th>Trajet</th>
              <th>Places</th>
              <th>Total</th>
              <th>Statut</th>
              <th>Paiement</th>
              <th>Date</th>
            </tr>
          </thead>
          <tbody>
            {% for reservation in reservations %}
              <tr>
                <td>#{{ reservation.id }}</td>
                <td>
                  {% if reservation.passager %}
                    <a href="{{ path('admin_user_show', { id: reservation.passager.id }) }}">
                      {{ reservation.passager.prenom }} {{ reservation.passager.nom }}
                    </a>
                  {% else %}
                    <span class="text-muted">-</span>
                  {% endif %}
                </td>
                <td>
                  {% if reservation.trajet %}
                    {{ reservation.trajet.depart }} → {{ reservation.trajet.arrivee }}
                    <div class="small text-muted">{{ reservation.trajet.dateTrajet|date('d/m/Y') }} à {{ reservation.trajet.heureTrajet|date('H:i') }}</div>
                  {% else %}
                    <span class="text-muted">Trajet supprimé</span>
                  {% endif %}
                </td>
                <td>{{ reservation.places }}</td>
                <td>{{ reservation.prixTotal|number_format(2, ',', ' ') }} €</td>
                <td><span class="badge bg-{{ classes[reservation.statut]|default('secondary') }}">{{ labels[reservation.statut]|default(reservation.statut) }}</span></td>
                <td>
                  {% if reservation.paiement %}
                    <a href="{{ path('admin_paiements') }}">#{{ reservation.paiement.id }}</a>
                    <span class="badge bg-light text-dark border">{{ reservation.paiement.statut }}</span>
                  {% else %}
                    <span class="text-muted">Aucun</span>
                  {% endif %}
                </td>
                <td>{{ reservation.createdAt|date('d/m/Y H:i') }}</td>
              </tr>
            {% else %}
              <tr>
                <td colspan="8" class="text-center text-muted">Aucune réservation.</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  </div>
{% endblock %}
