{% extends 'base_admin.html.twig' %}
{% import 'partials/avatar.html.twig' as avatar %}

{% block title %}Documents | Admin{% endblock %}

{% block body %}
  {% set labels = {
    'pending': 'En attente',
    'approved': 'Validé',
    'rejected': 'Refusé'
  } %}
  {% set classes = {
    'pending': 'warning text-dark',
    'approved': 'success',
    'rejected': 'danger'
  } %}

  <div class="container-fluid px-1">
    <div class="d-flex flex-column flex-md-row justify-content-between gap-3 mb-4">
      <div>
        <h1 class="h3 mb-1">Documents</h1>
        <p class="text-muted mb-0">Ouvrez les pièces dans une fenêtre admin, vérifiez, puis validez ou refusez.</p>
      </div>
      <span class="badge bg-primary align-self-start">{{ documents|length }} document{{ documents|length > 1 ? 's' : '' }}</span>
    </div>

    <div class="card">
      <div class="card-body table-responsive">
        <table class="table table-hover align-middle js-admin-table">
          <thead class="table-light">
            <tr>
              <th>ID</th>
              <th>Utilisateur</th>
              <th>Type</th>
              <th>Fichier</th>
              <th>Statut</th>
              <th>Date</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            {% for document in documents %}
              <tr>
                <td>#{{ document.id }}</td>
                <td>
                  {% if document.user %}
                    <div class="d-flex align-items-center gap-2">
                      {{ avatar.formatSimple(document.user, 42, 0, 1) }}
                      <div class="min-w-0">
                        <a href="{{ path('admin_user_show', { id: document.user.id }) }}">{{ document.user.prenom }} {{ document.user.nom }}</a>
                        {% if document.user.isProfilVerifieComplet %}
                          <span class="badge bg-success-subtle text-success border border-success-subtle ms-1">Profil vérifié</span>
                        {% endif %}
                        <div class="small text-muted text-truncate" style="max-width: 220px;">{{ document.user.email }}</div>
                      </div>
                    </div>
                  {% else %}
                    <span class="text-muted">-</span>
                  {% endif %}
                </td>
                <td>{{ document.typeDocument|replace({'_': ' ', '-': ' '})|title }}</td>
                <td class="text-truncate" style="max-width: 220px;">{{ document.filenameDocument }}</td>
                <td><span class="badge bg-{{ classes[document.status]|default('secondary') }}">{{ labels[document.status]|default(document.status) }}</span></td>
                <td>{{ document.dateDocument|date('d/m/Y H:i') }}</td>
                <td>
                  <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#document-modal-{{ document.id }}">
                    Ouvrir
                  </button>
                </td>
              </tr>
            {% else %}
              <tr>
                <td colspan="7" class="text-center text-muted">Aucun document.</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>

    {% for document in documents %}
      {% set fileUrl = path('admin_document_file', { id: document.id }) %}
      {% set ext = document.filenameDocument|split('.')|last|lower %}
      <div class="modal fade" id="document-modal-{{ document.id }}" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
          <div class="modal-content">
            <div class="modal-header">
              <div>
                <h5 class="modal-title">Document #{{ document.id }} - {{ document.typeDocument|replace({'_': ' ', '-': ' '})|title }}</h5>
                <div class="text-muted small">{{ document.filenameDocument }}</div>
              </div>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
            </div>
            <div class="modal-body">
              <div class="row g-3 mb-3">
                <div class="col-md-4">
                  <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Utilisateur</div>
                    {% if document.user %}
                      <div class="d-flex align-items-center gap-2 mb-2">
                        {{ avatar.formatSimple(document.user, 48, 0, 1) }}
                        <a class="fw-bold" href="{{ path('admin_user_show', { id: document.user.id }) }}">{{ document.user.prenom }} {{ document.user.nom }}</a>
                      </div>
                      <div class="small">{{ document.user.email }}</div>
                      <div class="small">{{ document.user.telephone ?: '-' }}</div>
                    {% else %}
                      <strong>-</strong>
                    {% endif %}
                  </div>
                </div>
                <div class="col-md-4">
                  <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Statut</div>
                    <span class="badge bg-{{ classes[document.status]|default('secondary') }}">{{ labels[document.status]|default(document.status) }}</span>
                    {% if document.rejectionReason %}
                      <div class="small text-danger mt-2">{{ document.rejectionReason }}</div>
                    {% endif %}
                  </div>
                </div>
                <div class="col-md-4">
                  <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Date d'envoi</div>
                    <strong>{{ document.dateDocument|date('d/m/Y H:i') }}</strong>
                  </div>
                </div>
              </div>

              {% if ext in ['jpg', 'jpeg', 'png', 'webp'] %}
                <img src="{{ fileUrl }}" alt="Document #{{ document.id }}" class="img-fluid rounded border w-100" style="max-height: 72vh; object-fit: contain; background: #f8f9fa;">
              {% elseif ext == 'pdf' %}
                <iframe src="{{ fileUrl }}" class="w-100 border rounded" style="min-height: 70vh;"></iframe>
              {% else %}
                <div class="alert alert-info">
                  Aperçu non disponible pour ce format.
                  <a href="{{ fileUrl }}" target="_blank" rel="noopener">Ouvrir le fichier</a>
                </div>
              {% endif %}
            </div>
            <div class="modal-footer justify-content-between">
              <a href="{{ fileUrl }}" target="_blank" rel="noopener" class="btn btn-outline-primary">Ouvrir dans un onglet</a>
              <div class="d-flex flex-wrap gap-2">
                {% if document.status != 'approved' %}
                  <form method="post" action="{{ path('admin_document_validate', { id: document.id }) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('admin_document_validate_' ~ document.id) }}">
                    <input type="hidden" name="_return_to" value="documents">
                    <button class="btn btn-success" onclick="return confirm('Valider ce document ?')">Valider</button>
                  </form>
                {% endif %}
                {% if document.status != 'rejected' %}
                  <form method="post" action="{{ path('admin_document_reject', { id: document.id }) }}" class="d-flex flex-wrap gap-2">
                    <input type="hidden" name="_token" value="{{ csrf_token('admin_document_reject_' ~ document.id) }}">
                    <input type="hidden" name="_return_to" value="documents">
                    <input type="text" name="reason" class="form-control form-control-sm" placeholder="Motif du refus" required style="max-width: 220px;">
                    <button class="btn btn-danger" onclick="return confirm('Refuser ce document ?')">Refuser</button>
                  </form>
                {% endif %}
                {% if document.status != 'pending' %}
                  <form method="post" action="{{ path('admin_document_pending', { id: document.id }) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('admin_document_pending_' ~ document.id) }}">
                    <input type="hidden" name="_return_to" value="documents">
                    <button class="btn btn-outline-secondary" onclick="return confirm('Remettre ce document en attente ?')">Remettre en attente</button>
                  </form>
                {% endif %}
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Fermer</button>
              </div>
            </div>
          </div>
        </div>
      </div>
    {% endfor %}
  </div>
{% endblock %}
