{% extends 'base_admin.html.twig' %}
{% import 'partials/avatar.html.twig' as avatar %}

{% block title %}{{ mode == 'litiges' ? 'Litiges et remboursements' : 'Paiements' }} | Admin{% endblock %}

{% block body %}
  {% set statusClasses = {
    'en_attente': 'secondary',
    'autorise': 'warning text-dark',
    'capture': 'success',
    'rembourse_partiel': 'info text-dark',
    'rembourse': 'info text-dark',
    'echoue': 'danger',
    'annule': 'dark'
  } %}
  {% set pageTitle = mode == 'litiges' ? 'Litiges et remboursements' : 'Paiements' %}
  {% set pageHelp = mode == 'litiges'
    ? 'Suivi des remboursements, annulations et paiements à contrôler.'
    : 'Suivi des paiements enregistrés, confirmés et des versements conducteurs.'
  %}

  <div class="container-fluid px-1">
    <div class="d-flex flex-column flex-md-row justify-content-between gap-3 mb-4">
      <div>
        <h1 class="h3 mb-1">{{ pageTitle }}</h1>
        <p class="text-muted mb-0">{{ pageHelp }}</p>
      </div>
      <div class="d-flex flex-wrap gap-2 align-self-start">
        <a class="btn btn-sm {{ mode == 'paiements' ? 'btn-primary' : 'btn-outline-primary' }}" href="{{ path('admin_paiements') }}">Paiements</a>
        <a class="btn btn-sm {{ mode == 'litiges' ? 'btn-primary' : 'btn-outline-primary' }}" href="{{ path('admin_litiges_remboursements') }}">Litiges</a>
      </div>
    </div>

    <div class="card mb-3">
      <div class="card-body">
        <div class="d-flex flex-wrap gap-2 js-payment-filter">
          <button type="button" class="btn btn-sm btn-primary" data-filter="all">Tous</button>
          <button type="button" class="btn btn-sm btn-outline-secondary" data-filter="enregistre">Enregistrés</button>
          <button type="button" class="btn btn-sm btn-outline-secondary" data-filter="confirme">Confirmés</button>
          <button type="button" class="btn btn-sm btn-outline-secondary" data-filter="a-rembourser">À rembourser</button>
          <button type="button" class="btn btn-sm btn-outline-secondary" data-filter="a-controler">À contrôler</button>
          <button type="button" class="btn btn-sm btn-outline-secondary" data-filter="rembourse">Remboursés</button>
          <button type="button" class="btn btn-sm btn-outline-secondary" data-filter="a-verser">À verser</button>
          <button type="button" class="btn btn-sm btn-outline-secondary" data-filter="verse">Versés</button>
          <button type="button" class="btn btn-sm btn-outline-secondary" data-filter="erreur">Erreur Stripe</button>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-body table-responsive">
        <table class="table table-bordered table-hover align-middle js-admin-table">
          <thead class="table-light">
            <tr>
              <th>ID</th>
              <th>Montant</th>
              <th>Passager</th>
              <th>Trajet</th>
              <th>Statut</th>
              <th>Date</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            {% for paiement in paiements %}
              {% set reservation = paiement.reservation %}
              {% set trajet = reservation ? reservation.trajet : null %}
              {% set dejaVerse = reservation and reservation.commissions|length > 0 %}
              {% set statutTrajet = trajet ? trajet.statutOperationnel : 'inconnu' %}
              {% set remboursementPourcentage = 0 %}
              {% if reservation and trajet and reservation.statut == 'annulee' and paiement.statut == 'capture' and not dejaVerse %}
                {% if reservation.canceledBy == 'conducteur' %}
                  {% set remboursementPourcentage = 100 %}
                {% elseif reservation.canceledBy == 'passager' and reservation.canceledAt %}
                  {% set departTs = (trajet.dateTrajet|date('Y-m-d') ~ ' ' ~ trajet.heureTrajet|date('H:i:s'))|date('U') %}
                  {% set cancelTs = reservation.canceledAt|date('U') %}
                  {% set delaiAvantDepart = departTs - cancelTs %}
                  {% set remboursementPourcentage = delaiAvantDepart > 86400 ? 100 : (delaiAvantDepart > 10800 ? 50 : 0) %}
                {% endif %}
              {% endif %}
              {% set aRembourser = remboursementPourcentage > 0 %}
              {% set aControler = reservation and reservation.statut == 'annulee' and paiement.statut == 'capture' and not dejaVerse and remboursementPourcentage == 0 %}
              {% set aVerser = paiement.statut == 'capture' and not dejaVerse and trajet and trajet.pretPourVersement %}
              {% set rowFilters = [
                paiement.statut == 'autorise' ? 'enregistre' : '',
                paiement.statut == 'capture' ? 'confirme' : '',
                aRembourser ? 'a-rembourser' : '',
                aControler ? 'a-controler' : '',
                paiement.statut in ['rembourse', 'rembourse_partiel'] ? 'rembourse' : '',
                aVerser ? 'a-verser' : '',
                dejaVerse ? 'verse' : '',
                paiement.statut == 'echoue' ? 'erreur' : ''
              ]|join(' ') %}
              {% set showRow = mode == 'paiements' or aRembourser or paiement.statut in ['rembourse', 'rembourse_partiel', 'echoue'] or statutTrajet == 'litige' %}
              {% if showRow %}
                <tr data-payment-filters="{{ rowFilters|trim ?: 'all' }}">
                  <td>#{{ paiement.id }}</td>
                  <td><strong>{{ paiement.montant|number_format(2, ',', ' ') }} €</strong></td>
                  <td>
                    {% if reservation and reservation.passager %}
                      <div class="d-flex align-items-center gap-2">
                        {{ avatar.formatSimple(reservation.passager, 38, 0, 1) }}
                        <div class="min-w-0">
                          <a href="{{ path('admin_user_show', { id: reservation.passager.id }) }}">{{ reservation.passager.prenom }} {{ reservation.passager.nom }}</a>
                          <div class="small text-muted text-truncate" style="max-width: 190px;">{{ reservation.passager.email }}</div>
                        </div>
                      </div>
                    {% else %}
                      <span class="text-muted">-</span>
                    {% endif %}
                  </td>
                  <td>
                    {% if trajet %}
                      {{ trajet.depart }} → {{ trajet.arrivee }}
                      <div class="small text-muted">{{ trajet.dateTrajet|date('d/m/Y') }} à {{ trajet.heureTrajet|date('H:i') }}</div>
                      {% if statutTrajet == 'litige' %}
                        <span class="badge bg-danger mt-1">Litige</span>
                      {% endif %}
                    {% else %}
                      <span class="text-muted">Réservation introuvable</span>
                    {% endif %}
                  </td>
                  <td>
                    <span class="badge bg-{{ statusClasses[paiement.statut]|default('secondary') }}">{{ paiement.statutLabel }}</span>
                    {% if aRembourser %}
                      <span class="badge bg-danger ms-1">à rembourser</span>
                    {% elseif aControler %}
                      <span class="badge bg-warning text-dark ms-1">à contrôler</span>
                    {% elseif dejaVerse %}
                      <span class="badge bg-success ms-1">versé</span>
                    {% elseif aVerser %}
                      <span class="badge bg-primary ms-1">à verser</span>
                    {% endif %}
                  </td>
                  <td>{{ paiement.createdAt|date('d/m/Y H:i') }}</td>
                  <td>
                    <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#paiement-modal-{{ paiement.id }}">
                      Gérer
                    </button>
                  </td>
                </tr>
              {% endif %}
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>

    {% for paiement in paiements %}
      {% set reservation = paiement.reservation %}
      {% set trajet = reservation ? reservation.trajet : null %}
      {% set dejaVerse = reservation and reservation.commissions|length > 0 %}
      {% set commissionVersement = dejaVerse ? reservation.commissions[0] : null %}
      {% set trajetTermine = trajet and trajet.pretPourVersement %}
      {% set montantRestant = paiement.montantDisponible %}
      {% set repartitionBase = commissionVersement ? commissionVersement.montantBrut : montantRestant %}
      {% set repartitionCommission = commissionVersement ? commissionVersement.commissionHaloGari : (montantRestant > 0 ? max((montantRestant * 0.12)|round(2, 'common'), 0.50) : 0) %}
      {% set repartitionFraisStripe = commissionVersement ? commissionVersement.fraisStripe : (montantRestant > 0 ? ((paiement.montant * 0.015) + 0.25)|round(2, 'common') : 0) %}
      {% set repartitionConducteur = commissionVersement ? commissionVersement.montantConducteur : max(montantRestant - repartitionCommission - repartitionFraisStripe, 0) %}
      {% set remboursementPourcentage = null %}
      {% set remboursementMessage = null %}
      {% if reservation and trajet and reservation.statut == 'annulee' and paiement.statut == 'capture' and not dejaVerse %}
        {% if reservation.canceledBy == 'conducteur' %}
          {% set remboursementPourcentage = 100 %}
          {% set remboursementMessage = 'Annulation conducteur : remboursement total prévu.' %}
        {% elseif reservation.canceledBy == 'passager' and reservation.canceledAt %}
          {% set departTs = (trajet.dateTrajet|date('Y-m-d') ~ ' ' ~ trajet.heureTrajet|date('H:i:s'))|date('U') %}
          {% set cancelTs = reservation.canceledAt|date('U') %}
          {% set delaiAvantDepart = departTs - cancelTs %}
          {% if delaiAvantDepart > 86400 %}
            {% set remboursementPourcentage = 100 %}
            {% set remboursementMessage = 'Annulation passager à plus de 24 h : remboursement total prévu.' %}
          {% elseif delaiAvantDepart > 10800 %}
            {% set remboursementPourcentage = 50 %}
            {% set remboursementMessage = 'Annulation passager entre 24 h et 3 h : remboursement partiel prévu.' %}
          {% else %}
            {% set remboursementPourcentage = 0 %}
            {% set remboursementMessage = 'Annulation passager à moins de 3 h : aucun remboursement automatique. À rembourser uniquement en geste exceptionnel ou après litige.' %}
          {% endif %}
        {% else %}
          {% set remboursementPourcentage = 0 %}
          {% set remboursementMessage = 'Annulation à contrôler : la règle automatique ne peut pas être déterminée.' %}
        {% endif %}
      {% endif %}
      <div class="modal fade" id="paiement-modal-{{ paiement.id }}" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
          <div class="modal-content">
            <div class="modal-header">
              <div>
                <h5 class="modal-title">Paiement #{{ paiement.id }}</h5>
                <div class="text-muted small">{{ paiement.createdAt|date('d/m/Y à H:i') }}</div>
              </div>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
            </div>
            <div class="modal-body">
              <div class="row g-3 mb-4">
                <div class="col-md-4">
                  <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Montant</div>
                    <strong>{{ paiement.montant|number_format(2, ',', ' ') }} €</strong>
                    {% if paiement.montantRembourseEffectif > 0 %}
                      <div class="small text-muted">Remboursé : {{ paiement.montantRembourseEffectif|number_format(2, ',', ' ') }} €</div>
                      <div class="small text-muted">Restant : {{ montantRestant|number_format(2, ',', ' ') }} €</div>
                    {% endif %}
                  </div>
                </div>
                <div class="col-md-4">
                  <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Statut</div>
                    <span class="badge bg-{{ statusClasses[paiement.statut]|default('secondary') }}">{{ paiement.statutLabel }}</span>
                  </div>
                </div>
                <div class="col-md-4">
                  <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Versement</div>
                    <strong>{{ dejaVerse ? 'Déjà versé' : (trajetTermine ? 'Disponible' : 'En attente') }}</strong>
                  </div>
                </div>
              </div>

              {% if reservation %}
                <div class="border rounded p-3 mb-3">
                  <h6>Réservation #{{ reservation.id }}</h6>
                  <div>{{ trajet ? trajet.depart ~ ' → ' ~ trajet.arrivee : 'Trajet introuvable' }}</div>
                  {% if trajet %}
                    <div class="small text-muted">{{ trajet.dateTrajet|date('d/m/Y') }} à {{ trajet.heureTrajet|date('H:i') }}</div>
                    <div class="small text-muted">Suivi : {{ trajet.statutOperationnel|replace({'_': ' '}) }}</div>
                  {% endif %}
                  {% if reservation.canceledAt %}
                    <div class="small text-danger mt-1">{{ reservation.cancellationLabel ?: 'Annulée' }} le {{ reservation.canceledAt|date('d/m/Y à H:i') }}</div>
                  {% endif %}
                </div>
              {% endif %}

              <div class="border rounded p-3 mb-3">
                <h6>{{ commissionVersement ? 'Répartition enregistrée' : 'Répartition prévue' }}</h6>
                <div class="row g-3">
                  <div class="col-md-3">
                    <div class="small text-muted">Base après remboursement</div>
                    <strong>{{ repartitionBase|number_format(2, ',', ' ') }} €</strong>
                  </div>
                  <div class="col-md-3">
                    <div class="small text-muted">Commission HaloGari</div>
                    <strong>{{ repartitionCommission|number_format(2, ',', ' ') }} €</strong>
                  </div>
                  <div class="col-md-3">
                    <div class="small text-muted">{{ commissionVersement ? 'Frais Stripe' : 'Frais estimés' }}</div>
                    <strong>{{ repartitionFraisStripe|number_format(2, ',', ' ') }} €</strong>
                  </div>
                  <div class="col-md-3">
                    <div class="small text-muted">Net conducteur</div>
                    <strong>{{ repartitionConducteur|number_format(2, ',', ' ') }} €</strong>
                  </div>
                </div>
              </div>

              {% if remboursementMessage %}
                <div class="alert {{ remboursementPourcentage > 0 ? 'alert-warning' : 'alert-light border' }} mb-3">
                  <div class="d-flex flex-column flex-md-row justify-content-between gap-2">
                    <div>
                      <strong>Décision remboursement</strong>
                      <div>{{ remboursementMessage }}</div>
                    </div>
                    <span class="badge {{ remboursementPourcentage > 0 ? 'bg-danger' : 'bg-secondary' }} align-self-start">
                      {{ remboursementPourcentage }} %
                    </span>
                  </div>
                </div>
              {% endif %}

              <div class="border rounded p-3">
                <h6>Historique</h6>
                {% if paiement.evenements|length > 0 %}
                  <ul class="list-unstyled mb-0">
                    {% for evenement in paiement.evenements|slice(0, 5) %}
                      <li class="mb-2">
                        <strong>{{ evenement.titre }}</strong>
                        <div class="small text-muted">{{ evenement.createdAt|date('d/m/Y à H:i') }}{% if evenement.acteur %} par {{ evenement.acteur.prenom }}{% endif %}</div>
                        {% if evenement.message %}<div class="small">{{ evenement.message }}</div>{% endif %}
                      </li>
                    {% endfor %}
                  </ul>
                {% else %}
                  <p class="text-muted mb-0">Aucun événement enregistré.</p>
                {% endif %}
              </div>

              {% if paiement.paymentIntentId %}
                <div class="small text-muted mt-3">Stripe PaymentIntent : {{ paiement.paymentIntentId }}</div>
              {% endif %}
            </div>
            <div class="modal-footer justify-content-between">
              <button type="button" class="btn btn-light" data-bs-dismiss="modal">Fermer</button>
              <div class="d-flex flex-wrap gap-2">
                {% if not reservation %}
                  <span class="text-muted">Aucune action disponible</span>
                {% elseif paiement.statut == 'autorise' %}
                  <form method="post" action="{{ path('admin_paiement_capture', {id: paiement.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('admin_paiement_capture_' ~ paiement.id) }}">
                    <input type="hidden" name="mode" value="{{ mode }}">
                    <button class="btn btn-success" onclick="return confirm('Confirmer ce paiement ?')">Confirmer</button>
                  </form>
                  <form method="post" action="{{ path('admin_paiement_cancel', {id: paiement.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('admin_paiement_cancel_' ~ paiement.id) }}">
                    <input type="hidden" name="mode" value="{{ mode }}">
                    <button class="btn btn-warning" onclick="return confirm('Annuler ce paiement ?')">Annuler</button>
                  </form>
                {% elseif paiement.statut == 'capture' %}
                  {% if not dejaVerse %}
                    {% if trajetTermine %}
                      <form method="post" action="{{ path('admin_paiement_transfer', {id: paiement.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('admin_paiement_transfer_' ~ paiement.id) }}">
                        <input type="hidden" name="mode" value="{{ mode }}">
                        <button class="btn btn-success" onclick="return confirm('Verser la part conducteur maintenant ?')">Verser conducteur</button>
                      </form>
                    {% else %}
                      <span class="text-muted small align-self-center">Versement bloqué jusqu’à la fin du trajet ou validation admin.</span>
                    {% endif %}
                  {% endif %}
                  <form method="post" action="{{ path('admin_paiement_refund', {id: paiement.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('admin_paiement_refund_' ~ paiement.id) }}">
                    <input type="hidden" name="mode" value="{{ mode }}">
                    {% if remboursementPourcentage is same as(0) %}
                      <input type="hidden" name="exceptionnel" value="1">
                      <button class="btn btn-outline-danger" onclick="return confirm('La politique indique 0 % de remboursement automatique. Confirmer un remboursement exceptionnel ?')">Remboursement exceptionnel</button>
                    {% elseif remboursementPourcentage is not null and remboursementPourcentage < 100 %}
                      <button class="btn btn-danger" onclick="return confirm('Rembourser {{ remboursementPourcentage }} % de ce paiement ?')">Rembourser {{ remboursementPourcentage }} %</button>
                    {% else %}
                      <button class="btn btn-danger" onclick="return confirm('Rembourser ce paiement ?')">Rembourser</button>
                    {% endif %}
                  </form>
                {% else %}
                  <span class="text-muted">Aucune action disponible</span>
                {% endif %}
              </div>
            </div>
          </div>
        </div>
      </div>
    {% endfor %}
  </div>
{% endblock %}

{% block scripts %}
  {{ parent() }}
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const group = document.querySelector('.js-payment-filter');
      if (!group) {
        return;
      }

      const buttons = Array.from(group.querySelectorAll('[data-filter]'));
      const rows = Array.from(document.querySelectorAll('[data-payment-filters]'));

      buttons.forEach((button) => {
        button.addEventListener('click', () => {
          const filter = button.dataset.filter;
          buttons.forEach((item) => {
            item.classList.toggle('btn-primary', item === button);
            item.classList.toggle('btn-outline-secondary', item !== button);
          });

          rows.forEach((row) => {
            row.hidden = filter !== 'all' && !row.dataset.paymentFilters.split(' ').includes(filter);
          });
        });
      });
    });
  </script>
{% endblock %}
