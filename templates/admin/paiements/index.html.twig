{% extends 'base_admin.html.twig' %}
{% block title %}Paiements | Admin{% endblock %}

{% block body %}
{% set statusClasses = {
    'en_attente': 'secondary',
    'autorise': 'warning text-dark',
    'capture': 'success',
    'rembourse': 'info text-dark',
    'echoue': 'danger',
    'annule': 'dark'
} %}

<div class="d-flex flex-column flex-md-row justify-content-between gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">Paiements</h1>
        <p class="text-muted mb-0">Suivi des paiements capturés, remboursements et versements conducteurs.</p>
    </div>
    <span class="badge bg-primary align-self-start">{{ paiements|length }} paiement{{ paiements|length > 1 ? 's' : '' }}</span>
</div>

<div class="table-responsive">
    <table class="table table-bordered table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>ID</th>
                <th>Montant</th>
                <th>Réservation</th>
                <th>Statut</th>
                <th>Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for paiement in paiements %}
            {% set reservation = paiement.reservation %}
            {% set dejaVerse = reservation and reservation.commissions|length > 0 %}
            <tr>
                <td>#{{ paiement.id }}</td>
                <td>{{ paiement.montant|number_format(2, ',', ' ') }} €</td>
                <td>
                    {% if reservation %}
                        ID {{ reservation.id }}
                        {% if reservation.trajet %}
                            <div class="small text-muted">{{ reservation.trajet.depart }} → {{ reservation.trajet.arrivee }}</div>
                        {% endif %}
                    {% else %}
                        <span class="text-muted">Réservation introuvable</span>
                    {% endif %}
                </td>
                <td>
                    <span class="badge bg-{{ statusClasses[paiement.statut]|default('secondary') }}">
                        {{ paiement.statutLabel }}
                    </span>
                    {% if dejaVerse %}
                        <span class="badge bg-success ms-1">versé</span>
                    {% endif %}
                </td>
                <td>{{ paiement.createdAt|date('d/m/Y H:i') }}</td>
                <td>
                    {% if not reservation %}
                        <span class="text-muted">Aucune action</span>
                    {% elseif paiement.statut == 'autorise' %}
                        <form method="post" action="{{ path('admin_paiement_capture', {id: paiement.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('admin_paiement_capture_' ~ paiement.id) }}">
                            <button class="btn btn-sm btn-success" onclick="return confirm('Capturer le paiement ?')">
                                Capturer
                            </button>
                        </form>
                        <form method="post" action="{{ path('admin_paiement_cancel', {id: paiement.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('admin_paiement_cancel_' ~ paiement.id) }}">
                            <button class="btn btn-sm btn-warning mt-1" onclick="return confirm('Annuler ce paiement ?')">
                                Annuler
                            </button>
                        </form>
                    {% elseif paiement.statut == 'capture' %}
                        {% if not dejaVerse %}
                            <form method="post" action="{{ path('admin_paiement_transfer', {id: paiement.id}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('admin_paiement_transfer_' ~ paiement.id) }}">
                                <button class="btn btn-sm btn-success" onclick="return confirm('Verser la part conducteur maintenant ?')">
                                    Verser conducteur
                                </button>
                            </form>
                        {% endif %}
                        <form method="post" action="{{ path('admin_paiement_refund', {id: paiement.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('admin_paiement_refund_' ~ paiement.id) }}">
                            <button class="btn btn-sm btn-danger mt-1" onclick="return confirm('Rembourser ce paiement ?')">
                                Rembourser
                            </button>
                        </form>
                    {% else %}
                        <span class="text-muted">Aucune action</span>
                    {% endif %}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6" class="text-center text-muted">Aucun paiement.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
