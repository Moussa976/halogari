{% extends 'base_admin.html.twig' %}
{% import 'partials/avatar.html.twig' as avatar %}

{% block title %}Utilisateurs | Admin{% endblock %}

{% block body %}
  <div class="container-fluid px-1">
    <div class="d-flex flex-column flex-md-row justify-content-between gap-3 mb-4">
      <div>
        <h1 class="h3 mb-1">Utilisateurs</h1>
        <p class="text-muted mb-0">Comptes inscrits, rôles, coordonnées et état de vérification.</p>
      </div>
      <span class="badge bg-primary align-self-start">{{ users|length }} utilisateur{{ users|length > 1 ? 's' : '' }}</span>
    </div>

    <div class="card">
      <div class="card-body table-responsive">
        <table class="table table-hover align-middle js-admin-table">
          <thead class="table-light">
            <tr>
              <th>ID</th>
              <th>Utilisateur</th>
              <th>Email</th>
              <th>Téléphone</th>
              <th>Vérification</th>
              <th>Rôles</th>
              <th>Date d'inscription</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            {% for user in users %}
              <tr>
                <td>#{{ user.id }}</td>
                <td>
                  <div class="d-flex align-items-center gap-2">
                    {{ avatar.formatSimple(user, 42, 0, 1) }}
                    <div>
                      <a href="{{ path('admin_user_show', {id: user.id}) }}" class="fw-semibold">{{ user.prenom }} {{ user.nom }}</a>
                      {% if user.isProfilVerifieComplet %}
                        <span class="badge bg-success-subtle text-success border border-success-subtle ms-1">Profil vérifié</span>
                      {% endif %}
                    </div>
                  </div>
                </td>
                <td class="text-truncate" style="max-width: 240px;">{{ user.email }}</td>
                <td>{{ user.telephone ?: '-' }}</td>
                <td>
                  <span class="badge {{ user.isVerified ? 'bg-success' : 'bg-warning text-dark' }}">{{ user.isVerified ? 'Email vérifié' : 'Email à confirmer' }}</span>
                  <span class="badge {{ user.hasVerifiedIdentity ? 'bg-success' : 'bg-secondary' }}">{{ user.hasVerifiedIdentity ? 'Identité validée' : 'Identité non validée' }}</span>
                  <span class="badge {{ user.hasVerifiedRib ? 'bg-success' : 'bg-secondary' }}">{{ user.hasVerifiedRib ? 'RIB validé' : 'RIB non validé' }}</span>
                </td>
                <td>
                  {% for role in user.roles %}
                    <span class="badge bg-light text-dark border">{{ role }}</span>
                  {% endfor %}
                </td>
                <td>{{ user.createdAt ? user.createdAt|date('d/m/Y H:i') : '-' }}</td>
                <td>
                  <a href="{{ path('admin_user_show', {id: user.id}) }}" class="btn btn-sm btn-outline-primary">
                    Voir
                  </a>
                </td>
              </tr>
            {% else %}
              <tr>
                <td colspan="8" class="text-center text-muted">Aucun utilisateur trouvé.</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  </div>
{% endblock %}
