{% extends 'base_admin.html.twig' %}
{% import 'partials/avatar.html.twig' as avatar %}

{% block title %}Utilisateur #{{ user.id }} | Admin{% endblock %}

{% block body %}
  {% set documentLabels = {'pending': 'En attente', 'approved': 'Validé', 'rejected': 'Refusé'} %}
  {% set documentClasses = {'pending': 'warning text-dark', 'approved': 'success', 'rejected': 'danger'} %}
  {% set reservationLabels = {'en_attente': 'En attente', 'acceptee': 'Acceptée', 'refusee': 'Refusée', 'payee': 'Payée', 'annulee': 'Annulée'} %}
  {% set reservationClasses = {'en_attente': 'warning text-dark', 'acceptee': 'success', 'refusee': 'danger', 'payee': 'primary', 'annulee': 'secondary'} %}
  {% set paiementClasses = {'en_attente': 'secondary', 'autorise': 'warning text-dark', 'capture': 'success', 'rembourse_partiel': 'info text-dark', 'rembourse': 'info text-dark', 'echoue': 'danger', 'annule': 'dark'} %}
  {% set totalNotes = user.notesPour|length %}
  {% set sommeNotes = user.notesPour|reduce((acc, note) => acc + note.note, 0) %}
  {% set moyenne = totalNotes > 0 ? (sommeNotes / totalNotes)|number_format(1, '.', '') : 0 %}
  {% set paiementsEnvoyes = user.reservations|map(resa => resa.paiement)|filter(p => p) %}
  {% set paiementsRecus = [] %}
  {% for trajet in user.trajets %}
    {% for resa in trajet.reservations %}
      {% if resa.paiement is defined and resa.paiement %}
        {% set paiementsRecus = paiementsRecus|merge([resa.paiement]) %}
      {% endif %}
    {% endfor %}
  {% endfor %}
  {% set totalRecuConducteur = 0 %}
  {% for paiement in paiementsRecus %}
    {% set commission = paiement.reservation.commissions[0] ?? null %}
    {% if commission %}
      {% set montantConducteur = commission.montantConducteur and commission.montantConducteur > 0 ? commission.montantConducteur : (commission.montantBrut - commission.montantNet - commission.fraisStripe) %}
      {% set totalRecuConducteur = totalRecuConducteur + montantConducteur %}
    {% endif %}
  {% endfor %}
  {% set rib = user.getDocumentByType('rib') ?: user.getDocumentByType('RIB') %}
  {% set identite = user.getDocumentByType('identite') %}
  {% set ribHasIban = rib and rib.ribIban %}
  {% set canCreateStripe = rib and identite and rib.status == 'approved' and identite.status == 'approved' and ribHasIban %}
  {% set adminCanEditUser = is_granted('ROLE_SUPER_ADMIN') %}

  <div class="container-fluid px-1">
    <div class="d-flex flex-column flex-xl-row justify-content-between gap-3 mb-4">
      <div>
        <a href="{{ path('admin_users') }}" class="btn btn-outline-secondary btn-sm mb-3">Retour à la liste</a>
        <h1 class="h3 mb-1">{{ user.prenom }} {{ user.nom }}</h1>
        <p class="text-muted mb-0">Fiche administrateur complète du compte #{{ user.id }}.</p>
      </div>
      <div class="d-flex flex-wrap gap-2 align-self-xl-start">
        <a href="{{ path('admin_reservations') }}" class="btn btn-outline-primary btn-sm">Réservations</a>
        <a href="{{ path('admin_trajets') }}" class="btn btn-outline-primary btn-sm">Trajets</a>
        <a href="{{ path('admin_documents') }}" class="btn btn-outline-primary btn-sm">Documents</a>
      </div>
    </div>

    <div class="row g-3 mb-4">
      <div class="col-xl-4">
        <div class="card h-100">
          <div class="card-body">
            <div class="d-flex align-items-center gap-3 mb-3">
              {{ avatar.formatSimple(user, 86, 0, 1) }}
              <div class="min-w-0">
                <h2 class="h5 mb-1">{{ user.prenom }} {{ user.nom }}</h2>
                {% if user.isProfilVerifieComplet %}
                  <span class="badge bg-success">Profil vérifié</span>
                {% else %}
                  <span class="badge bg-warning text-dark">Profil incomplet</span>
                {% endif %}
                {% if user.isDisabled %}
                  <span class="badge bg-danger">Compte désactivé</span>
                {% endif %}
                {% for role in user.roles %}
                  <span class="badge bg-light text-dark border">{{ role }}</span>
                {% endfor %}
              </div>
            </div>
            <div class="small text-muted">Email</div>
            <div class="mb-2 text-break">{{ user.email }}</div>
            <div class="small text-muted">Téléphone</div>
            <div class="mb-2">{{ user.telephone ?: '-' }}</div>
            <div class="small text-muted">Inscription</div>
            <div>{{ user.createdAt ? user.createdAt|date('d/m/Y H:i') : '-' }}</div>
          </div>
        </div>
      </div>

      <div class="col-xl-8">
        <div class="row g-3 h-100">
          <div class="col-sm-6 col-lg-3">
            <div class="card h-100">
              <div class="card-body">
                <div class="text-muted small">Trajets publiés</div>
                <h3 class="mb-0">{{ user.trajets|length }}</h3>
              </div>
            </div>
          </div>
          <div class="col-sm-6 col-lg-3">
            <div class="card h-100">
              <div class="card-body">
                <div class="text-muted small">Réservations</div>
                <h3 class="mb-0">{{ user.reservations|length }}</h3>
              </div>
            </div>
          </div>
          <div class="col-sm-6 col-lg-3">
            <div class="card h-100">
              <div class="card-body">
                <div class="text-muted small">Note moyenne</div>
                <h3 class="mb-0">{{ moyenne }}/5</h3>
              </div>
            </div>
          </div>
          <div class="col-sm-6 col-lg-3">
            <div class="card h-100">
              <div class="card-body">
                <div class="text-muted small">Documents</div>
                <h3 class="mb-0">{{ user.documents|length }}</h3>
              </div>
            </div>
          </div>

          <div class="col-12">
            <div class="card h-100">
              <div class="card-body">
                <div class="d-flex flex-wrap gap-2">
                  <span class="badge {{ user.isVerified ? 'bg-success' : 'bg-warning text-dark' }}">{{ user.isVerified ? 'Email vérifié' : 'Email à confirmer' }}</span>
                  <span class="badge {{ user.hasVerifiedIdentity ? 'bg-success' : 'bg-secondary' }}">{{ user.hasVerifiedIdentity ? 'Identité validée' : 'Identité non validée' }}</span>
                  <span class="badge {{ user.hasVerifiedRib ? 'bg-success' : 'bg-secondary' }}">{{ user.hasVerifiedRib ? 'RIB validé' : 'RIB non validé' }}</span>
                  <span class="badge {{ user.hasPostalAddress ? 'bg-success' : 'bg-warning text-dark' }}">{{ user.hasPostalAddress ? 'Adresse complète' : 'Adresse à compléter' }}</span>
                  <span class="badge {{ user.canPublishRide ? 'bg-success' : 'bg-warning text-dark' }}">{{ user.canPublishRide ? 'Publication autorisée' : 'Publication bloquée' }}</span>
                  <span class="badge {{ user.stripeAccountId ? (stripeStatus.invalid|default(false) ? 'bg-warning text-dark' : 'bg-success') : 'bg-secondary' }}">{{ user.stripeAccountId ? (stripeStatus.invalid|default(false) ? 'Stripe à vérifier' : 'Stripe connecté') : 'Stripe absent' }}</span>
                </div>
                {% if user.isDisabled %}
                  <div class="alert alert-danger mt-3 mb-0">
                    Compte désactivé depuis le {{ user.disabledAt|date('d/m/Y H:i') }}.
                    {% if user.scheduledDeletionAt %}
                      Suppression programmée le {{ user.scheduledDeletionAt|date('d/m/Y H:i') }}.
                    {% endif %}
                    <div class="d-flex flex-wrap gap-2 mt-3">
                      <form method="post" action="{{ path('admin_user_reactivate', {id: user.id}) }}" onsubmit="return confirm('Réactiver ce compte ? L’utilisateur pourra se reconnecter.');">
                        <input type="hidden" name="_token" value="{{ csrf_token('admin_user_reactivate_' ~ user.id) }}">
                        <button class="btn btn-success btn-sm">
                          <i class="bi bi-arrow-counterclockwise"></i>
                          Réactiver le compte
                        </button>
                      </form>
                      <a href="{{ path('admin_users', {status: 'disabled'}) }}" class="btn btn-outline-danger btn-sm">
                        Voir les comptes désactivés
                      </a>
                    </div>
                  </div>
                {% endif %}
                {% if not user.isVerified %}
                  <form class="mt-3" method="post" action="{{ path('admin_user_resend_confirmation', { id: user.id }) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('admin_user_resend_confirmation_' ~ user.id) }}">
                    <button class="btn btn-sm btn-outline-primary" onclick="return confirm('Renvoyer l’e-mail de confirmation ?');">Renvoyer l’e-mail de confirmation</button>
                  </form>
                {% endif %}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="card mb-4">
      <div class="card-header">Informations du compte</div>
      <div class="card-body">
        <form method="post" enctype="multipart/form-data" action="{{ path('admin_user_update', {id: user.id}) }}">
          <input type="hidden" name="_token" value="{{ csrf_token('admin_user_update_' ~ user.id) }}">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label fw-bold">Nom</label>
              <input type="text" name="nom" class="form-control" value="{{ user.nom }}">
            </div>
            <div class="col-md-6">
              <label class="form-label fw-bold">Prénom</label>
              <input type="text" name="prenom" class="form-control" value="{{ user.prenom }}">
            </div>
            <div class="col-md-6">
              <label class="form-label fw-bold">Email</label>
              <input type="email" name="email" class="form-control" value="{{ user.email }}">
            </div>
            <div class="col-md-6">
              <label class="form-label fw-bold">Téléphone</label>
              <input type="text" name="telephone" class="form-control" value="{{ user.telephone }}">
            </div>
            <div class="col-12">
              <hr>
              <h2 class="h5 mb-1">Adresse postale</h2>
              <p class="text-muted small mb-0">À compléter pour autoriser la publication de trajets.</p>
            </div>
            <div class="col-md-8 position-relative" data-address-autocomplete>
              <label class="form-label fw-bold">Adresse</label>
              <input type="text" name="postalAddressLine1" class="form-control" value="{{ user.postalAddressLine1 }}" autocomplete="address-line1" data-address-input>
              <div class="list-group position-absolute start-0 end-0 shadow-sm d-none z-3 mx-2" data-address-results></div>
            </div>
            <div class="col-md-4">
              <label class="form-label fw-bold">Complément</label>
              <input type="text" name="postalAddressLine2" class="form-control" value="{{ user.postalAddressLine2 }}" autocomplete="address-line2">
            </div>
            <div class="col-md-3">
              <label class="form-label fw-bold">Code postal</label>
              <input type="text" name="postalCode" class="form-control" value="{{ user.postalCode }}" autocomplete="postal-code" data-address-postcode>
            </div>
            <div class="col-md-5">
              <label class="form-label fw-bold">Ville</label>
              <input type="text" name="postalCity" class="form-control" value="{{ user.postalCity }}" autocomplete="address-level2" data-address-city>
            </div>
            <div class="col-md-4">
              <label class="form-label fw-bold">Pays ou territoire</label>
              <input type="text" name="postalCountry" class="form-control" value="{{ user.postalCountry ?: 'Mayotte' }}" autocomplete="country-name" data-address-country>
            </div>
            <div class="col-md-8">
              <label class="form-label fw-bold">Photo de profil</label>
              <input type="file" name="photo" class="form-control" accept="image/*">
            </div>
            {% if user.photo %}
              <div class="col-md-4 d-flex align-items-end">
                <div class="form-check">
                  <input type="checkbox" name="remove_photo" value="1" class="form-check-input" id="removePhoto">
                  <label for="removePhoto" class="form-check-label text-danger">Supprimer la photo actuelle</label>
                </div>
              </div>
            {% endif %}
          </div>
          <div class="mt-3">
            <button class="btn btn-primary btn-sm">Enregistrer</button>
          </div>
        </form>
      </div>
    </div>

    <div class="row g-3 mb-4">
      <div class="col-xl-7">
        <div class="card h-100">
          <div class="card-header d-flex justify-content-between align-items-center">
            <span>Documents envoyés</span>
            <span class="badge bg-light text-dark border">{{ user.documents|length }}</span>
          </div>
          <div class="card-body">
            {% if user.documents is empty %}
              <div class="alert alert-warning mb-0">Aucun document.</div>
            {% else %}
              <div class="table-responsive">
                <table class="table table-hover align-middle js-admin-table">
                  <thead class="table-light">
                    <tr>
                      <th>ID</th>
                      <th>Type</th>
                      <th>Fichier</th>
                      <th>IBAN</th>
                      <th>Statut</th>
                      <th>Date</th>
                      <th>Action</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for doc in user.documents %}
                      <tr>
                        <td>#{{ doc.id }}</td>
                        <td>{{ doc.typeDocument|replace({'_': ' ', '-': ' '})|title }}</td>
                        <td class="text-truncate" style="max-width: 210px;">{{ doc.filenameDocument }}</td>
                        <td>
                          {% if doc.typeDocument|lower == 'rib' %}
                            {% if doc.ribIban %}
                              <span class="small text-break">{{ doc.ribIban }}</span>
                            {% else %}
                              <span class="badge bg-warning text-dark">IBAN manquant</span>
                            {% endif %}
                          {% else %}
                            <span class="text-muted">-</span>
                          {% endif %}
                        </td>
                        <td><span class="badge bg-{{ documentClasses[doc.status]|default('secondary') }}">{{ documentLabels[doc.status]|default(doc.status) }}</span></td>
                        <td>{{ doc.dateDocument|date('d/m/Y H:i') }}</td>
                        <td>
                          <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#modal-doc-{{ doc.id }}">Ouvrir</button>
                        </td>
                      </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            {% endif %}
          </div>
        </div>
      </div>

      <div class="col-xl-5">
        <div class="card h-100">
          <div class="card-header">Compte Stripe Connect</div>
          <div class="card-body">
            {% if user.stripeAccountId %}
              <div class="alert {{ stripeStatus.invalid|default(false) ? 'alert-warning' : 'alert-success' }}">
                {{ stripeStatus.invalid|default(false) ? 'Compte Stripe Connect à vérifier.' : 'Compte Stripe Connect créé.' }}
                <div class="small text-break mt-1">ID : {{ user.stripeAccountId }}</div>
                {% if stripeStatus.invalid|default(false) %}
                  <div class="small mt-2">{{ stripeStatus.error }}</div>
                {% endif %}
              </div>
              {% if stripeStatus and not stripeStatus.invalid|default(false) %}
                <dl class="row small mb-3">
                  <dt class="col-7">Email</dt><dd class="col-5 text-end">{{ stripeStatus.email ?: '-' }}</dd>
                  <dt class="col-7">Type</dt><dd class="col-5 text-end">{{ stripeStatus.type ?: '-' }}</dd>
                  <dt class="col-7">Charges activées</dt><dd class="col-5 text-end">{{ stripeStatus.charges_enabled ? 'Oui' : 'Non' }}</dd>
                  <dt class="col-7">Paiements sortants</dt><dd class="col-5 text-end">{{ stripeStatus.payouts_enabled ? 'Oui' : 'Non' }}</dd>
                  <dt class="col-7">Infos complètes</dt><dd class="col-5 text-end">{{ stripeStatus.details_submitted ? 'Oui' : 'Non' }}</dd>
                </dl>
                {% if not stripeStatus.verification_document %}
                  <form method="post" action="{{ path('admin_user_stripe_upload_identity', {id: user.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('admin_user_stripe_identity_' ~ user.id) }}">
                    <button class="btn btn-sm btn-outline-primary">Envoyer la pièce d'identité à Stripe</button>
                  </form>
                {% endif %}
              {% endif %}
              <form class="mt-3" method="post" action="{{ path('admin_user_delete_stripe', {id: user.id}) }}" onsubmit="return confirm('Confirmer la suppression du compte Stripe ?');">
                <input type="hidden" name="_token" value="{{ csrf_token('admin_user_stripe_delete_' ~ user.id) }}">
                <button class="btn btn-outline-danger btn-sm">Supprimer le compte Stripe</button>
              </form>
            {% elseif canCreateStripe %}
              <div class="alert alert-success">Les documents requis sont validés. Vous pouvez créer le compte Stripe Connect.</div>
              <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#modalStripe">Créer le compte Stripe Connect</button>
            {% elseif rib and identite and rib.status == 'approved' and identite.status == 'approved' and not ribHasIban %}
              <div class="alert alert-warning mb-0">Le RIB est validé, mais aucun IBAN n’est enregistré. Demandez au conducteur d’envoyer à nouveau son RIB avec l’IBAN saisi.</div>
            {% else %}
              <div class="alert alert-warning mb-0">Le compte Stripe ne peut pas encore être créé : identité et RIB doivent être validés.</div>
            {% endif %}
          </div>
        </div>
      </div>
    </div>

    <div class="row g-3 mb-4">
      <div class="col-xl-6">
        <div class="card h-100">
          <div class="card-header">Notes reçues</div>
          <div class="card-body">
            {% if user.notesPour is empty %}
              <div class="alert alert-info mb-0">Aucune note.</div>
            {% else %}
              <div class="list-group">
                {% for note in user.notesPour %}
                  <div class="list-group-item">
                    <div class="d-flex justify-content-between gap-3">
                      <div>
                        <strong>{{ note.note }}/5</strong>
                        <span class="text-warning ms-1">{% for i in 1..5 %}{{ i <= note.note ? '★' : '☆' }}{% endfor %}</span>
                        {% if note.noteur %}
                          <div class="small text-muted">par <a href="{{ path('admin_user_show', {id: note.noteur.id}) }}">{{ note.noteur.prenom }} {{ note.noteur.nom }}</a></div>
                        {% endif %}
                      </div>
                      <span class="small text-muted">{{ note.createdAt ? note.createdAt|date('d/m/Y H:i') : '-' }}</span>
                    </div>
                    {% if note.commentaire %}
                      <div class="mt-2">{{ note.commentaire }}</div>
                    {% endif %}
                  </div>
                {% endfor %}
              </div>
            {% endif %}
          </div>
        </div>
      </div>

      <div class="col-xl-6">
        <div class="card h-100">
          <div class="card-header">Actions sensibles</div>
          <div class="card-body d-flex flex-wrap gap-2 align-items-start">
            {% if is_granted('ROLE_SUPER_ADMIN') and 'ROLE_ADMIN' not in user.roles and 'ROLE_SUPER_ADMIN' not in user.roles %}
              <form method="post" action="{{ path('admin_user_promote', {id: user.id}) }}" onsubmit="return confirm('Promouvoir cet utilisateur au rôle ADMIN ?');">
                <input type="hidden" name="_token" value="{{ csrf_token('admin_user_promote_' ~ user.id) }}">
                <button type="submit" class="btn btn-outline-success btn-sm">Promouvoir en admin</button>
              </form>
            {% endif %}
            <form method="post" action="{{ path('admin_user_delete', {id: user.id}) }}" onsubmit="return confirm('Confirmer la suppression (anonymisation) de ce compte ?');">
              <input type="hidden" name="_token" value="{{ csrf_token('admin_user_delete_' ~ user.id) }}">
              <button type="submit" class="btn btn-outline-danger btn-sm">Supprimer ce compte</button>
            </form>
          </div>
        </div>
      </div>
    </div>

    <div class="card mb-4">
      <div class="card-header d-flex justify-content-between align-items-center">
        <span>Trajets publiés</span>
        <span class="badge bg-light text-dark border">{{ user.trajets|length }}</span>
      </div>
      <div class="card-body">
        {% if user.trajets is empty %}
          <div class="alert alert-info mb-0">Aucun trajet publié.</div>
        {% else %}
          <div class="table-responsive">
            <table class="table table-hover table-bordered align-middle js-admin-table">
              <thead class="table-light">
                <tr>
                  <th>ID</th>
                  <th>Trajet</th>
                  <th>Date</th>
                  <th>Places</th>
                  <th>Prix</th>
                  <th>Créé le</th>
                </tr>
              </thead>
              <tbody>
                {% for trajet in user.trajets %}
                  <tr>
                    <td>#{{ trajet.id }}</td>
                    <td>{{ trajet.depart }} → {{ trajet.arrivee }}</td>
                    <td>{{ trajet.dateTrajet|date('d/m/Y') }} à {{ trajet.heureTrajet|date('H:i') }}</td>
                    <td>{{ trajet.placesDisponibles }}/{{ trajet.places }}</td>
                    <td>{{ trajet.prix|number_format(2, ',', ' ') }} €</td>
                    <td>{{ trajet.createdAt|date('d/m/Y H:i') }}</td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        {% endif %}
      </div>
    </div>

    <div class="card mb-4">
      <div class="card-header d-flex justify-content-between align-items-center">
        <span>Réservations effectuées</span>
        <span class="badge bg-light text-dark border">{{ user.reservations|length }}</span>
      </div>
      <div class="card-body">
        {% if user.reservations is empty %}
          <div class="alert alert-info mb-0">Aucune réservation.</div>
        {% else %}
          <div class="table-responsive">
            <table class="table table-hover table-bordered align-middle js-admin-table">
              <thead class="table-light">
                <tr>
                  <th>ID</th>
                  <th>Trajet</th>
                  <th>Date</th>
                  <th>Conducteur</th>
                  <th>Places</th>
                  <th>Statut</th>
                  <th>Créé le</th>
                </tr>
              </thead>
              <tbody>
                {% for resa in user.reservations %}
                  {% set reservationLabel = resa.statut == 'annulee' and resa.cancellationLabel ? resa.cancellationLabel : reservationLabels[resa.statut]|default(resa.statut) %}
                  <tr>
                    <td>#{{ resa.id }}</td>
                    <td>{{ resa.trajet ? resa.trajet.depart ~ ' → ' ~ resa.trajet.arrivee : 'Trajet supprimé' }}</td>
                    <td>{{ resa.trajet ? resa.trajet.dateTrajet|date('d/m/Y') ~ ' à ' ~ resa.trajet.heureTrajet|date('H:i') : '-' }}</td>
                    <td>
                      {% if resa.trajet and resa.trajet.conducteur %}
                        <a href="{{ path('admin_user_show', { id: resa.trajet.conducteur.id }) }}">{{ resa.trajet.conducteur.prenom }} {{ resa.trajet.conducteur.nom }}</a>
                      {% else %}
                        <span class="text-muted">-</span>
                      {% endif %}
                    </td>
                    <td>{{ resa.places ?: '-' }}</td>
                    <td>
                      <span class="badge bg-{{ reservationClasses[resa.statut]|default('secondary') }}">{{ reservationLabel }}</span>
                      {% if resa.canceledAt %}
                        <div class="small text-muted">{{ resa.canceledAt|date('d/m/Y à H:i') }}</div>
                      {% endif %}
                    </td>
                    <td>{{ resa.createdAt|date('d/m/Y H:i') }}</td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        {% endif %}
      </div>
    </div>

    <div class="row g-3">
      <div class="col-xl-6">
        <div class="card h-100">
          <div class="card-header d-flex justify-content-between align-items-center">
            <span>Paiements effectués</span>
            <span class="badge bg-light text-dark border">{{ paiementsEnvoyes|length }}</span>
          </div>
          <div class="card-body">
            {% if paiementsEnvoyes is empty %}
              <div class="alert alert-info mb-0">Aucun paiement effectué.</div>
            {% else %}
              <div class="table-responsive">
                <table class="table table-hover table-bordered align-middle js-admin-table">
                  <thead class="table-light">
                    <tr>
                      <th>ID</th>
                      <th>Montant</th>
                      <th>Trajet</th>
                      <th>Statut</th>
                      <th>Date</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for paiement in paiementsEnvoyes %}
                      <tr>
                        <td>#{{ paiement.id }}</td>
                        <td>{{ paiement.montant|number_format(2, ',', ' ') }} €</td>
                        <td>{{ paiement.reservation and paiement.reservation.trajet ? paiement.reservation.trajet.depart ~ ' → ' ~ paiement.reservation.trajet.arrivee : '-' }}</td>
                        <td><span class="badge bg-{{ paiementClasses[paiement.statut]|default('secondary') }}">{{ paiement.statutLabel }}</span></td>
                        <td>{{ paiement.createdAt|date('d/m/Y H:i') }}</td>
                      </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            {% endif %}
          </div>
        </div>
      </div>

      <div class="col-xl-6">
        <div class="card h-100">
          <div class="card-header d-flex justify-content-between align-items-center">
            <span>Paiements reçus</span>
            <span class="badge bg-light text-dark border">{{ paiementsRecus|length }} - {{ totalRecuConducteur|number_format(2, ',', ' ') }} €</span>
          </div>
          <div class="card-body">
            {% if paiementsRecus is empty %}
              <div class="alert alert-info mb-0">Aucun paiement reçu.</div>
            {% else %}
              <div class="table-responsive">
                <table class="table table-hover table-bordered align-middle js-admin-table">
                  <thead class="table-light">
                    <tr>
                      <th>ID</th>
                      <th>Total payé</th>
                      <th>Net conducteur</th>
                      <th>Passager</th>
                      <th>Trajet</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for paiement in paiementsRecus %}
                      {% set commission = paiement.reservation.commissions[0] ?? null %}
                      <tr>
                        <td>#{{ paiement.id }}</td>
                        <td>{{ paiement.montant|number_format(2, ',', ' ') }} €</td>
                        <td>
                          {% if commission %}
                            {% set montantConducteur = commission.montantConducteur and commission.montantConducteur > 0 ? commission.montantConducteur : (commission.montantBrut - commission.montantNet - commission.fraisStripe) %}
                            {{ montantConducteur|number_format(2, ',', ' ') }} €
                          {% else %}
                            <span class="text-muted">-</span>
                          {% endif %}
                        </td>
                        <td>{{ paiement.reservation.passager ? paiement.reservation.passager.prenom ~ ' ' ~ paiement.reservation.passager.nom : '-' }}</td>
                        <td>{{ paiement.reservation.trajet ? paiement.reservation.trajet.depart ~ ' → ' ~ paiement.reservation.trajet.arrivee : '-' }}</td>
                      </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    </div>

    {% for doc in user.documents %}
      {% set fileUrl = path('admin_document_file', { id: doc.id }) %}
      {% set ext = doc.filenameDocument|split('.')|last|lower %}
      <div class="modal fade" id="modal-doc-{{ doc.id }}" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
          <div class="modal-content">
            <div class="modal-header">
              <div>
                <h5 class="modal-title">Document #{{ doc.id }} - {{ doc.typeDocument|replace({'_': ' ', '-': ' '})|title }}</h5>
                <div class="text-muted small">{{ doc.filenameDocument }}</div>
              </div>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
            </div>
            <div class="modal-body">
              <div class="mb-3">
                <span class="badge bg-{{ documentClasses[doc.status]|default('secondary') }}">{{ documentLabels[doc.status]|default(doc.status) }}</span>
                <span class="text-muted small ms-2">{{ doc.dateDocument|date('d/m/Y H:i') }}</span>
                {% if doc.rejectionReason %}
                  <div class="small text-danger mt-2">{{ doc.rejectionReason }}</div>
                {% endif %}
                {% if doc.typeDocument|lower == 'rib' and doc.ribIban %}
                  <div class="small text-muted mt-2">IBAN saisi : <strong>{{ doc.ribIban }}</strong></div>
                {% endif %}
              </div>
              {% if ext in ['jpg', 'jpeg', 'png', 'webp'] %}
                <img src="{{ fileUrl }}" alt="Document #{{ doc.id }}" class="img-fluid rounded border w-100" style="max-height: 72vh; object-fit: contain; background: #f8f9fa;">
              {% elseif ext == 'pdf' %}
                <iframe src="{{ fileUrl }}" class="w-100 border rounded" style="min-height: 70vh;"></iframe>
              {% else %}
                <div class="alert alert-info">Aperçu non disponible. <a href="{{ fileUrl }}" target="_blank" rel="noopener">Ouvrir le fichier</a></div>
              {% endif %}
            </div>
            <div class="modal-footer justify-content-between">
              <a href="{{ fileUrl }}" target="_blank" rel="noopener" class="btn btn-outline-primary">Ouvrir dans un onglet</a>
              <div class="d-flex flex-wrap gap-2">
                {% if doc.status != 'approved' %}
                  <form method="post" action="{{ path('admin_document_validate', {id: doc.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('admin_document_validate_' ~ doc.id) }}">
                    <input type="hidden" name="_return_to" value="user">
                    <button class="btn btn-success" onclick="return confirm('Valider ce document ?')">Valider</button>
                  </form>
                {% endif %}
                {% if doc.status != 'rejected' %}
                  <form method="post" action="{{ path('admin_document_reject', {id: doc.id}) }}" class="d-flex flex-wrap gap-2">
                    <input type="hidden" name="_token" value="{{ csrf_token('admin_document_reject_' ~ doc.id) }}">
                    <input type="hidden" name="_return_to" value="user">
                    <input type="text" name="reason" class="form-control form-control-sm" placeholder="Motif du refus" required style="max-width: 220px;">
                    <button class="btn btn-danger" onclick="return confirm('Refuser ce document ?')">Refuser</button>
                  </form>
                {% endif %}
                {% if doc.status != 'pending' %}
                  <form method="post" action="{{ path('admin_document_pending', {id: doc.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('admin_document_pending_' ~ doc.id) }}">
                    <input type="hidden" name="_return_to" value="user">
                    <button class="btn btn-outline-secondary" onclick="return confirm('Remettre ce document en attente ?')">Remettre en attente</button>
                  </form>
                {% endif %}
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Fermer</button>
              </div>
            </div>
          </div>
        </div>
      </div>
    {% endfor %}

    {% if not user.stripeAccountId and canCreateStripe %}
      <div class="modal fade" id="modalStripe" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
          <div class="modal-content">
            <form method="post" action="{{ path('admin_user_create_stripe_custom', {id: user.id}) }}">
              <input type="hidden" name="_token" value="{{ csrf_token('admin_user_stripe_create_' ~ user.id) }}">
              <div class="modal-header">
                <h5 class="modal-title">Création compte Stripe Connect</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
              </div>
              <div class="modal-body">
                <div class="row g-3">
                  <div class="col-12">
                    <label class="form-label">Titulaire du compte</label>
                    <input type="text" name="nom_complet" required class="form-control" value="{{ user.prenom ~ ' ' ~ user.nom }}">
                  </div>
                  <div class="col-md-6 position-relative" data-address-autocomplete>
                    <label class="form-label">Adresse</label>
                    <input type="text" name="line1" required class="form-control" value="{{ user.postalAddressLine1 ?: '1 rue fictive' }}" autocomplete="address-line1" data-address-input>
                    <div class="list-group position-absolute start-0 end-0 shadow-sm d-none z-3 mx-2" data-address-results></div>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label">Ville</label>
                    <input type="text" name="city" required class="form-control" value="{{ user.postalCity ?: 'Mamoudzou' }}" autocomplete="address-level2" data-address-city>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label">Code postal</label>
                    <input type="text" name="postal_code" required class="form-control" value="{{ user.postalCode ?: '97600' }}" autocomplete="postal-code" data-address-postcode>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label">Pays</label>
                    <select name="country" class="form-control">
                      <option value="FR" selected>France</option>
                    </select>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label">Téléphone</label>
                    <input type="text" name="telephone" class="form-control" required value="{{ user.telephone }}">
                  </div>
                  <div class="col-md-6">
                    <label class="form-label">Site web</label>
                    <input type="url" name="site_web" class="form-control" value="https://halogari.yt" required>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label">Secteur d'activité</label>
                    <input type="text" name="secteur" class="form-control" required value="Mobilité">
                  </div>
                  <div class="col-md-6">
                    <label class="form-label">IBAN</label>
                    <input type="text" name="iban" required class="form-control" placeholder="FR76..." value="{{ rib.ribIban }}">
                  </div>
                </div>
              </div>
              <div class="modal-footer">
                <button class="btn btn-success">Créer le compte maintenant</button>
              </div>
            </form>
          </div>
        </div>
      </div>
    {% endif %}
  </div>
{% endblock %}

{% block scripts %}
  {{ parent() }}
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const addressBlocks = Array.from(document.querySelectorAll('[data-address-autocomplete]'));
      const timers = new WeakMap();

      const resolvePostalCountry = (postcode, context) => {
        if ((postcode || '').startsWith('976')) return 'Mayotte';
        if ((postcode || '').startsWith('974')) return 'Réunion';
        if ((context || '').includes('Mayotte')) return 'Mayotte';
        if ((context || '').includes('Réunion') || (context || '').includes('Reunion')) return 'Réunion';
        return 'France';
      };

      const hideResults = (block) => {
        const results = block.querySelector('[data-address-results]');
        if (!results) return;
        results.classList.add('d-none');
        results.innerHTML = '';
      };

      const fillAddress = (block, props) => {
        const input = block.querySelector('[data-address-input]');
        const form = block.closest('form') || document;
        const postcode = form.querySelector('[data-address-postcode]');
        const city = form.querySelector('[data-address-city]');
        const country = form.querySelector('[data-address-country]');

        if (input) input.value = props.name || props.label || '';
        if (postcode) postcode.value = props.postcode || '';
        if (city) city.value = props.city || '';
        if (country) country.value = resolvePostalCountry(props.postcode || '', props.context || '');
        hideResults(block);
      };

      const renderResults = (block, features) => {
        const results = block.querySelector('[data-address-results]');
        if (!results) return;
        results.innerHTML = '';

        if (!features.length) {
          hideResults(block);
          return;
        }

        features.slice(0, 5).forEach((feature) => {
          const props = feature.properties || {};
          const option = document.createElement('button');
          option.type = 'button';
          option.className = 'list-group-item list-group-item-action text-start';
          option.textContent = props.label || props.name || '';
          option.addEventListener('click', () => fillAddress(block, props));
          results.appendChild(option);
        });

        results.classList.remove('d-none');
      };

      addressBlocks.forEach((block) => {
        const input = block.querySelector('[data-address-input]');
        if (!input) return;

        input.addEventListener('input', () => {
          clearTimeout(timers.get(input));
          const query = input.value.trim();
          if (query.length < 3) {
            hideResults(block);
            return;
          }

          timers.set(input, setTimeout(async () => {
            try {
              const response = await fetch(`https://api-adresse.data.gouv.fr/search/?q=${encodeURIComponent(query)}&limit=5&autocomplete=1`);
              if (!response.ok) throw new Error('Adresse introuvable');
              const data = await response.json();
              renderResults(block, Array.isArray(data.features) ? data.features : []);
            } catch (error) {
              hideResults(block);
            }
          }, 250));
        });
      });

      document.addEventListener('click', (event) => {
        if (event.target.closest('[data-address-autocomplete]')) return;
        addressBlocks.forEach(hideResults);
      });
    });
  </script>
{% endblock %}
