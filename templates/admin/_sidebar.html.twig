{% set route = app.request.attributes.get('_route') %}

<nav id="sidebar" class="sidebar js-sidebar">
	<div class="sidebar-content js-simplebar">
		<a class="sidebar-brand" href="{{ path('admin_dashboard') }}">
			<span class="align-middle">HaloGari Admin</span>
		</a>

		<ul class="sidebar-nav">

			<li class="sidebar-item {% if route == 'admin_dashboard' %}active{% endif %}">
				<a class="sidebar-link" href="{{ path('admin_dashboard') }}">
					<i class="align-middle" data-feather="sliders"></i>
					<span class="align-middle">Tableau de bord</span>
				</a>
			</li>

			<li class="sidebar-item {% if route == 'admin_trajets' %}active{% endif %}">
				<a class="sidebar-link" href="{{ path('admin_trajets') }}">
					<i class="align-middle" data-feather="map-pin"></i>
					<span class="align-middle">Trajets</span>
				</a>
			</li>

			<li class="sidebar-item {% if route == 'admin_reservations' %}active{% endif %}">
				<a class="sidebar-link" href="{{ path('admin_reservations') }}">
					<i class="align-middle" data-feather="shopping-bag"></i>
					<span class="align-middle">Réservations</span>
				</a>
			</li>

			<li class="sidebar-item {% if route in ['admin_users', 'admin_user_show'] %}active{% endif %}">
				<a class="sidebar-link" href="{{ path('admin_users') }}">
					<i class="align-middle" data-feather="users"></i>
					<span class="align-middle">Utilisateurs</span>
				</a>
			</li>

			<li class="sidebar-item {% if route starts with 'admin_document' %}active{% endif %}">
				<a class="sidebar-link" href="{{ path('admin_documents') }}">
					<i class="align-middle" data-feather="file-text"></i>
					<span class="align-middle">Documents</span>
				</a>
			</li>

			<li class="sidebar-item {% if route == 'admin_paiements' %}active{% endif %}">
				<a class="sidebar-link" href="{{ path('admin_paiements') }}">
					<i class="align-middle" data-feather="dollar-sign"></i>
					<span class="align-middle">Paiements</span>
				</a>
			</li>

			<li class="sidebar-item {% if route == 'admin_stripe_connect_accounts' %}active{% endif %}">
				<a class="sidebar-link" href="{{ path('admin_stripe_connect_accounts') }}">
					<i class="align-middle" data-feather="credit-card"></i>
					<span class="align-middle">Comptes Stripe</span>
				</a>
			</li>

			<li class="sidebar-item {% if route == 'admin_litiges_remboursements' %}active{% endif %}">
				<a class="sidebar-link" href="{{ path('admin_litiges_remboursements') }}">
					<i class="align-middle" data-feather="alert-triangle"></i>
					<span class="align-middle">Litiges et remboursements</span>
				</a>
			</li>
			

      <li class="sidebar-item {% if route == 'admin_notes' %}active{% endif %}">
				<a class="sidebar-link" href="{{ path('admin_notes') }}">
					<i class="align-middle" data-feather="star"></i>
					<span class="align-middle">Notes</span>
				</a>
			</li>

			{% if is_granted('ROLE_SUPER_ADMIN') %}
				<li class="sidebar-item {% if route == 'admin_settings' %}active{% endif %}">
					<a class="sidebar-link" href="{{ path('admin_settings') }}">
						<i class="align-middle" data-feather="settings"></i>
						<span class="align-middle">Paramètres</span>
					</a>
				</li>

				<li class="sidebar-item {% if route == 'admin_audit_logs' %}active{% endif %}">
					<a class="sidebar-link" href="{{ path('admin_audit_logs') }}">
						<i class="align-middle" data-feather="activity"></i>
						<span class="align-middle">Historique</span>
					</a>
				</li>
			{% endif %}

		</ul>
	</div>
</nav>
