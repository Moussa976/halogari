{% extends 'base.html.twig' %}

{% block title %}HaloGari | Chercher un trajet{% endblock %}

{% block body %}
<section class="app-page-header">
  <div class="container">
    <p class="app-kicker">Recherche</p>
    <h1>Où voulez-vous aller aujourd'hui ?</h1>
    <p>Indiquez votre départ, votre arrivée et la date.</p>
  </div>
</section>

<section class="container app-page-grid">
  <form method="GET" id="form-recherche" action="{{ path('app_chercher') }}" class="app-panel app-panel--form">
    <div class="app-panel__header">
      <span class="app-panel__icon"><i class="bi bi-search"></i></span>
      <div>
        <h2>Votre trajet</h2>
      </div>
    </div>

    <div class="form-floating">
      <input id="select_departure" class="form-control villages" name="select_departure" placeholder="Départ" required>
      <label for="select_departure">Départ</label>
    </div>

    <div class="form-floating">
      <input id="select_arrival" name="select_arrival" class="form-control villages" placeholder="Arrivée" required>
      <label for="select_arrival">Arrivée</label>
    </div>

    <div class="app-form-row">
      <div class="form-floating">
        <input type="text" id="date" class="form-control dateDepart" name="date_trajet" placeholder="jj/mm/aaaa" required>
        <label for="date">Date</label>
      </div>

      <div class="form-floating">
        <select class="form-select" id="places" name="places_min" required>
          {% for i in 1..8 %}
            <option value="{{ i }}">{{ i }}</option>
          {% endfor %}
        </select>
        <label for="places">Passagers</label>
      </div>
    </div>

    <button type="submit" class="btn btn-orange btn-lg w-100" data-loading-button data-loading-label="Recherche">
      <i class="bi bi-arrow-right-circle"></i>
      Rechercher
    </button>
  </form>

  <aside class="app-panel app-tips-panel">
    <span class="app-panel__icon"><i class="bi bi-stars"></i></span>
    <h2>Bon à savoir</h2>
    <p>Si aucun trajet direct n’est disponible, essayez un village proche.</p>
    <div class="tip-list">
      <span><i class="bi bi-check-circle-fill"></i> Prix visible avant de réserver</span>
      <span><i class="bi bi-check-circle-fill"></i> Paiement après acceptation</span>
    </div>
  </aside>
</section>
{% endblock %}
