{% extends 'base.html.twig' %}

{% block title %}HaloGari | Chercher un trajet{% endblock %}
{% block meta_description %}Recherchez un trajet de covoiturage entre villages à Mayotte. Choisissez le départ, l’arrivée, la date et le nombre de places souhaitées.{% endblock %}

{% block body %}
<section class="app-page-header">
  <div class="container">
    <p class="app-kicker">Recherche</p>
    <h1>Où voulez-vous aller aujourd'hui ?</h1>
    <p>Indiquez votre départ, votre arrivée et la date.</p>
  </div>
</section>

<section class="container search-page-layout">
  <form method="GET" id="form-recherche" action="{{ path('app_chercher') }}" class="quick-search search-page-form search-page-form--wide" aria-label="Recherche rapide">
    <div class="ride-scene" aria-hidden="true">
      <div class="ride-scene__sign ride-scene__sign--start">Départ</div>
      <div class="ride-scene__road"></div>
      <div class="ride-scene__group ride-scene__group--start">
        <span></span><span></span>
      </div>
      <div class="ride-scene__van">
        <i class="bi bi-car-front-fill"></i>
        <div class="ride-scene__passengers">
          <span></span><span></span>
        </div>
      </div>
      <div class="ride-scene__group ride-scene__group--arrival">
        <span></span><span></span>
      </div>
      <div class="ride-scene__sign ride-scene__sign--end">Arrivée</div>
    </div>

    <div class="quick-search__title search-page-form__title">
      <strong>Où allez-vous ?</strong>
      <span>Recherche rapide</span>
    </div>

    <div class="search-page-fields">
    <div class="input-group search-form-field">
      <span class="input-group-text text-vert"><i class="bi bi-geo-fill"></i></span>
      <div class="form-floating">
        <input id="select_departure" class="form-control villages" name="select_departure" placeholder="Village de départ" required>
        <label for="select_departure">Départ</label>
      </div>
    </div>

    <div class="input-group search-form-field">
      <span class="input-group-text text-vert"><i class="bi bi-flag-fill"></i></span>
      <div class="form-floating">
        <input id="select_arrival" name="select_arrival" class="form-control villages" placeholder="Village d'arrivée" required>
        <label for="select_arrival">Arrivée</label>
      </div>
    </div>

    <div class="quick-search__row">
      <div class="input-group search-form-field">
        <span class="input-group-text text-vert"><i class="bi bi-calendar2-event-fill"></i></span>
        <div class="form-floating">
          <input type="text" id="date_trajet" class="form-control dateDepart" name="date_trajet" value="{{ 'now'|date('d/m/Y') }}" placeholder="jj/mm/aaaa" data-default-today="true" required>
          <label for="date_trajet">Date</label>
        </div>
      </div>

      <div class="input-group search-form-field">
        <span class="input-group-text text-vert"><i class="bi bi-people-fill"></i></span>
        <div class="form-floating">
          <select class="form-select" id="places_min" name="places_min" required>
            {% for i in 1..8 %}
              <option value="{{ i }}" {{ i == 1 ? 'selected' : '' }}>{{ i }}</option>
            {% endfor %}
          </select>
          <label for="places_min">Places</label>
        </div>
      </div>
    </div>

    <button type="submit" class="btn btn-orange btn-lg w-100" data-loading-button data-loading-label="Recherche">
      <i class="bi bi-search"></i>
      Voir les trajets
    </button>
    </div>
  </form>

  <div class="search-discovery">
    <section class="search-discovery__panel">
      <div class="search-discovery__header">
        <p class="app-kicker">Nouveautés</p>
        <h2>Derniers trajets publiés</h2>
      </div>
      <div class="search-mini-list">
        {% for trajet in latestTrajets %}
          <a class="search-mini-card" href="{{ path('app_trajet_show', { id: trajet.id, ledepart: trajet.depart, larrive: trajet.arrivee, nbPlaceReservee: 1 }) }}">
            <span class="search-mini-card__time">
              <strong>{{ trajet.heureTrajet ? trajet.heureTrajet|date('H:i') : '--:--' }}</strong>
              <small>{{ trajet.dateTrajet ? trajet.dateTrajet|date('d/m') : '' }}</small>
            </span>
            <span class="search-mini-card__main">
              <strong>{{ trajet.depart }} vers {{ trajet.arrivee }}</strong>
              <small>{{ trajet.placesDisponibles }} place{{ trajet.placesDisponibles > 1 ? 's' : '' }} disponible{{ trajet.placesDisponibles > 1 ? 's' : '' }}</small>
            </span>
            <span class="search-mini-card__price">{{ trajet.prix|number_format(2, ',', ' ') }} €</span>
          </a>
        {% else %}
          <div class="search-empty-line">Aucun trajet disponible pour le moment.</div>
        {% endfor %}
      </div>
    </section>

    <section class="search-discovery__panel">
      <div class="search-discovery__header">
        <p class="app-kicker">Fréquentés</p>
        <h2>Lignes les plus demandées</h2>
      </div>
      <div class="search-mini-list">
        {% for route in popularRoutes %}
          <a class="search-mini-card" href="{{ path('app_chercher') ~ '?select_departure=' ~ route.depart|url_encode ~ '&select_arrival=' ~ route.arrivee|url_encode ~ '&date_trajet=' ~ todaySearchDate ~ '&places_min=1' }}">
            <span class="search-mini-card__icon"><i class="bi bi-signpost-2"></i></span>
            <span class="search-mini-card__main">
              <strong>{{ route.depart }} vers {{ route.arrivee }}</strong>
              <small>{{ route.total }} réservation{{ route.total > 1 ? 's' : '' }}</small>
            </span>
            <i class="bi bi-chevron-right search-mini-card__arrow"></i>
          </a>
        {% else %}
          <div class="search-empty-line">Les lignes populaires apparaîtront après les premières réservations.</div>
        {% endfor %}
      </div>
    </section>
  </div>
</section>
{% endblock %}
