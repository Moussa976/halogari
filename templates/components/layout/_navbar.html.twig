{% import 'partials/avatar.html.twig' as avatar %}
<nav class="navbar fixed-top navbar-expand-lg app-navbar">
  <div class="container">
    <a class="navbar-brand app-brand" href="{{ path('app_home') }}">
      <img src="{{ asset('images/logo/logo-787x298.png') }}" alt="HaloGari">
    </a>

    <div class="d-none d-lg-flex align-items-center gap-2 ms-auto">
      <a class="app-nav-link {{ app.request.attributes.get('_route') starts with 'app_chercher' ? 'active' : '' }}" href="{{ path('app_chercher') }}">
        <i class="bi bi-search"></i>
        Chercher
      </a>
      <a class="app-nav-link {{ app.request.attributes.get('_route') == 'app_publier' ? 'active' : '' }}" href="{{ path('app_publier') }}">
        <i class="bi bi-plus-circle"></i>
        Publier
      </a>

      <button class="installAppBtn app-nav-link d-none" type="button">
        <i class="bi bi-download"></i>
        Installer
      </button>
      {% if app.user %}
        <a class="app-icon-link position-relative" href="{{ path('app_message') }}" title="Messages">
          <i class="bi bi-chat-dots-fill"></i>
          <span class="message-notif position-absolute top-0 start-100 translate-middle badge rounded-circle bg-danger" style="display:none;">0</span>
        </a>
        <a class="app-icon-link position-relative" href="{{ path('app_notifications') }}" title="Notifications">
          <i class="bi bi-bell-fill"></i>
          <span class="notification-badge position-absolute top-0 start-100 translate-middle badge rounded-circle bg-danger" style="display:none;">0</span>
        </a>
        <button class="app-user-button" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasRight" aria-controls="offcanvasRight">
          {{ avatar.formatSimple(app.user, 38) }}
          <span>{{ app.user.prenom|e }}</span>
        </button>
      {% else %}
        <button class="btn btn-orange app-login-button" type="button" data-bs-toggle="modal" data-bs-target="#modalConnexion">
          <i class="bi bi-box-arrow-in-right"></i>
          Connexion
        </button>
      {% endif %}
    </div>

    <div class="d-flex d-lg-none align-items-center gap-2 ms-auto">
      {% if app.user %}
        <a class="app-icon-link position-relative" href="{{ path('app_message') }}" title="Messages">
          <i class="bi bi-chat-dots-fill"></i>
          <span class="message-notif position-absolute top-0 start-100 translate-middle badge rounded-circle bg-danger" style="display:none;">0</span>
        </a>
        <a class="app-icon-link position-relative" href="{{ path('app_notifications') }}" title="Notifications">
          <i class="bi bi-bell-fill"></i>
          <span class="notification-badge position-absolute top-0 start-100 translate-middle badge rounded-circle bg-danger" style="display:none;">0</span>
        </a>
      {% else %}
        <button class="app-menu-button" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasRight" aria-controls="offcanvasRight">
          <i class="bi bi-list"></i>
        </button>
      {% endif %}
    </div>
  </div>
</nav>

<div class="offcanvas offcanvas-end app-drawer" tabindex="-1" id="offcanvasRight" aria-labelledby="offcanvasRightLabel">
  <div class="offcanvas-header">
    <div id="offcanvasRightLabel">
      <img src="{{ asset('images/logo/logo-787x298.png') }}" alt="HaloGari" class="app-drawer__logo">
      <p class="mb-0 mt-2">{{ app.user ? 'Bonjour ' ~ app.user.prenom : 'Bienvenue sur HaloGari' }}</p>
    </div>
    <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Fermer"></button>
  </div>
  <div class="offcanvas-body">
    {% set currentRoute = app.request.attributes.get('_route') %}
    <div class="app-drawer__actions">
      {% if app.user %}
        <a href="{{ path('app_profile', { id: app.user.id }) }}" class="{{ currentRoute == 'app_profile' ? 'is-active' : '' }}"><i class="bi bi-person"></i> Mon profil</a>
        <a href="{{ path('app_mes_trajets') }}" class="{{ currentRoute == 'app_mes_trajets' ? 'is-active' : '' }}"><i class="bi bi-signpost-2"></i> Mes trajets</a>
        <a href="{{ path('app_mes_reservations') }}" class="app-drawer__mobile-redundant {{ currentRoute == 'app_mes_reservations' ? 'is-active' : '' }}"><i class="bi bi-calendar-check"></i> Mes réservations</a>
        <a href="{{ path('app_mes_paiements') }}" class="{{ currentRoute == 'app_mes_paiements' ? 'is-active' : '' }}"><i class="bi bi-credit-card"></i> Mes paiements</a>
        <a href="{{ path('app_documents') }}" class="{{ currentRoute == 'app_documents' ? 'is-active' : '' }}"><i class="bi bi-file-earmark-text"></i> Mes documents</a>
        <a href="{{ path('app_compte') }}" class="{{ currentRoute == 'app_compte' or currentRoute == 'app_parametres' or currentRoute starts with 'app_mon_' ? 'is-active' : '' }}"><i class="bi bi-person-gear"></i> Mon compte</a>
        <a href="{{ path('app_logout') }}" class="app-drawer__logout" data-loading-button data-loading-label="Déconnexion"><i class="bi bi-box-arrow-right"></i> Déconnexion</a>
      {% else %}
        <button type="button" data-bs-toggle="modal" data-bs-target="#modalConnexion" data-bs-dismiss="offcanvas">
          <i class="bi bi-box-arrow-in-right"></i> Se connecter
        </button>
        <a href="{{ path('app_securite') }}" class="{{ currentRoute == 'app_securite' ? 'is-active' : '' }}"><i class="bi bi-shield-check"></i> Sécurité</a>
      {% endif %}

      <button class="installAppBtn d-none" type="button"><i class="bi bi-download"></i> Installer HaloGari</button>
    </div>
  </div>
</div>

<main class="flex-grow-1 {% if app.request.attributes.get('_route') == 'app_home' %}pt-0{% else %}app-main{% endif %}">
{% set announcementEnabled = platform_setting('announcement.enabled', '0') == '1' %}
{% set announcementTitle = platform_setting('announcement.title', '')|trim %}
{% set announcementMessage = platform_setting('announcement.message', '')|trim %}
{% set announcementType = platform_setting('announcement.type', 'info') %}
{% set announcementLinkUrl = platform_setting('announcement.link_url', '')|trim %}
{% set announcementLinkLabel = platform_setting('announcement.link_label', '')|trim %}
{% set announcementStartDate = platform_setting('announcement.start_date', '')|trim %}
{% set announcementEndDate = platform_setting('announcement.end_date', '')|trim %}
{% set announcementNow = 'now'|date('Y-m-d\\TH:i') %}
{% set announcementIsActive = announcementEnabled
  and announcementMessage
  and (announcementStartDate == '' or announcementStartDate <= announcementNow)
  and (announcementEndDate == '' or announcementEndDate >= announcementNow)
%}
{% if announcementIsActive %}
  {% set announcementIcons = {
    info: 'bi-megaphone-fill',
    maintenance: 'bi-tools',
    warning: 'bi-exclamation-triangle-fill',
    success: 'bi-check-circle-fill'
  } %}
  <section class="platform-announcement platform-announcement--{{ announcementType|default('info') }}" aria-label="Annonce HaloGari">
    <div class="platform-announcement__track">
      {% for i in 1..2 %}
        <div class="platform-announcement__item" aria-hidden="{{ i == 2 ? 'true' : 'false' }}">
          <span class="platform-announcement__badge">
            <i class="bi {{ announcementIcons[announcementType]|default('bi-megaphone-fill') }}"></i>
            HaloGari
          </span>
          {% if announcementTitle %}
            <strong>{{ announcementTitle }}</strong>
          {% endif %}
          <span>{{ announcementMessage }}</span>
          {% if announcementLinkUrl %}
            <a href="{{ announcementLinkUrl }}" class="platform-announcement__link">
              {{ announcementLinkLabel ?: 'En savoir plus' }}
            </a>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </section>
{% endif %}
