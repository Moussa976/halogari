{% set login_id_prefix = login_id_prefix|default('') %}
{% set email_id = login_id_prefix ~ 'inputEmail' %}
{% set password_id = login_id_prefix ~ 'inputPassword' %}

<form class="app-panel app-panel--form auth-form" method="post" action="{{ path('app_login') }}">
	{% if error is defined and error %}
		<div class="alert alert-danger text-center">
			<i class="bi bi-exclamation-triangle-fill"></i>
			{{ error.messageKey|trans(error.messageData, 'security') }}
		</div>
	{% endif %}

	<div class="auth-form__heading">
		<span><i class="bi bi-person-check-fill"></i></span>
		<div>
			<h2>Bienvenue</h2>
			<p>Connectez-vous en quelques secondes.</p>
		</div>
	</div>

	<div class="input-group auth-input-group">
		<span class="input-group-text">
			<i class="bi bi-envelope"></i>
		</span>
		<div class="form-floating">
			<input type="email" id="{{ email_id }}" name="email" class="form-control" placeholder="exemple@halogari.yt" value="{{ last_username|default('') }}" autocomplete="email" inputmode="email" required autofocus>
			<label for="{{ email_id }}">Adresse e-mail</label>
		</div>
	</div>

	<div class="input-group auth-input-group password-input-group">
		<span class="input-group-text">
			<i class="bi bi-lock-fill"></i>
		</span>
		<div class="form-floating">
			<input type="password" id="{{ password_id }}" name="password" class="form-control" placeholder="Votre mot de passe" autocomplete="current-password" required>
			<label for="{{ password_id }}">Mot de passe</label>
		</div>
		<button class="btn btn-outline-secondary toggle-password" type="button" data-target="{{ password_id }}" aria-label="Afficher ou masquer le mot de passe">
			<i class="bi bi-eye-slash-fill"></i>
		</button>
	</div>

	<input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

	<div class="auth-form__links">
		<a class="link-secondary text-decoration-none" href="{{ path('app_forgot_password_request') }}">
			<i class="bi bi-question-circle"></i>
			Mot de passe oublié ?
		</a>
	</div>

	<button type="submit" class="btn btn-orange auth-form__submit">
		<i class="bi bi-box-arrow-in-right"></i>
		Se connecter
	</button>

	<div class="auth-form__register">
		<span>Pas encore de compte ?</span>
		<a class="btn btn-success" href="{{ path('app_register') }}">
			<i class="bi bi-person-plus-fill"></i>
			S'inscrire
		</a>
	</div>
</form>
