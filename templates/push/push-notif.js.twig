{# templates/push/push-notif.js.twig #}

const VAPID_PUBLIC_KEY = '{{ vapidPublicKey }}';
const HALOGARI_PUSH_TIMEOUT_MS = 8000;

function withPushTimeout(promise, label) {
  return Promise.race([
    promise,
    new Promise((_, reject) => {
      window.setTimeout(() => reject(new Error(`${label} timeout`)), HALOGARI_PUSH_TIMEOUT_MS);
    })
  ]);
}

function urlBase64ToUint8Array(base64String) {
  const padding = '='.repeat((4 - base64String.length % 4) % 4);
  const base64 = (base64String + padding).replace(/-/g, '+').replace(/_/g, '/');
  const rawData = atob(base64);
  return Uint8Array.from([...rawData].map(char => char.charCodeAt(0)));
}

async function subscribeToPush() {
  if (!('serviceWorker' in navigator) || !('PushManager' in window)) {
    alert('Notifications non supportées sur ce navigateur.');
    return false;
  }

  try {
    const registration = await withPushTimeout(navigator.serviceWorker.ready, 'Service worker');
    const subscription = await registration.pushManager.getSubscription()
      || await withPushTimeout(registration.pushManager.subscribe({
        userVisibleOnly: true,
        applicationServerKey: urlBase64ToUint8Array(VAPID_PUBLIC_KEY)
      }), 'Push subscription');

    const response = await withPushTimeout(fetch('/abonnement-push', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(subscription)
    }), 'Push save');

    if (response.ok) {
      localStorage.setItem('halogariPushSubscribed', '1');
      console.log('Abonnement Push enregistré');
      return true;
    }

    console.error("Erreur lors de l'envoi de l'abonnement Push");
  } catch (error) {
    console.error('Abonnement Push impossible', error);
  }

  localStorage.removeItem('halogariPushSubscribed');
  return false;
}

window.subscribeToHaloGariPush = subscribeToPush;

document.addEventListener('DOMContentLoaded', () => {
  const ua = navigator.userAgent.toLowerCase();
  const isIos = /iphone|ipad|ipod/.test(ua);
  const isInStandaloneMode = window.matchMedia('(display-mode: standalone)').matches
    || (('standalone' in window.navigator) && window.navigator.standalone);
  const installHelpStorageKey = 'halogariIosInstallHelpSeen';

  if (isInStandaloneMode) {
    localStorage.setItem('halogariPwaInstalled', '1');
  }

  if (isIos && !isInStandaloneMode && !localStorage.getItem(installHelpStorageKey)) {
    setTimeout(() => {
      Swal.fire({
        icon: 'info',
        title: 'Installer HaloGari',
        html: `Pour installer HaloGari sur iPhone, ouvrez le menu de partage puis choisissez <strong>Sur l’écran d’accueil</strong>.<br><br>
               Les étapes complètes sont disponibles dans l'assistant d'aide et la FAQ.`,
        confirmButtonText: "J'ai compris",
        showDenyButton: true,
        denyButtonText: 'Ne plus afficher'
      }).then((result) => {
        if (result.isConfirmed || result.isDenied) {
          localStorage.setItem(installHelpStorageKey, '1');
        }
      });
    }, 10000);
  }

  if ('Notification' in window && Notification.permission === 'granted') {
    subscribeToPush();
  }
});
